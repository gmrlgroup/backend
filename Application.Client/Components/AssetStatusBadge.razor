@using Application.Shared.Enums

@* Renders a colored status badge for AssetStatus *@

<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @GetClass()">
    <span class="w-1.5 h-1.5 rounded-full mr-1.5 @GetDotClass()"></span>
    @Status.ToString()
</span>

@code {
    [Parameter, EditorRequired] public AssetStatus Status { get; set; }

    private string GetClass() => Status switch
    {
        AssetStatus.Online      => "bg-green-100 text-green-800",
        AssetStatus.Offline     => "bg-red-100 text-red-800",
        AssetStatus.Degraded    => "bg-yellow-100 text-yellow-800",
        AssetStatus.Maintenance => "bg-blue-100 text-blue-800",
        AssetStatus.Error       => "bg-red-100 text-red-900",
        _                       => "bg-gray-100 text-gray-600"
    };

    private string GetDotClass() => Status switch
    {
        AssetStatus.Online      => "bg-green-500",
        AssetStatus.Offline     => "bg-red-500",
        AssetStatus.Degraded    => "bg-yellow-500",
        AssetStatus.Maintenance => "bg-blue-500",
        AssetStatus.Error       => "bg-red-700",
        _                       => "bg-gray-400"
    };
}
