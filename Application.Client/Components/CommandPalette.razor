@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@implements IAsyncDisposable
@inject NavigationManager _navigation
@inject StateContainer _stateContainer
@inject IJSRuntime _js
@inject AuthenticationStateProvider _authProvider
@inject HttpClient _http
@inject MonitoredAssetClientService _entityService
@inject IncidentClientService _incidentService

@if (open)
{
    <div class="cp-overlay" @onclick="Close">
        <div class="cp-panel" @onclick:stopPropagation="true">

            <div class="cp-search-row">
                @if (IsResourceMode)
                {
                    <span class="cp-mode-chip cp-mode-resource">#</span>
                }
                else
                {
                    <svg class="cp-search-icon" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" />
                    </svg>
                }
                <input @ref="searchInput" class="cp-input"
                       placeholder="@(IsResourceMode ? "Pick a category: datasets · entities · incidents" : "Search pages…  (type # for data)")"
                       @bind="search" @bind:event="oninput" @bind:after="OnSearchChanged"
                       @onkeydown="HandleKey" autocomplete="off" spellcheck="false" />
                <kbd class="cp-esc">esc</kbd>
            </div>

            <div class="cp-results">
                @if (IsResourceMode)
                {
                    var kind = DetectKind(TypeToken);
                    if (kind is null)
                    {
                        @* ---- Category chooser ---- *@
                        var opts = FilteredKindOptions();
                        if (opts.Count == 0)
                        {
                            <div class="cp-empty">
                                <svg width="34" height="34" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" /></svg>
                                <p>No category matches "<strong>@TypeToken</strong>"</p>
                            </div>
                        }
                        else
                        {
                            <div class="cp-group-label">Categories</div>
                            var oIndex = 0;
                            foreach (var opt in opts)
                            {
                                var idx = oIndex++;
                                var isActive = idx == selectedIndex;
                                <button type="button" style="border:none;"
                                        class="cp-item @(isActive ? "cp-item-active" : "")"
                                        @onclick="() => SelectKind(opt)"
                                        @onmouseenter="() => selectedIndex = idx">
                                    <span class="cp-icon cp-icon-@opt.Color">@((MarkupString)ResourceIcon(opt.Kind))</span>
                                    <span class="cp-text">
                                        <span class="cp-name">@opt.Label</span>
                                        <span class="cp-desc">@opt.Description</span>
                                    </span>
                                    <span class="cp-route">#@opt.Keyword</span>
                                </button>
                            }
                        }
                    }
                    else if (loadingKinds.Contains(kind))
                    {
                        <div class="cp-empty"><div class="cp-spinner"></div><p>Loading @KindLabel(kind).ToLower()…</p></div>
                    }
                    else
                    {
                        @* ---- Items of the chosen category ---- *@
                        var items = FilteredKindItems(kind);
                        if (items.Count == 0)
                        {
                            var loadedCount = kindCache.TryGetValue(kind, out var all) ? all.Count : 0;
                            <div class="cp-empty">
                                <svg width="34" height="34" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" /></svg>
                                <p>@(loadedCount == 0 ? $"No {KindLabel(kind).ToLower()} found" : $"No matches for \"{ItemFilter}\"")</p>
                            </div>
                        }
                        else
                        {
                            <div class="cp-group-label">@KindLabel(kind) <span class="cp-count">@items.Count</span></div>
                            var rIndex = 0;
                            foreach (var item in items)
                            {
                                var idx = rIndex++;
                                var isActive = idx == selectedIndex;
                                <button type="button" style="border:none;"
                                        class="cp-item @(isActive ? "cp-item-active" : "")"
                                        @onclick="() => NavigateResource(item)"
                                        @onmouseenter="() => selectedIndex = idx">
                                    <span class="cp-icon cp-icon-@item.Color">@((MarkupString)ResourceIcon(item.Kind))</span>
                                    <span class="cp-text">
                                        <span class="cp-name">@item.Name</span>
                                        <span class="cp-desc">@item.Subtitle</span>
                                    </span>
                                    @if (isActive)
                                    {
                                        <span class="cp-route">tab ↵</span>
                                    }
                                </button>
                            }
                        }
                    }
                }
                else
                {
                    var pages = FilteredPages();
                    if (pages.Count == 0)
                    {
                        <div class="cp-empty">
                            <svg width="34" height="34" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" /></svg>
                            <p>No pages match "<strong>@search</strong>"</p>
                        </div>
                    }
                    else
                    {
                        var pIndex = 0;
                        foreach (var group in pages.GroupBy(p => p.Category))
                        {
                            <div class="cp-group-label">@group.Key</div>
                            foreach (var entry in group)
                            {
                                var idx = pIndex++;
                                var isActive = idx == selectedIndex;
                                <button type="button" style="border:none;"
                                        class="cp-item @(isActive ? "cp-item-active" : "")"
                                        @onclick="() => Navigate(entry)"
                                        @onmouseenter="() => selectedIndex = idx">
                                    <span class="cp-icon cp-icon-@entry.Color">@((MarkupString)CategoryIcon(entry.Category))</span>
                                    <span class="cp-text">
                                        <span class="cp-name">@entry.Name</span>
                                        <span class="cp-desc">@entry.Description</span>
                                    </span>
                                    <span class="cp-route">@entry.Route</span>
                                </button>
                            }
                        }
                    }
                }
            </div>

            <div class="cp-footer">
                <span><kbd>↑</kbd><kbd>↓</kbd> navigate</span>
                <span><kbd>↵</kbd>/<kbd>tab</kbd> select</span>
                <span><kbd>/</kbd> pages · <kbd>#</kbd> data</span>
            </div>
        </div>
    </div>
}

<style>
    .cp-overlay {
        position: fixed; inset: 0; z-index: 1000;
        display: flex; align-items: flex-start; justify-content: center;
        padding: 12vh 16px 16px;
        background: rgba(17, 24, 39, .45);
        backdrop-filter: blur(4px);
        animation: cp-fade .12s ease;
    }
    @@keyframes cp-fade { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes cp-pop { from { opacity: 0; transform: translateY(-8px) scale(.98); } to { opacity: 1; transform: none; } }
    @@keyframes cp-spin { to { transform: rotate(360deg); } }

    .cp-panel {
        width: 100%; max-width: 620px;
        background: #fff; border-radius: 16px;
        box-shadow: 0 24px 60px rgba(0,0,0,.28), 0 0 0 1px rgba(0,0,0,.04);
        overflow: hidden;
        display: flex; flex-direction: column;
        max-height: 70vh;
        animation: cp-pop .14s ease;
    }

    .cp-search-row {
        display: flex; align-items: center; gap: 12px;
        padding: 16px 18px; border-bottom: 1px solid #f1f1f4;
    }
    .cp-search-icon { color: #9ca3af; flex-shrink: 0; }
    .cp-mode-chip {
        flex-shrink: 0; width: 26px; height: 26px; border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 15px;
    }
    .cp-mode-resource { background: #eff6ff; color: #2563eb; }
    .cp-input {
        flex: 1; border: none; outline: none;
        font-size: 16px; color: #111827; background: transparent;
    }
    .cp-input::placeholder { color: #9ca3af; }
    .cp-esc {
        font-size: 11px; color: #9ca3af; background: #f3f4f6;
        border-radius: 6px; padding: 3px 7px; font-family: inherit; flex-shrink: 0;
    }

    .cp-results { overflow-y: auto; padding: 8px; }

    .cp-group-label {
        padding: 10px 10px 4px; font-size: 10.5px; font-weight: 600;
        text-transform: uppercase; letter-spacing: .07em; color: #9ca3af;
        display: flex; align-items: center; gap: 6px;
    }
    .cp-count {
        font-size: 10px; color: #9ca3af; background: #f3f4f6;
        border-radius: 999px; padding: 0 6px; font-weight: 600;
    }

    .cp-item {
        display: flex; align-items: center; gap: 12px;
        width: 100%; text-align: left; cursor: pointer;
        padding: 9px 10px; border-radius: 10px; background: transparent;
        transition: background .08s;
    }
    .cp-item-active { background: #f5f3ff; }

    .cp-icon {
        width: 34px; height: 34px; border-radius: 9px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
    }
    .cp-icon svg { width: 17px; height: 17px; }
    .cp-icon-slate   { background: #f1f5f9; color: #475569; }
    .cp-icon-blue    { background: #eff6ff; color: #2563eb; }
    .cp-icon-violet  { background: #f5f3ff; color: #7c3aed; }
    .cp-icon-emerald { background: #ecfdf5; color: #059669; }
    .cp-icon-amber   { background: #fffbeb; color: #d97706; }
    .cp-icon-rose    { background: #fff1f2; color: #e11d48; }
    .cp-icon-gray    { background: #f3f4f6; color: #4b5563; }

    .cp-text { display: flex; flex-direction: column; min-width: 0; flex: 1; }
    .cp-name { font-size: 14px; font-weight: 600; color: #111827; }
    .cp-desc {
        font-size: 12px; color: #6b7280; overflow: hidden;
        text-overflow: ellipsis; white-space: nowrap;
    }
    .cp-route {
        font-size: 11px; color: #9ca3af; font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        background: #f9fafb; border: 1px solid #f1f1f4; border-radius: 6px;
        padding: 2px 7px; flex-shrink: 0;
    }
    .cp-item-active .cp-route { color: #7c3aed; border-color: #ede9fe; background: #faf5ff; }

    .cp-empty {
        display: flex; flex-direction: column; align-items: center; gap: 10px;
        padding: 44px 16px; color: #9ca3af; text-align: center;
    }
    .cp-empty p { margin: 0; font-size: 13.5px; }
    .cp-empty strong { color: #6b7280; }
    .cp-spinner {
        width: 26px; height: 26px; border-radius: 50%;
        border: 3px solid #ede9fe; border-top-color: #7c3aed;
        animation: cp-spin .7s linear infinite;
    }

    .cp-footer {
        display: flex; gap: 18px; align-items: center;
        padding: 10px 18px; border-top: 1px solid #f1f1f4;
        font-size: 11.5px; color: #9ca3af; background: #fcfcfd;
    }
    .cp-footer kbd {
        font-family: inherit; font-size: 11px; color: #6b7280;
        background: #fff; border: 1px solid #e5e7eb; border-bottom-width: 2px;
        border-radius: 5px; padding: 1px 5px; margin-right: 3px;
    }
</style>

@code {
    private bool open;
    private string search = string.Empty;
    private int selectedIndex;
    private ElementReference searchInput;
    private DotNetObjectReference<CommandPalette>? selfRef;
    private System.Security.Claims.ClaimsPrincipal? user;
    private bool listenerRegistered;

    // Resource mode (#) state — data is loaded per category, on demand.
    private readonly Dictionary<string, List<ResourceItem>> kindCache = new();
    private readonly HashSet<string> loadingKinds = new();
    private string? resourcesCompany;

    private string CompanyQuery => _stateContainer.Company is null ? "" : $"?c={_stateContainer.Company.Id}";
    private string? CompanyId => _stateContainer.Company?.Id;

    private bool IsResourceMode => search.StartsWith("#");

    // After "#": the first word selects the category, the rest filters within it.
    private string AfterHash => search.Length > 0 ? search.Substring(1) : "";
    private string TypeToken
    {
        get { var s = AfterHash; var i = s.IndexOf(' '); return (i < 0 ? s : s.Substring(0, i)).Trim(); }
    }
    private string ItemFilter
    {
        get { var s = AfterHash; var i = s.IndexOf(' '); return i < 0 ? "" : s.Substring(i + 1).Trim(); }
    }

    protected override async Task OnInitializedAsync()
    {
        user = (await _authProvider.GetAuthenticationStateAsync()).User;
        _authProvider.AuthenticationStateChanged += OnAuthChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !listenerRegistered)
        {
            selfRef = DotNetObjectReference.Create(this);
            await _js.InvokeVoidAsync("commandPalette.register", selfRef);
            listenerRegistered = true;
        }
    }

    [JSInvokable]
    public async Task OpenFromJs(string key)
    {
        open = true;
        selectedIndex = 0;
        search = key == "#" ? "#" : string.Empty;
        await InvokeAsync(StateHasChanged);
        await _js.InvokeVoidAsync("commandPalette.focus", searchInput);
    }

    private void Close() => open = false;

    private async Task OnSearchChanged()
    {
        selectedIndex = 0;
        if (IsResourceMode)
        {
            var kind = DetectKind(TypeToken);
            if (kind is not null) await EnsureKindLoaded(kind);
        }
    }

    private void HandleKey(KeyboardEventArgs e)
    {
        var count = CurrentCount();
        switch (e.Key)
        {
            case "Escape":
                Close();
                break;
            case "ArrowDown":
                if (count > 0) selectedIndex = (selectedIndex + 1) % count;
                break;
            case "ArrowUp":
                if (count > 0) selectedIndex = (selectedIndex - 1 + count) % count;
                break;
            case "Enter":
            case "Tab":
                _ = NavigateSelected();
                break;
        }
    }

    private int CurrentCount()
    {
        if (!IsResourceMode) return FilteredPages().Count;
        var kind = DetectKind(TypeToken);
        if (kind is null) return FilteredKindOptions().Count;
        return FilteredKindItems(kind).Count;
    }

    private async Task NavigateSelected()
    {
        if (IsResourceMode)
        {
            var kind = DetectKind(TypeToken);
            if (kind is null)
            {
                var opts = FilteredKindOptions();
                if (selectedIndex >= 0 && selectedIndex < opts.Count) await SelectKind(opts[selectedIndex]);
            }
            else
            {
                var items = FilteredKindItems(kind);
                if (selectedIndex >= 0 && selectedIndex < items.Count) NavigateResource(items[selectedIndex]);
            }
        }
        else
        {
            var p = FilteredPages();
            if (selectedIndex >= 0 && selectedIndex < p.Count) Navigate(p[selectedIndex]);
        }
    }

    // ---------- Pages (/) ----------

    private List<PageEntry> FilteredPages() => VisiblePages.Where(MatchesPage).ToList();

    private bool MatchesPage(PageEntry p)
    {
        var q = search?.Trim();
        if (string.IsNullOrEmpty(q)) return true;
        return p.Name.Contains(q, StringComparison.OrdinalIgnoreCase)
            || p.Description.Contains(q, StringComparison.OrdinalIgnoreCase)
            || p.Route.Contains(q, StringComparison.OrdinalIgnoreCase)
            || p.Category.Contains(q, StringComparison.OrdinalIgnoreCase);
    }

    private IEnumerable<PageEntry> VisiblePages => AllPages.Where(CanAccess);

    private bool CanAccess(PageEntry p)
    {
        if (user?.Identity?.IsAuthenticated != true) return false;
        if (p.Roles is null) return true;
        return HasAnyRole(p.Roles);
    }

    private void Navigate(PageEntry page)
    {
        open = false;
        var href = page.CompanyScoped ? $"{page.Route}{CompanyQuery}" : page.Route;
        _navigation.NavigateTo(href);
    }

    // ---------- Resources (#) ----------

    private static string? DetectKind(string token) => token.ToLowerInvariant() switch
    {
        "dataset" or "datasets" => "Dataset",
        "entity" or "entities" => "Entity",
        "incident" or "incidents" => "Incident",
        _ => null
    };

    private List<KindOption> FilteredKindOptions()
    {
        var token = TypeToken;
        return KindOptions
            .Where(o => KindAccessible(o.Kind))
            .Where(o => string.IsNullOrEmpty(token)
                        || o.Keyword.StartsWith(token, StringComparison.OrdinalIgnoreCase)
                        || o.Label.Contains(token, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private List<ResourceItem> FilteredKindItems(string kind)
    {
        if (!kindCache.TryGetValue(kind, out var all)) return new();
        var q = ItemFilter;
        if (string.IsNullOrEmpty(q)) return all;
        return all.Where(r =>
            r.Name.Contains(q, StringComparison.OrdinalIgnoreCase)
            || r.Subtitle.Contains(q, StringComparison.OrdinalIgnoreCase)).ToList();
    }

    private async Task SelectKind(KindOption opt)
    {
        // Complete the keyword and drop into filter mode for that category.
        search = $"#{opt.Keyword} ";
        selectedIndex = 0;
        await EnsureKindLoaded(opt.Kind);
        await _js.InvokeVoidAsync("commandPalette.focus", searchInput);
    }

    private async Task EnsureKindLoaded(string kind)
    {
        var company = CompanyId;
        if (string.IsNullOrEmpty(company)) return;

        // Invalidate the cache if the active company changed.
        if (resourcesCompany != company)
        {
            kindCache.Clear();
            resourcesCompany = company;
        }

        if (kindCache.ContainsKey(kind) || loadingKinds.Contains(kind)) return;
        if (!KindAccessible(kind)) { kindCache[kind] = new(); return; }

        loadingKinds.Add(kind);
        await InvokeAsync(StateHasChanged);
        try
        {
            var items = kind switch
            {
                "Dataset" => await LoadDatasets(company),
                "Entity" => (await _entityService.GetEntitiesAsync(company)).Select(e => new ResourceItem(
                    "Entity", e.Id, string.IsNullOrWhiteSpace(e.Name) ? "(unnamed entity)" : e.Name!,
                    EntitySubtitle(e), "violet")).ToList(),
                "Incident" => (await _incidentService.GetIncidentsAsync(company)).Select(i => new ResourceItem(
                    "Incident", i.Id, string.IsNullOrWhiteSpace(i.Title) ? "(untitled incident)" : i.Title,
                    $"{i.Severity} · {i.Status}", "rose")).ToList(),
                _ => new List<ResourceItem>()
            };
            kindCache[kind] = items;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"CommandPalette load '{kind}' failed: {ex.Message}");
            kindCache[kind] = new();
        }
        finally
        {
            loadingKinds.Remove(kind);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<List<ResourceItem>> LoadDatasets(string company)
    {
        _http.DefaultRequestHeaders.Remove("X-Company-Id");
        _http.DefaultRequestHeaders.Add("X-Company-Id", company);
        var userId = user?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (!string.IsNullOrEmpty(userId))
        {
            _http.DefaultRequestHeaders.Remove("UserId");
            _http.DefaultRequestHeaders.Add("UserId", userId);
        }
        var ds = await _http.GetFromJsonAsync<List<Dataset>>("api/datasets") ?? new();
        return ds.Select(d => new ResourceItem(
            "Dataset", d.Id ?? "", string.IsNullOrWhiteSpace(d.Name) ? "(untitled dataset)" : d.Name!,
            d.Description ?? "", "blue")).ToList();
    }

    private void NavigateResource(ResourceItem item)
    {
        open = false;
        // Datasets "open" into the Tables view of their data (matches the list page's Open action);
        // entities/incidents open their detail pages.
        var href = item.Kind switch
        {
            "Dataset" => $"data/tables?c={CompanyId}&d={item.Id}",
            "Entity" => $"status/entities/{item.Id}{CompanyQuery}",
            "Incident" => $"status/incidents/{item.Id}{CompanyQuery}",
            _ => "/"
        };
        _navigation.NavigateTo(href);
    }

    private bool KindAccessible(string kind) => kind switch
    {
        "Dataset" => HasAnyRole(new[] { "VIEW_DATA" }),
        "Entity" => HasAnyRole(new[] { "STATUS_READ", "INCIDENTS" }),
        "Incident" => HasAnyRole(new[] { "STATUS_READ", "INCIDENTS" }),
        _ => false
    };

    private static string EntitySubtitle(MonitoredAsset e)
    {
        if (!string.IsNullOrWhiteSpace(e.Description)) return e.Description!;
        var parts = new List<string> { e.EntityType.ToString() };
        if (!string.IsNullOrWhiteSpace(e.Owner)) parts.Add(e.Owner!);
        return string.Join(" · ", parts);
    }

    // ---------- Shared ----------

    private bool HasAnyRole(string[] suffixes)
    {
        var company = CompanyId;
        if (user?.Identity?.IsAuthenticated != true || string.IsNullOrEmpty(company)) return false;
        if (user.IsInRole($"{company}_ADMIN")) return true;
        return suffixes.Any(s => user.IsInRole($"{company}_{s}"));
    }

    private void OnAuthChanged(Task<AuthenticationState> task)
    {
        _ = InvokeAsync(async () =>
        {
            user = (await task).User;
            kindCache.Clear();
            StateHasChanged();
        });
    }

    public async ValueTask DisposeAsync()
    {
        _authProvider.AuthenticationStateChanged -= OnAuthChanged;
        if (listenerRegistered)
        {
            try { await _js.InvokeVoidAsync("commandPalette.unregister"); } catch { }
        }
        selfRef?.Dispose();
    }

    private record PageEntry(
        string Name, string Route, string Description, string Category,
        string Color, string[]? Roles, bool CompanyScoped = true);

    private record ResourceItem(string Kind, string Id, string Name, string Subtitle, string Color);

    private record KindOption(string Kind, string Keyword, string Label, string Description, string Color);

    private static readonly KindOption[] KindOptions =
    {
        new("Dataset", "datasets", "Datasets", "Browse and open a dataset", "blue"),
        new("Entity", "entities", "Entities", "Open a monitored asset", "violet"),
        new("Incident", "incidents", "Incidents", "Open a reported incident", "rose"),
    };

    private static string KindLabel(string kind) => kind switch
    {
        "Dataset" => "Datasets",
        "Entity" => "Entities",
        "Incident" => "Incidents",
        _ => kind
    };

    private static readonly PageEntry[] AllPages =
    {
        new("Home", "/", "Workspace overview and entry point", "General", "slate", null),
        new("Profile", "Account/Manage", "Manage your account, email, and security", "General", "slate", null, CompanyScoped: false),

        new("Datasets", "data/datasets", "Browse and manage your datasets", "Data", "blue", new[] { "VIEW_DATA" }),
        new("Create Dataset", "data/datasets/create", "Define a new dataset", "Data", "blue", new[] { "EDIT_DATA" }),
        new("Import Data", "data/import", "Upload files and import data", "Data", "blue", new[] { "EDIT_DATA" }),
        new("Query Workbench", "data/query", "Run ad-hoc SQL queries", "Data", "blue", new[] { "VIEW_DATA" }),
        new("View Data", "data/view", "Inspect stored data and tables", "Data", "blue", new[] { "VIEW_DATA" }),
        new("Tables", "data/tables", "Manage database tables", "Data", "blue", new[] { "VIEW_DATA" }),
        new("Ingestion Sources", "data/ingestion", "Configure data ingestion pipelines", "Data", "blue", new[] { "EDIT_DATA" }),
        new("API Keys", "data/api-keys", "Create and manage API keys", "Data", "blue", null),

        new("Data Warehouse", "datawarehouse", "Explore the read-only data warehouse", "Analytics", "violet", new[] { "DATA_WAREHOUSE" }),
        new("Metrics", "metrics", "Track and analyze business metrics", "Analytics", "violet", new[] { "METRICS_READ", "METRICS_WRITE" }),

        new("Daily Inventory", "demand/daily-inventory", "Stock positions with rolling sales", "Demand", "emerald", new[] { "INVENTORY_READ" }),
        new("Daily Inventory (AG Grid)", "demand/daily-inventory-aggrid", "Inventory in a high-density grid", "Demand", "emerald", new[] { "INVENTORY_READ" }),

        new("Sales Dashboard", "realtime/sales-dashboard", "Live real-time sales stream", "Stream", "amber", new[] { "SALES" }),

        new("Status Board", "status/board", "Public service status overview", "Status", "rose", null),
        new("Monitoring Overview", "status", "Health summary across all entities", "Status", "rose", new[] { "STATUS_READ", "INCIDENTS" }),
        new("Entities", "status/entities", "Monitored assets and dependencies", "Status", "rose", new[] { "STATUS_READ", "INCIDENTS" }),
