@using System.Globalization
@using Application.Client.Models
@inject IJSRuntime JSRuntime

<style>
    .drt-wrap { display: flex; flex-direction: column; height: 100%; }
    .drt-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 48px; gap: 8px; color: #94a3b8; }
    .drt-empty-icon { font-size: 32px; }
    .drt-toolbar { display: flex; align-items: center; justify-content: space-between; padding: 10px 0 10px 0; gap: 8px; flex-wrap: wrap; }
    .drt-record-count { font-size: 13px; color: #64748b; }
    .drt-toolbar-right { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .drt-search { height: 32px; padding: 0 10px; border: 1px solid #e2e8f0; border-radius: 6px; font-size: 13px; outline: none; width: 220px; }
    .drt-search:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,0.1); }
    .drt-btn { display: inline-flex; align-items: center; gap: 4px; height: 32px; padding: 0 12px; border: 1px solid #e2e8f0; background: white; border-radius: 6px; font-size: 13px; cursor: pointer; color: #374151; transition: all 0.15s; }
    .drt-btn:hover { background: #f9fafb; }
    .drt-table-container { overflow: auto; flex: 1; border: 1px solid #e2e8f0; border-radius: 8px; }
    .drt-table { width: 100%; border-collapse: collapse; font-size: 13px; min-width: 600px; }
    .drt-table thead th { background: #f8fafc; padding: 8px 12px; text-align: left; font-weight: 600; color: #374151; border-bottom: 1px solid #e2e8f0; white-space: nowrap; cursor: pointer; user-select: none; }
    .drt-table thead th:hover { background: #f1f5f9; }
    .drt-table thead th.sorted { color: #6366f1; }
    .drt-sort-icon { margin-left: 4px; font-size: 10px; color: #6366f1; }
    .drt-filter-th { padding: 4px 4px; background: #f8fafc; border-bottom: 1px solid #e2e8f0; }
    .drt-filter-input { width: 100%; height: 26px; padding: 0 6px; border: 1px solid #e2e8f0; border-radius: 4px; font-size: 12px; outline: none; background: white; }
    .drt-filter-input:focus { border-color: #6366f1; }
    .drt-table tbody tr { border-bottom: 1px solid #f1f5f9; transition: background 0.1s; }
    .drt-table tbody tr:hover { background: #f8fafc; }
    .drt-table tbody td { padding: 8px 12px; color: #0f172a; vertical-align: middle; }
    .drt-table .align-right td, td.align-right { text-align: right; }
    .drt-table .align-center td, td.align-center { text-align: center; }
    .drt-footer { display: flex; align-items: center; justify-content: space-between; padding: 10px 0 0 0; flex-wrap: wrap; gap: 8px; }
    .drt-page-info { font-size: 13px; color: #64748b; }
    .drt-page-controls { display: flex; align-items: center; gap: 4px; }
    .drt-page-btn { width: 32px; height: 32px; border: 1px solid #e2e8f0; background: white; border-radius: 6px; font-size: 13px; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; color: #374151; transition: all 0.15s; }
    .drt-page-btn:hover:not(:disabled) { background: #f1f5f9; }
    .drt-page-btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .drt-page-btn.active { background: #6366f1; color: white; border-color: #6366f1; }
</style>

<div class="drt-wrap">
    @if (Data == null || !Data.Any())
    {
        <div class="drt-empty">
            <div class="drt-empty-icon">🗄️</div>
            <span>@EmptyMessage</span>
        </div>
    }
    else
    {
        <div class="drt-toolbar">
            <span class="drt-record-count">@GetRecordCountText()</span>
            <div class="drt-toolbar-right">
                @if (ShowGlobalFilter)
                {
                    <input type="text" class="drt-search" placeholder="Search all columns..."
                           value="@GlobalFilter"
                           @oninput="@(e => { GlobalFilter = e.Value?.ToString() ?? ""; ApplyFilters(); })" />
                }
                @if (AdditionalToolbarContent != null)
                {
                    @AdditionalToolbarContent
                }
                @if (ShowExport)
                {
                    <button class="drt-btn" @onclick="ExportToCsv">⬇ Export</button>
                }
            </div>
        </div>

        <div class="drt-table-container">
            <table class="drt-table">
                <thead>
                    <tr>
                        @foreach (var column in Columns)
                        {
                            var sorted = column == SortColumn ? "sorted" : "";
                            <th class="@sorted" @onclick="@(() => ToggleSort(column))">
                                @FormatColumnHeader(column)
                                @if (column == SortColumn)
                                {
                                    <span class="drt-sort-icon">@(SortAscending ? "▲" : "▼")</span>
                                }
                            </th>
                        }
                    </tr>
                    @if (ShowColumnFilters)
                    {
                        <tr>
                            @foreach (var column in Columns)
                            {
                                <th class="drt-filter-th">
                                    <input type="text" class="drt-filter-input" placeholder="Filter..."
                                           value="@ColumnFilters[column]"
                                           @oninput="@(e => { ColumnFilters[column] = e.Value?.ToString() ?? ""; ApplyFilters(); })" />
                                </th>
                            }
                        </tr>
                    }
                </thead>
                <tbody>
                    @foreach (var row in PagedData)
                    {
                        <tr @onclick="@(() => OnRowClick.InvokeAsync(row))">
                            @foreach (var column in Columns)
                            {
                                <td class="@GetCellAlignmentClass(column, row)">
                                    @((MarkupString)FormatCellValue(column, row.TryGetValue(column, out var value) ? value : null))
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (ShowPagination && TotalPages > 1)
        {
            <div class="drt-footer">
                <span class="drt-page-info">
                    Showing @(((CurrentPage - 1) * PageSize) + 1)–@Math.Min(CurrentPage * PageSize, FilteredData.Count) of @FilteredData.Count
                </span>
                <div class="drt-page-controls">
                    <button class="drt-page-btn" disabled="@(CurrentPage == 1)" @onclick="() => GoToPage(1)">«</button>
                    <button class="drt-page-btn" disabled="@(CurrentPage == 1)" @onclick="() => GoToPage(CurrentPage - 1)">‹</button>
                    @for (int p = Math.Max(1, CurrentPage - 2); p <= Math.Min(TotalPages, CurrentPage + 2); p++)
                    {
                        var pg = p;
                        <button class="drt-page-btn @(pg == CurrentPage ? "active" : "")" @onclick="() => GoToPage(pg)">@pg</button>
                    }
                    <button class="drt-page-btn" disabled="@(CurrentPage == TotalPages)" @onclick="() => GoToPage(CurrentPage + 1)">›</button>
                    <button class="drt-page-btn" disabled="@(CurrentPage == TotalPages)" @onclick="() => GoToPage(TotalPages)">»</button>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public List<Dictionary<string, object?>>? Data { get; set; }
    [Parameter] public Dictionary<string, ColumnFormat>? ColumnFormats { get; set; }
    [Parameter] public string EmptyMessage { get; set; } = "No data available";
    [Parameter] public bool ShowGlobalFilter { get; set; } = true;
    [Parameter] public bool ShowColumnFilters { get; set; } = true;
    [Parameter] public bool ShowPagination { get; set; } = true;
    [Parameter] public bool ShowExport { get; set; } = true;
    [Parameter] public int PageSize { get; set; } = 50;
    [Parameter] public RenderFragment? AdditionalToolbarContent { get; set; }
    [Parameter] public EventCallback<Dictionary<string, object?>> OnRowClick { get; set; }

    private List<string> Columns = new();
    private List<Dictionary<string, object?>> FilteredData = new();
    private Dictionary<string, string> ColumnFilters = new();
    private string GlobalFilter = string.Empty;
    private string? SortColumn;
    private bool SortAscending = true;
    private int CurrentPage = 1;
    private int TotalPages => (int)Math.Ceiling((double)FilteredData.Count / PageSize);
    private IEnumerable<Dictionary<string, object?>> PagedData => ShowPagination
        ? FilteredData.Skip((CurrentPage - 1) * PageSize).Take(PageSize)
        : FilteredData;

    //private Icons.Regular.Size12 GetSortIcon(bool sortAscending) => sortAscending ? new Icons.Regular.Size12.ArrowUp() : new Icons.Regular.Size12.ArrowDown()


    protected override void OnParametersSet()
    {
        if (Data != null && Data.Any())
        {
            var newColumns = Data.First().Keys.ToList();
            if (!Columns.SequenceEqual(newColumns))
            {
                Columns = newColumns;
                ColumnFilters = Columns.ToDictionary(c => c, c => string.Empty);
            }
            ApplyFilters();
        }
        else
        {
            Columns.Clear();
            FilteredData.Clear();
        }
    }

    private void ApplyFilters()
    {
        if (Data == null) return;

        var filtered = Data.AsEnumerable();

        // Apply global filter
        if (!string.IsNullOrWhiteSpace(GlobalFilter))
        {
            filtered = filtered.Where(row =>
                row.Values.Any(v => v?.ToString()?.Contains(GlobalFilter, StringComparison.OrdinalIgnoreCase) == true));
        }

        // Apply column filters
        foreach (var (column, filter) in ColumnFilters)
        {
            if (!string.IsNullOrWhiteSpace(filter))
            {
                filtered = filtered.Where(row =>
                    row.TryGetValue(column, out var value) &&
                    value?.ToString()?.Contains(filter, StringComparison.OrdinalIgnoreCase) == true);
            }
        }

        // Apply sorting
        if (!string.IsNullOrEmpty(SortColumn))
        {
            filtered = SortAscending
                ? filtered.OrderBy(row => GetSortValue(row, SortColumn))
                : filtered.OrderByDescending(row => GetSortValue(row, SortColumn));
        }

        FilteredData = filtered.ToList();
        CurrentPage = 1;
    }

    private IComparable? GetSortValue(Dictionary<string, object?> row, string column)
    {
        if (!row.TryGetValue(column, out var value) || value == null)
            return null;

        // Try to parse as number for proper numeric sorting
        if (value is string strValue)
        {
            if (double.TryParse(strValue, out var numValue))
                return numValue;
            return strValue;
        }

        // Return value if it's already comparable
        if (value is IComparable comparable)
            return comparable;

        // Fallback to string representation for non-comparable types
        return value.ToString() ?? "";
    }

    private void ToggleSort(string column)
    {
        if (SortColumn == column)
        {
            SortAscending = !SortAscending;
        }
        else
        {
            SortColumn = column;
            SortAscending = true;
        }
        ApplyFilters();
    }

    private void GoToPage(int page)
    {
        CurrentPage = Math.Max(1, Math.Min(page, TotalPages));
    }

    private string GetRecordCountText()
    {
        var total = Data?.Count ?? 0;
        var filtered = FilteredData.Count;
        return total == filtered
            ? $"{total.ToString("N0")} record(s)"
            : $"{filtered.ToString("N0")} of {total.ToString("N0")} record(s)";
    }

    private string FormatColumnHeader(string column)
    {
        // Convert snake_case or camelCase to Title Case
        var result = System.Text.RegularExpressions.Regex.Replace(column, "([a-z])([A-Z])", "$1 $2");
        result = result.Replace("_", " ");
        return CultureInfo.CurrentCulture.TextInfo.ToTitleCase(result.ToLower());
    }

    private string GetCellAlignmentClass(string column, Dictionary<string, object?> row)
    {
        if (ColumnFormats?.TryGetValue(column, out var format) == true)
        {
            return format.Type switch
            {
                FormatType.Currency or FormatType.Number or FormatType.Percentage => "align-right",
                FormatType.Boolean => "align-center",
                _ => ""
            };
        }

        // Auto-detect alignment based on value type
        if (row.TryGetValue(column, out var value) && value != null)
        {
            if (IsNumeric(value))
                return "align-right";
        }

        return "";
    }

    private string FormatCellValue(string column, object? value)
    {
        if (value == null)
            return "<span class=\"null-value\">NULL</span>";

        var format = ColumnFormats?.GetValueOrDefault(column);

        if (format != null)
        {
            return FormatWithDefinition(value, format);
        }

        // Auto-detect and format
        return AutoFormat(value);
    }

    private string FormatWithDefinition(object value, ColumnFormat format)
    {
        var strValue = value.ToString() ?? "";

        return format.Type switch
        {
            FormatType.Currency => FormatCurrency(value, format),
            FormatType.Number => FormatNumber(value, format),
            FormatType.Percentage => FormatPercentage(value, format),
            FormatType.Date => FormatDate(value, format),
            FormatType.DateTime => FormatDateTime(value, format),
            FormatType.Boolean => FormatBoolean(value),
            FormatType.Text => System.Web.HttpUtility.HtmlEncode(strValue),
            _ => System.Web.HttpUtility.HtmlEncode(strValue)
        };
    }

    private string AutoFormat(object value)
    {
        return value switch
        {
            bool b => FormatBoolean(b),
            DateTime dt => $"<span class=\"date-value\">{dt.ToString("yyyy-MM-dd HH:mm:ss")}</span>",
            DateTimeOffset dto => $"<span class=\"date-value\">{dto.ToString("yyyy-MM-dd HH:mm:ss")}</span>",
            decimal d => FormatAutoNumber((double)d),
            double dbl => FormatAutoNumber(dbl),
            float f => FormatAutoNumber(f),
            int i => $"<span class=\"number-value\">{i.ToString("N0")}</span>",
            long l => $"<span class=\"number-value\">{l.ToString("N0")}</span>",
            _ => System.Web.HttpUtility.HtmlEncode(value.ToString() ?? "")
        };
    }

    private string FormatAutoNumber(double value)
    {
        var cssClass = value < 0 ? "number-value negative-value" : "number-value";
        return $"<span class='{cssClass}'>{value.ToString("N2")}</span>";
    }

    private string FormatCurrency(object value, ColumnFormat format)
    {
        if (!TryParseNumber(value, out var numValue))
            return System.Web.HttpUtility.HtmlEncode(value.ToString() ?? "");

        var symbol = format.CurrencySymbol ?? "$";
        var decimals = format.DecimalPlaces ?? 2;
        var cssClass = numValue < 0 ? "number-value currency-value negative-value" : "number-value currency-value";
        var suffix = numValue < 0 ? " CR" : "";
        var formattedValue = Math.Abs(numValue).ToString($"N{decimals}");

        return $"<span class='{cssClass}'>{symbol}{formattedValue}{suffix}</span>";
    }

    private string FormatNumber(object value, ColumnFormat format)
    {
        if (!TryParseNumber(value, out var numValue))
            return System.Web.HttpUtility.HtmlEncode(value.ToString() ?? "");

        var decimals = format.DecimalPlaces ?? 0;
        var cssClass = numValue < 0 ? "number-value negative-value" : "number-value";
        var prefix = format.Prefix ?? "";
        var suffix = format.Suffix ?? "";
        var formattedValue = numValue.ToString($"N{decimals}");

        return $"<span class='{cssClass}'>{prefix}{formattedValue}{suffix}</span>";
    }

    private string FormatPercentage(object value, ColumnFormat format)
    {
        if (!TryParseNumber(value, out var numValue))
            return System.Web.HttpUtility.HtmlEncode(value.ToString() ?? "");

        var decimals = format.DecimalPlaces ?? 1;
        var cssClass = numValue < 0 ? "number-value negative-value" : "number-value";

        // Assume value is already a percentage (not 0-1 range) unless specified
        var displayValue = format.MultiplyBy100 ? numValue * 100 : numValue;
        var formattedValue = displayValue.ToString($"N{decimals}");

        return $"<span class='{cssClass}'>{formattedValue}%</span>";
    }

    private string FormatDate(object value, ColumnFormat format)
    {
        if (value is DateTime dt)
            return $"<span class='date-value'>{dt.ToString(format.DateFormat ?? "yyyy-MM-dd")}</span>";
        if (value is DateTimeOffset dto)
            return $"<span class='date-value'>{dto.ToString(format.DateFormat ?? "yyyy-MM-dd")}</span>";
        if (DateTime.TryParse(value.ToString(), out var parsed))
            return $"<span class='date-value'>{parsed.ToString(format.DateFormat ?? "yyyy-MM-dd")}</span>";
        return System.Web.HttpUtility.HtmlEncode(value.ToString() ?? "");
    }

    private string FormatDateTime(object value, ColumnFormat format)
    {
        if (value is DateTime dt)
            return $"<span class='date-value'>{dt.ToString(format.DateFormat ?? "yyyy-MM-dd HH:mm:ss")}</span>";
        if (value is DateTimeOffset dto)
            return $"<span class='date-value'>{dto.ToString(format.DateFormat ?? "yyyy-MM-dd HH:mm:ss")}</span>";
        if (DateTime.TryParse(value.ToString(), out var parsed))
            return $"<span class='date-value'>{parsed.ToString(format.DateFormat ?? "yyyy-MM-dd HH:mm:ss")}</span>";

        return System.Web.HttpUtility.HtmlEncode(value.ToString() ?? "");
    }

    private string FormatBoolean(object value)
    {
        var boolValue = value switch
        {
            bool b => b,
            string s => s.Equals("true", StringComparison.OrdinalIgnoreCase) || s == "1",
            int i => i != 0,
            _ => false
        };

        return boolValue
            ? "<span class='boolean-true'>Yes</span>"
            : "<span class='boolean-false'>No</span>";
    }

    private bool TryParseNumber(object value, out double result)
    {
        result = 0;
        if (value is double d) { result = d; return true; }
        if (value is decimal dec) { result = (double)dec; return true; }
        if (value is float f) { result = f; return true; }
        if (value is int i) { result = i; return true; }
        if (value is long l) { result = l; return true; }
        return double.TryParse(value.ToString(), out result);
    }

    private bool IsNumeric(object value)
    {
        return value is int or long or float or double or decimal ||
               (value is string s && double.TryParse(s, out _));
    }

    private async Task ExportToCsv()
    {
        var csv = new System.Text.StringBuilder();

        // Headers
        csv.AppendLine(string.Join(",", Columns.Select(c => $"\"{c}\"")));

        // Data
        foreach (var row in FilteredData)
        {
            var values = Columns.Select(c =>
            {
                var value = row.TryGetValue(c, out var v) ? v?.ToString() ?? "" : "";
                return value; //$"\"{value.Replace("\"", "\"\"")}\"";
            });
            csv.AppendLine(string.Join(",", values));
        }

        var fileName = $"export_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
        var bytes = System.Text.Encoding.UTF8.GetBytes(csv.ToString());
        var base64 = Convert.ToBase64String(bytes);

        await JSRuntime.InvokeVoidAsync("eval",
            "var a = document.createElement('a');" +
            $"a.href = 'data:text/csv;base64,{base64}';" +
            $"a.download = '{fileName}';" +
            "document.body.appendChild(a);" +
            "a.click();" +
            "document.body.removeChild(a);");
    }
}
