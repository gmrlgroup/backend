@using System.Text.Json

<style>
    .dwt-container {
        display: flex; flex-direction: column; height: 100%;
        background: #f9fafb; overflow: hidden;
        font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'Segoe UI', sans-serif;
    }

    /* ── Header ─────────────────────────────────────── */
    .dwt-header {
        display: flex; align-items: center; justify-content: space-between; gap: 12px;
        padding: 14px 20px; background: white; border-bottom: 1px solid #e5e7eb;
        flex-shrink: 0; flex-wrap: wrap;
    }
    .dwt-header-left { display: flex; flex-direction: column; gap: 3px; }
    .dwt-eyebrow {
        display: inline-flex; align-items: center; gap: 5px;
        font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .07em; color: #9ca3af;
    }
    .dwt-table-name { margin: 0; font-size: 16px; font-weight: 700; color: #111827; letter-spacing: -.01em; }
    .dwt-header-right { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }

    /* Buttons */
    .dwt-btn { display: inline-flex; align-items: center; gap: 6px; height: 34px; padding: 0 12px;
        border-radius: 7px; font-size: 13px; font-weight: 500; cursor: pointer; }
    .dwt-btn-outline { background: white; border: 1px solid #e5e7eb; color: #374151; }
    .dwt-btn-outline:hover { background: #f9fafb; border-color: #d1d5db; }

    /* Search */
    .dwt-search-wrap { position: relative; }
    .dwt-search-wrap svg { position: absolute; left: 9px; top: 50%; transform: translateY(-50%);
        width: 13px; height: 13px; color: #9ca3af; pointer-events: none; }
    .dwt-search { height: 34px; padding: 0 10px 0 30px; border: 1px solid #e5e7eb; border-radius: 7px;
        font-size: 13px; background: white; color: #111827; outline: none; width: 220px; }
    .dwt-search:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,.1); }

    /* ── Column selector panel ──────────────────────── */
    .dwt-col-panel {
        background: white; border-bottom: 1px solid #e5e7eb;
        padding: 12px 20px; flex-shrink: 0;
    }
    .dwt-col-panel-header {
        display: flex; align-items: center; gap: 8px; margin-bottom: 10px;
    }
    .dwt-col-panel-title { font-size: 13px; font-weight: 600; color: #111827; flex: 1; }
    .dwt-col-panel-actions { display: flex; align-items: center; gap: 6px; }
    .dwt-col-divider { color: #d1d5db; }
    .dwt-link-btn { background: none; border: none; color: #6366f1; font-size: 12.5px;
        cursor: pointer; padding: 0; font-weight: 500; }
    .dwt-link-btn:hover { color: #4f46e5; text-decoration: underline; }
    .dwt-close-btn { width: 28px; height: 28px; display: flex; align-items: center; justify-content: center;
        border: 1px solid #e5e7eb; border-radius: 6px; background: white; cursor: pointer; color: #6b7280; }
    .dwt-close-btn:hover { background: #f3f4f6; color: #374151; }

    .dwt-col-list {
        display: flex; flex-wrap: wrap; gap: 4px 16px;
        max-height: 160px; overflow-y: auto;
    }
    .dwt-col-item { display: flex; align-items: center; gap: 6px; cursor: pointer;
        font-size: 13px; color: #374151; padding: 3px 0; white-space: nowrap; }
    .dwt-col-item input { accent-color: #6366f1; cursor: pointer; width: 14px; height: 14px; }
    .dwt-col-name { font-weight: 500; }
    .dwt-col-type { font-size: 11px; color: #9ca3af; }

    /* ── Table ──────────────────────────────────────── */
    .dwt-table-wrap { flex: 1; overflow: auto; }
    .dwt-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .dwt-table thead th {
        position: sticky; top: 0; z-index: 1;
        background: #f9fafb; border-bottom: 1px solid #e5e7eb;
        padding: 0; white-space: nowrap; vertical-align: top; min-width: 100px;
    }
    .dwt-th-inner {
        display: flex; align-items: center; gap: 6px;
        padding: 9px 12px 4px;
        font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: #6b7280;
    }
    .dwt-col-dtype { font-size: 10px; color: #9ca3af; font-weight: 400; text-transform: none; letter-spacing: 0; }
    .dwt-col-filter {
        display: block; width: 100%; padding: 3px 8px; margin: 0 0 6px;
        border: none; border-top: 1px solid #f3f4f6; background: white;
        font-size: 12px; color: #374151; outline: none; box-sizing: border-box;
    }
    .dwt-col-filter:focus { background: #f9fafb; border-top-color: #c7d2fe; }

    .dwt-table tbody tr { border-bottom: 1px solid #f3f4f6; }
    .dwt-table tbody tr:hover { background: #f9fafb; }
    .dwt-table tbody td {
        padding: 9px 12px; color: #111827; vertical-align: middle;
        white-space: nowrap; max-width: 300px; overflow: hidden; text-overflow: ellipsis;
    }
    .numeric-column { font-variant-numeric: tabular-nums; text-align: right; color: #374151; }
    .date-column { color: #6b7280; font-size: 12.5px; }
    .boolean-column { text-align: center; }
    .text-column {}

    /* Loading / empty */
    .dwt-loading { display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: 12px; height: 240px; color: #6b7280; font-size: 13.5px; }
    .dwt-spinner { width: 28px; height: 28px; border: 2px solid #e5e7eb; border-top-color: #6366f1;
        border-radius: 50%; animation: dwt-spin .7s linear infinite; }
    @@keyframes dwt-spin { to { transform: rotate(360deg); } }
    .dwt-empty { display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: 10px; height: 240px; color: #9ca3af; font-size: 13.5px; }
    .dwt-empty svg { width: 36px; height: 36px; color: #e5e7eb; }

    /* ── Footer / pagination ────────────────────────── */
    .dwt-footer {
        display: flex; align-items: center; justify-content: space-between;
        padding: 10px 20px; background: white; border-top: 1px solid #e5e7eb; flex-shrink: 0;
        flex-wrap: wrap; gap: 8px;
    }
    .dwt-row-info { font-size: 12.5px; color: #6b7280; }
    .dwt-pager { display: flex; align-items: center; gap: 4px; }
    .dwt-pager-btn {
        width: 30px; height: 30px; display: flex; align-items: center; justify-content: center;
        border: 1px solid #e5e7eb; border-radius: 6px; background: white; cursor: pointer; color: #374151;
    }
    .dwt-pager-btn:hover:not(:disabled) { background: #f9fafb; border-color: #d1d5db; }
    .dwt-pager-btn:disabled { opacity: .4; cursor: not-allowed; }
    .dwt-pager-info { font-size: 13px; color: #374151; padding: 0 6px; }
</style>

<div class="dwt-container">

    <!-- Header -->
    <div class="dwt-header">
        <div class="dwt-header-left">
            <div class="dwt-eyebrow">
                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                table
            </div>
            <h3 class="dwt-table-name">@TableName</h3>
        </div>
        <div class="dwt-header-right">
            <button class="dwt-btn dwt-btn-outline" @onclick="@(() => showColumnSelector = !showColumnSelector)">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18M15 3v18"/></svg>
                Columns (@VisibleColumns.Count/@AllColumns.Count)
            </button>
            <div class="dwt-search-wrap">
                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input class="dwt-search" type="search" placeholder="Search all columns..."
                       @bind="searchText" @bind:after="OnSearchChanged" />
            </div>
        </div>
    </div>

    <!-- Column selector panel -->
    @if (showColumnSelector)
    {
        <div class="dwt-col-panel">
            <div class="dwt-col-panel-header">
                <span class="dwt-col-panel-title">Columns</span>
                <div class="dwt-col-panel-actions">
                    <button class="dwt-link-btn" @onclick="SelectAllColumns">Select all</button>
                    <span class="dwt-col-divider">·</span>
                    <button class="dwt-link-btn" @onclick="DeselectAllColumns">Deselect all</button>
                </div>
                <button class="dwt-close-btn" @onclick="@(() => showColumnSelector = false)">
                    <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="dwt-col-list">
                @foreach (var column in AllColumns)
                {
                    <label class="dwt-col-item">
                        <input type="checkbox" @bind="column.IsVisible" @bind:after="UpdateVisibleColumns" />
                        <span class="dwt-col-name">@column.Name</span>
                        <span class="dwt-col-type">@column.DataType</span>
                    </label>
                }
            </div>
        </div>
    }

    <!-- Table wrapper -->
    <div class="dwt-table-wrap">
        @if (IsLoading)
        {
            <div class="dwt-loading">
                <div class="dwt-spinner"></div>
                <span>Loading data...</span>
            </div>
        }
        else if (FilteredData.Any())
        {
            <table class="dwt-table">
                <thead>
                    <tr>
                        @foreach (var col in VisibleColumns)
                        {
                            <th>
                                <div class="dwt-th-inner">
                                    <span>@col.Name</span>
                                    <span class="dwt-col-dtype">@col.DataType</span>
                                </div>
                                <input class="dwt-col-filter" type="text" placeholder="Filter..."
                                       @bind="col.FilterValue" @bind:after="ApplyFilters" />
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in FilteredData)
                    {
                        <tr>
                            @foreach (var col in VisibleColumns)
                            {
                                <td class="@GetColumnClass(col.DataType)">@GetCellValue(row, col.Name)</td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="dwt-empty">
                <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <p>No data available</p>
            </div>
        }
    </div>

    <!-- Info bar + pagination -->
    <div class="dwt-footer">
        <span class="dwt-row-info">@TotalRows rows · Page @CurrentPage of @TotalPages</span>
        @if (TotalPages > 1)
        {
            <div class="dwt-pager">
                <button class="dwt-pager-btn" @onclick="@(() => ChangePage(1))" disabled="@(CurrentPage <= 1)" title="First">
                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="11 17 6 12 11 7"/><polyline points="18 17 13 12 18 7"/></svg>
                </button>
                <button class="dwt-pager-btn" @onclick="@(() => ChangePage(CurrentPage - 1))" disabled="@(CurrentPage <= 1)" title="Previous">
                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <span class="dwt-pager-info">@CurrentPage / @TotalPages</span>
                <button class="dwt-pager-btn" @onclick="@(() => ChangePage(CurrentPage + 1))" disabled="@(CurrentPage >= TotalPages)" title="Next">
                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
                <button class="dwt-pager-btn" @onclick="@(() => ChangePage(TotalPages))" disabled="@(CurrentPage >= TotalPages)" title="Last">
                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="13 17 18 12 13 7"/><polyline points="6 17 11 12 6 7"/></svg>
                </button>
            </div>
        }
    </div>

</div>

@code {
    [Parameter] public string TableName { get; set; } = string.Empty;
    [Parameter] public List<ColumnDefinition> AllColumns { get; set; } = new();
    [Parameter] public List<Dictionary<string, object?>> Data { get; set; } = new();
    [Parameter] public int TotalRows { get; set; }
    [Parameter] public int CurrentPage { get; set; } = 1;
    [Parameter] public int TotalPages { get; set; }
    [Parameter] public int PageSize { get; set; } = 100;
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public EventCallback<int> OnPageChanged { get; set; }
    [Parameter] public EventCallback<int> OnPageSizeChanged { get; set; }

    private List<ColumnDefinition> VisibleColumns => AllColumns.Where(c => c.IsVisible).ToList();
    private List<Dictionary<string, object?>> FilteredData => ApplyClientSideFilters();
    
    private bool showColumnSelector = false;
    private string searchText = string.Empty;

    protected override void OnParametersSet()
    {
        // Initialize column visibility on first load
        if (AllColumns.Any() && AllColumns.All(c => !c.IsVisible))
        {
            foreach (var column in AllColumns)
            {
                column.IsVisible = true;
            }
        }
    }

    private void UpdateVisibleColumns()
    {
        StateHasChanged();
    }

    private void SelectAllColumns()
    {
        foreach (var column in AllColumns)
        {
            column.IsVisible = true;
        }
        StateHasChanged();
    }

    private void DeselectAllColumns()
    {
        foreach (var column in AllColumns)
        {
            column.IsVisible = false;
        }
        StateHasChanged();
    }

    private void OnSearchChanged()
    {
        StateHasChanged();
    }

    private void ApplyFilters()
    {
        StateHasChanged();
    }

    private List<Dictionary<string, object?>> ApplyClientSideFilters()
    {
        var filtered = Data.AsEnumerable();

        // Apply global search
        if (!string.IsNullOrWhiteSpace(searchText))
        {
            filtered = filtered.Where(row =>
                row.Values.Any(value =>
                    value?.ToString()?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        // Apply column-specific filters
        foreach (var column in AllColumns.Where(c => !string.IsNullOrWhiteSpace(c.FilterValue)))
        {
            var filterValue = column.FilterValue;
            filtered = filtered.Where(row =>
            {
                if (row.TryGetValue(column.Name, out var value))
                {
                    return value?.ToString()?.Contains(filterValue, StringComparison.OrdinalIgnoreCase) ?? false;
                }
                return false;
            });
        }

        return filtered.ToList();
    }

    private string GetCellValue(Dictionary<string, object?> row, string columnName)
    {
        if (row.TryGetValue(columnName, out var value))
        {
            if (value == null)
                return "NULL";
            
            if (value is DateTime dt)
                return dt.ToString("yyyy-MM-dd HH:mm:ss");
            
            if (value is decimal || value is double || value is float)
                return string.Format("{0:N2}", value);
            
            return value.ToString() ?? string.Empty;
        }
        return string.Empty;
    }

    private string GetGridTemplateColumns()
    {
        var columnCount = VisibleColumns.Count;
        if (columnCount == 0) return "1fr";
        
        return string.Join(" ", Enumerable.Repeat("1fr", columnCount));
    }

    private string GetColumnClass(string dataType)
    {
        return dataType.ToLower() switch
        {
            var t when t.Contains("int") || t.Contains("decimal") || t.Contains("double") || t.Contains("float") => "numeric-column",
            var t when t.Contains("date") || t.Contains("time") => "date-column",
            var t when t.Contains("bool") => "boolean-column",
            _ => "text-column"
        };
    }

    private async Task ChangePage(int page)
    {
        await OnPageChanged.InvokeAsync(page);
    }

    @* private async Task OnPageSizeChanged()
    {
        await this.OnPageSizeChanged.InvokeAsync(PageSize);
    } *@

    public class ColumnDefinition
    {
        public string Name { get; set; } = string.Empty;
        public string DataType { get; set; } = string.Empty;
        public bool IsVisible { get; set; } = true;
        public string FilterValue { get; set; } = string.Empty;
    }
}
