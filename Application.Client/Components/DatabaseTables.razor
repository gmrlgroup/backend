@using Application.Shared.Models
@using Application.Shared.Enums
@using Application.Client.Services
@inject DatabaseTableClientService DatabaseService
@inject StateContainer StateContainer
@inject IJSRuntime JSRuntime

<!-- Database Connection -->
<div class="bg-white overflow-hidden shadow rounded-lg">
    <div class="px-6 py-5 sm:p-6">
        <div class="flex items-center justify-between mb-4 gap-3 flex-wrap">
            <div>
                <h3 class="text-lg leading-6 font-medium text-gray-900">Database Connection</h3>
                <p class="text-xs text-gray-500 mt-0.5">Configure how to reach this database so its tables can be listed and added as dependencies.</p>
            </div>
            @if (savedConnection != null)
            {
                <span class="text-xs px-2 py-0.5 rounded-full bg-green-100 text-green-700">Configured</span>
            }
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-6 gap-4">
            <div class="sm:col-span-2">
                <label class="block text-sm font-medium text-gray-700">Engine</label>
                <select @bind="form.DatabaseType" @bind:after="OnEngineChanged"
                        class="mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500">
                    @foreach (var t in Enum.GetValues<DataSourceType>())
                    {
                        <option value="@t">@EngineLabel(t)</option>
                    }
                </select>
            </div>

            @if (form.DatabaseType == DataSourceType.DuckDB)
            {
                <div class="sm:col-span-4">
                    <label class="block text-sm font-medium text-gray-700">File path</label>
                    <input @bind="form.FilePath" placeholder="C:/data/warehouse.duckdb"
                           class="mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
                </div>
            }
            else
            {
                <div class="sm:col-span-3">
                    <label class="block text-sm font-medium text-gray-700">Host</label>
                    <input @bind="form.Host" placeholder="db.example.com or IP"
                           class="mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
                </div>
                <div class="sm:col-span-1">
                    <label class="block text-sm font-medium text-gray-700">Port</label>
                    <input @bind="form.Port" type="number" min="0"
                           class="mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
                </div>
                <div class="sm:col-span-3">
                    <label class="block text-sm font-medium text-gray-700">Database</label>
                    <input @bind="form.DatabaseName" placeholder="catalog / database name"
                           class="mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
                </div>
                <div class="sm:col-span-3">
                    <label class="block text-sm font-medium text-gray-700">Username</label>
                    <input @bind="form.Username" autocomplete="off"
                           class="mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
                </div>
                <div class="sm:col-span-3">
                    <label class="block text-sm font-medium text-gray-700">Password</label>
                    <input @bind="form.Secret" type="password" autocomplete="new-password"
                           placeholder="@(savedConnection?.HasSecret == true ? "Leave blank to keep current" : "Enter password")"
                           class="mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
                </div>
                <div class="sm:col-span-3 flex items-end">
                    <label class="inline-flex items-center gap-2 text-sm text-gray-700 pb-2">
                        <input @bind="form.UseSsl" type="checkbox" class="h-4 w-4 rounded text-indigo-600 border-gray-300 focus:ring-indigo-500" />
                        Use SSL / encrypt connection
                    </label>
                </div>
            }
        </div>

        @if (!string.IsNullOrEmpty(connectionMessage))
        {
            <div class="mt-4 rounded-md p-3 text-sm @(connectionOk ? "bg-green-50 border border-green-200 text-green-800" : "bg-red-50 border border-red-200 text-red-700")">
                @connectionMessage
            </div>
        }

        <AuthorizeView Roles="@writeRoles" Context="cfgCtx">
            <Authorized>
                <div class="mt-5 pt-4 border-t border-gray-100 flex items-center justify-end gap-2">
                    @if (savedConnection != null)
                    {
                        <button @onclick="DeleteConnection"
                                class="inline-flex items-center px-3 py-1.5 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-red-600 bg-white hover:bg-red-50">
                            Delete
                        </button>
                        <button @onclick="TestConnection" disabled="@isTesting"
                                class="inline-flex items-center px-3 py-1.5 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50">
                            @(isTesting ? "Testing..." : "Test")
                        </button>
                    }
                    <button @onclick="SaveConnection" disabled="@isSaving"
                            class="inline-flex items-center px-4 py-1.5 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 disabled:opacity-50">
                        @(isSaving ? "Saving..." : "Save")
                    </button>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>
</div>

<!-- Tables -->
@if (savedConnection != null)
{
    <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="px-6 py-5 sm:p-6">
            <div class="flex items-center justify-between mb-4 gap-3 flex-wrap">
                <div>
                    <h3 class="text-lg leading-6 font-medium text-gray-900">Tables</h3>
                    <p class="text-xs text-gray-500 mt-0.5">Fetch the tables from this database, then add the ones you want as entities (each becomes a Table → Database dependency).</p>
                </div>
                <button @onclick="Fetch" disabled="@isFetching"
                        class="inline-flex items-center px-3 py-1 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50">
                    @(isFetching ? "Fetching..." : "Fetch tables")
                </button>
            </div>

            @if (!string.IsNullOrEmpty(fetchError))
            {
                <div class="bg-red-50 border border-red-200 rounded-md p-3 text-sm text-red-700">@fetchError</div>
            }

            @if (!string.IsNullOrEmpty(commitMessage))
            {
                <div class="mb-4 bg-green-50 border border-green-200 rounded-md p-3 text-sm text-green-800">@commitMessage</div>
            }

            @if (discovery != null)
            {
                <div class="flex items-center justify-between mb-2">
                    <h4 class="text-xs font-medium uppercase tracking-wide text-gray-400">@discovery.Tables.Count table(s)</h4>
                    @if (discovery.Tables.Any())
                    {
                        <div class="text-xs">
                            <button @onclick="SelectAll" class="text-indigo-600 hover:text-indigo-900 mr-2" style="border:none;background:none;">Select all</button>
                            <button @onclick="ClearAll" class="text-gray-500 hover:text-gray-700" style="border:none;background:none;">None</button>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(discovery.Error))
                {
                    <div class="bg-amber-50 border border-amber-200 rounded-md p-3 text-sm text-amber-800">
                        Couldn't read tables: @discovery.Error
                    </div>
                }
                else if (discovery.Tables.Any())
                {
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1 max-h-72 overflow-y-auto">
                        @foreach (var t in discovery.Tables)
                        {
                            <label class="flex items-center gap-2 text-sm cursor-pointer">
                                <input type="checkbox" checked="@selectedTables.Contains(t.FullName)" @onchange="() => ToggleTable(t.FullName)" />
                                <span class="text-gray-900 truncate font-mono text-xs">@t.FullName</span>
                                @if (t.ExistingEntityId != null)
                                {
                                    <span class="text-xs px-1.5 py-0.5 rounded bg-gray-100 text-gray-600">Exists</span>
                                }
                                else
                                {
                                    <span class="text-xs px-1.5 py-0.5 rounded bg-indigo-100 text-indigo-700">New</span>
                                }
                            </label>
                        }
                    </div>

                    <AuthorizeView Roles="@writeRoles" Context="tablesCtx">
                        <Authorized>
                            <div class="mt-5 pt-4 border-t border-gray-100 flex items-center justify-end">
                                <button @onclick="Commit" disabled="@(isCommitting || !selectedTables.Any())"
                                        class="inline-flex items-center px-4 py-1.5 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 disabled:opacity-50">
                                    @(isCommitting ? "Adding..." : $"Add selected ({selectedTables.Count})")
                                </button>
                            </div>
                        </Authorized>
                    </AuthorizeView>
                }
                else
                {
                    <p class="text-sm text-gray-500">No tables found.</p>
                }
            }
            else
            {
                <p class="text-center py-4 text-sm text-gray-500">Click "Fetch tables" to list this database's tables.</p>
            }
        </div>
    </div>
}

@code {
    [Parameter] public string EntityId { get; set; } = string.Empty;

    private string CompanyId => StateContainer.Company?.Id ?? string.Empty;
    private string writeRoles => $"{CompanyId}_INCIDENTS,{CompanyId}_ADMIN";

    private DatabaseConnectionDto? savedConnection;
    private DatabaseConnectionRequest form = new() { DatabaseType = DataSourceType.SQLServer, Port = 1433 };

    private bool isSaving;
    private bool isTesting;
    private bool connectionOk;
    private string? connectionMessage;

    // Tables
    private DatabaseTableDiscoveryDto? discovery;
    private bool isFetching;
    private bool isCommitting;
    private string? fetchError;
    private string? commitMessage;
    private readonly HashSet<string> selectedTables = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(CompanyId)) return;
        await LoadConnection();
    }

    private async Task LoadConnection()
    {
        savedConnection = await DatabaseService.GetConnectionAsync(CompanyId, EntityId);
        if (savedConnection != null)
        {
            form = new DatabaseConnectionRequest
            {
                DatabaseType = savedConnection.DatabaseType,
                Host = savedConnection.Host,
                Port = savedConnection.Port,
                DatabaseName = savedConnection.DatabaseName,
                Username = savedConnection.Username,
                UseSsl = savedConnection.UseSsl,
                FilePath = savedConnection.FilePath,
                Secret = null
            };
        }
    }

    private void OnEngineChanged()
    {
        // Reset the port to the engine default when switching engines.
        form.Port = DefaultPort(form.DatabaseType);
    }

    // ---- Connection ----

    private async Task SaveConnection()
    {
        isSaving = true;
        connectionMessage = null;
        try
        {
            savedConnection = await DatabaseService.SaveConnectionAsync(CompanyId, EntityId, form);
            form.Secret = null; // don't keep the plaintext around
            connectionOk = true;
            connectionMessage = "Connection saved.";
        }
        catch (Exception ex)
        {
            connectionOk = false;
            connectionMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task TestConnection()
    {
        isTesting = true;
        connectionMessage = null;
        try
        {
            var result = await DatabaseService.TestConnectionAsync(CompanyId, EntityId);
            connectionOk = result.Ok;
            connectionMessage = result.Ok ? "Connection succeeded." : $"Connection failed: {result.Error}";
        }
        finally
        {
            isTesting = false;
        }
    }

    private async Task DeleteConnection()
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "Remove this database connection?")) return;
        if (await DatabaseService.DeleteConnectionAsync(CompanyId, EntityId))
        {
            savedConnection = null;
            discovery = null;
            selectedTables.Clear();
            form = new DatabaseConnectionRequest { DatabaseType = DataSourceType.SQLServer, Port = 1433 };
            connectionMessage = null;
        }
    }

    // ---- Tables ----

    private async Task Fetch()
    {
        isFetching = true;
        fetchError = null;
        commitMessage = null;
        try
        {
            discovery = await DatabaseService.DiscoverTablesAsync(CompanyId, EntityId);
            // Pre-select every discovered table by default.
            selectedTables.Clear();
            foreach (var t in discovery.Tables)
                selectedTables.Add(t.FullName);
        }
        catch (Exception ex)
        {
            discovery = null;
            fetchError = ex.Message;
        }
        finally
        {
            isFetching = false;
        }
    }

    private void ToggleTable(string fullName)
    {
        if (!selectedTables.Remove(fullName)) selectedTables.Add(fullName);
    }

    private void SelectAll()
    {
        if (discovery == null) return;
        foreach (var t in discovery.Tables) selectedTables.Add(t.FullName);
    }

    private void ClearAll() => selectedTables.Clear();

    private async Task Commit()
    {
        if (discovery == null) return;
        isCommitting = true;
        commitMessage = null;
        fetchError = null;
        try
        {
            var request = new DatabaseTableCommitRequest
            {
                Tables = discovery.Tables
                    .Where(t => selectedTables.Contains(t.FullName))
                    .Select(t => t.FullName)
                    .ToList()
            };

            var result = await DatabaseService.CommitTablesAsync(CompanyId, EntityId, request);
            // Re-fetch so the "New"/"Exists" badges reflect the entities we just created.
            await Fetch();
            commitMessage = result.Message; // set after Fetch(), which clears it
        }
        catch (Exception ex)
        {
            fetchError = ex.Message;
        }
        finally
        {
            isCommitting = false;
        }
    }

    // ---- Helpers ----

    private static string EngineLabel(DataSourceType t) => t switch
    {
        DataSourceType.SQLServer => "Microsoft SQL Server",
        DataSourceType.PostgreSQL => "PostgreSQL",
        DataSourceType.MySQL => "MySQL",
        DataSourceType.ClickHouse => "ClickHouse",
        DataSourceType.DuckDB => "DuckDB",
        _ => t.ToString()
    };

    private static int DefaultPort(DataSourceType t) => t switch
    {
        DataSourceType.SQLServer => 1433,
        DataSourceType.PostgreSQL => 5432,
        DataSourceType.MySQL => 3306,
        DataSourceType.ClickHouse => 8123,
        _ => 0
    };
}
