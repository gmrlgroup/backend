@using Application.Shared.Models

<style>
    .mfd-backdrop {
        position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 1000;
        display: flex; align-items: center; justify-content: center; padding: 16px;
        animation: mfd-fade 0.15s ease;
    }
    @@keyframes mfd-fade { from { opacity: 0; } to { opacity: 1; } }
    .mfd-modal {
        background: white; border-radius: 10px; width: 100%; max-width: 560px;
        max-height: 85vh; display: flex; flex-direction: column;
        box-shadow: 0 20px 60px rgba(0,0,0,0.15);
        animation: mfd-pop 0.2s ease;
        font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'Segoe UI', sans-serif;
    }
    @@keyframes mfd-pop { from { transform: scale(0.96) translateY(8px); opacity: 0; } to { transform: scale(1) translateY(0); opacity: 1; } }
    .mfd-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 18px 22px; border-bottom: 1px solid #e5e7eb; flex-shrink: 0;
    }
    .mfd-header h3 { margin: 0; font-size: 15px; font-weight: 700; color: #111827; }
    .mfd-header-sub { font-size: 13px; color: #6b7280; margin-top: 2px; }
    .mfd-close { width: 32px; height: 32px; border: none; background: none; cursor: pointer; color: #9ca3af; border-radius: 6px; display: flex; align-items: center; justify-content: center; transition: all 0.15s; }
    .mfd-close:hover { background: #f3f4f6; color: #374151; }
    .mfd-body { overflow-y: auto; padding: 20px 22px; display: flex; flex-direction: column; gap: 16px; flex: 1; }
    .mfd-info { background: #eef2ff; border: 1px solid #c7d2fe; border-radius: 8px; padding: 10px 14px; font-size: 13px; color: #4338ca; display: flex; align-items: flex-start; gap: 8px; }
    .mfd-info svg { flex-shrink: 0; margin-top: 1px; }
    .mfd-filter-group { display: flex; flex-direction: column; gap: 6px; }
    .mfd-filter-label { font-size: 13px; font-weight: 600; color: #374151; display: flex; align-items: center; gap: 4px; }
    .mfd-filter-op { font-size: 11px; font-weight: 400; color: #9ca3af; }
    .mfd-required { color: #ef4444; }
    .mfd-filter-desc { font-size: 12px; color: #6b7280; margin: 0; }
    .mfd-filter-hint { font-size: 11px; color: #9ca3af; margin: 0; }
    .mfd-between { display: flex; align-items: center; gap: 8px; }
    .mfd-between-sep { font-size: 13px; color: #6b7280; flex-shrink: 0; }
    .mfd-input { width: 100%; height: 36px; padding: 0 12px; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 13.5px; color: #111827; outline: none; transition: border-color 0.15s; box-sizing: border-box; }
    .mfd-input:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,0.1); }
    .mfd-select { width: 100%; height: 36px; padding: 0 10px; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 13.5px; color: #111827; background: white; outline: none; cursor: pointer; }
    .mfd-select:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,0.1); }
    .mfd-footer { padding: 16px 22px; border-top: 1px solid #e5e7eb; display: flex; justify-content: flex-end; gap: 8px; flex-shrink: 0; }
    .mfd-btn { display: inline-flex; align-items: center; gap: 6px; height: 36px; padding: 0 16px; border-radius: 8px; font-size: 13.5px; font-weight: 500; cursor: pointer; border: none; transition: all 0.15s; }
    .mfd-btn-primary { background: #6366f1; color: white; }
    .mfd-btn-primary:hover { background: #4f46e5; }
    .mfd-btn-secondary { background: white; color: #374151; border: 1px solid #e5e7eb; }
    .mfd-btn-secondary:hover { background: #f9fafb; }
    .mfd-error { background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 10px 14px; font-size: 13px; color: #dc2626; }
</style>

<div class="mfd-backdrop">
    <div class="mfd-modal" @onclick:stopPropagation="true">
        <div class="mfd-header">
            <div>
                <h3>Configure Filters</h3>
                <div class="mfd-header-sub">@Content.KPI</div>
            </div>
            <button class="mfd-close" @onclick="() => OnCancel.InvokeAsync()">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>

        <div class="mfd-body">
            @if (!Content.Filters.Any())
            {
                <div class="mfd-info">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    No filters configured — the query will run with default settings.
                </div>
            }
            else
            {
                <div class="mfd-info">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    Adjust filter values below before running the query.
                </div>

                @foreach (var filter in Content.Filters.OrderBy(f => f.SortOrder))
                {
                    var columnName = filter.ColumnName;
                    <div class="mfd-filter-group">
                        <div class="mfd-filter-label">
                            @filter.FilterLabel
                            <span class="mfd-filter-op">(@GetOperatorLabel(filter.Operator))</span>
                            @if (filter.IsRequired) { <span class="mfd-required">*</span> }
                        </div>
                        @if (!string.IsNullOrEmpty(filter.Description))
                        {
                            <p class="mfd-filter-desc">@filter.Description</p>
                        }
                        @switch (filter.FilterType.ToLowerInvariant())
                        {
                            case "date":
                                @if (filter.Operator == "BETWEEN")
                                {
                                    <div class="mfd-between">
                                        <input type="date" class="mfd-input" value="@GetBetweenStartValue(columnName)"
                                               @oninput="@(e => SetBetweenStartValue(columnName, e.Value?.ToString()))" />
                                        <span class="mfd-between-sep">to</span>
                                        <input type="date" class="mfd-input" value="@GetBetweenEndValue(columnName)"
                                               @oninput="@(e => SetBetweenEndValue(columnName, e.Value?.ToString()))" />
                                    </div>
                                }
                                else
                                {
                                    <input type="date" class="mfd-input" value="@GetFilterValue(columnName)"
                                           @oninput="@(e => SetFilterValue(columnName, e.Value?.ToString()))" />
                                }
                                break;

                            case "number":
                                @if (filter.Operator == "BETWEEN")
                                {
                                    <div class="mfd-between">
                                        <input type="number" class="mfd-input" placeholder="Min" value="@GetBetweenStartValue(columnName)"
                                               @oninput="@(e => SetBetweenStartValue(columnName, e.Value?.ToString()))" />
                                        <span class="mfd-between-sep">to</span>
                                        <input type="number" class="mfd-input" placeholder="Max" value="@GetBetweenEndValue(columnName)"
                                               @oninput="@(e => SetBetweenEndValue(columnName, e.Value?.ToString()))" />
                                    </div>
                                }
                                else
                                {
                                    <input type="text" class="mfd-input" placeholder="@GetPlaceholderForOperator(filter)"
                                           value="@GetFilterValue(columnName)"
                                           @oninput="@(e => SetFilterValue(columnName, e.Value?.ToString()))" />
                                }
                                break;

                            case "select":
                                @if (!string.IsNullOrEmpty(filter.SelectOptions))
                                {
                                    <select class="mfd-select" value="@GetFilterValue(columnName)"
                                            @onchange="@(e => SetFilterValue(columnName, e.Value?.ToString()))">
                                        <option value="">-- Select --</option>
                                        @foreach (var opt in filter.SelectOptions.Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                                        {
                                            <option value="@opt">@opt</option>
                                        }
                                    </select>
                                }
                                break;

                            default:
                                @if (filter.Operator == "BETWEEN")
                                {
                                    <div class="mfd-between">
                                        <input type="text" class="mfd-input" placeholder="Start value" value="@GetBetweenStartValue(columnName)"
                                               @oninput="@(e => SetBetweenStartValue(columnName, e.Value?.ToString()))" />
                                        <span class="mfd-between-sep">to</span>
                                        <input type="text" class="mfd-input" placeholder="End value" value="@GetBetweenEndValue(columnName)"
                                               @oninput="@(e => SetBetweenEndValue(columnName, e.Value?.ToString()))" />
                                    </div>
                                }
                                else
                                {
                                    <input type="text" class="mfd-input" placeholder="@GetPlaceholderForOperator(filter)"
                                           value="@GetFilterValue(columnName)"
                                           @oninput="@(e => SetFilterValue(columnName, e.Value?.ToString()))" />
                                }
                                break;
                        }
                        <p class="mfd-filter-hint">Column: @filter.ColumnName@(!string.IsNullOrEmpty(filter.DefaultValue) ? $" | Default: {filter.DefaultValue}" : "")</p>
                    </div>
                }

                @if (!string.IsNullOrEmpty(ValidationError))
                {
                    <div class="mfd-error">@ValidationError</div>
                }
            }
        </div>

        <div class="mfd-footer">
            <button class="mfd-btn mfd-btn-secondary" @onclick="() => OnCancel.InvokeAsync()">Cancel</button>
            <button class="mfd-btn mfd-btn-primary" @onclick="SubmitAsync">
                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                Run Query
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public Metric Content { get; set; } = new();
    [Parameter] public EventCallback<List<MetricFilterValue>> OnRun { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private string? ValidationError;


    private Dictionary<string, string?> FilterValues = new();
    private Dictionary<string, string?> BetweenStartValues = new();
    private Dictionary<string, string?> BetweenEndValues = new();
    private Dictionary<string, IEnumerable<string>> MultiSelectValues = new();

    protected override void OnInitialized()
    {
        // Initialize filter values with defaults
        foreach (var filter in Content.Filters)
        {
            if (filter.Operator == "BETWEEN" && !string.IsNullOrEmpty(filter.DefaultValue))
            {
                var parts = filter.DefaultValue.Split(';', StringSplitOptions.TrimEntries);
                BetweenStartValues[filter.ColumnName] = parts.Length > 0 ? parts[0] : null;
                BetweenEndValues[filter.ColumnName] = parts.Length > 1 ? parts[1] : null;
            }
            else if ((filter.Operator == "IN" || filter.Operator == "NOT IN") && filter.FilterType == "select")
            {
                var defaultValues = filter.DefaultValue?.Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries) ?? Array.Empty<string>();
                MultiSelectValues[filter.ColumnName] = defaultValues;
            }
            else
            {
                FilterValues[filter.ColumnName] = filter.DefaultValue;
            }

            // Ensure all dictionaries have entries for all filters
            if (!BetweenStartValues.ContainsKey(filter.ColumnName)) BetweenStartValues[filter.ColumnName] = null;
            if (!BetweenEndValues.ContainsKey(filter.ColumnName)) BetweenEndValues[filter.ColumnName] = null;
            if (!MultiSelectValues.ContainsKey(filter.ColumnName)) MultiSelectValues[filter.ColumnName] = Enumerable.Empty<string>();
            if (!FilterValues.ContainsKey(filter.ColumnName)) FilterValues[filter.ColumnName] = null;
        }
    }

    // Getter/Setter methods to work around Blazor's dictionary indexer limitation
    private string? GetFilterValue(string columnName) => FilterValues.GetValueOrDefault(columnName);
    private void SetFilterValue(string columnName, string? value) => FilterValues[columnName] = value;

    private string? GetBetweenStartValue(string columnName) => BetweenStartValues.GetValueOrDefault(columnName);
    private void SetBetweenStartValue(string columnName, string? value) => BetweenStartValues[columnName] = value;

    private string? GetBetweenEndValue(string columnName) => BetweenEndValues.GetValueOrDefault(columnName);
    private void SetBetweenEndValue(string columnName, string? value) => BetweenEndValues[columnName] = value;

    private IEnumerable<string> GetMultiSelectValue(string columnName) => MultiSelectValues.GetValueOrDefault(columnName) ?? Enumerable.Empty<string>();
    private void SetMultiSelectValue(string columnName, IEnumerable<string> value) => MultiSelectValues[columnName] = value;

    private async Task SubmitAsync()
    {
        // Validate required filters
        var missingRequired = Content.Filters
            .Where(f => f.IsRequired && !HasFilterValue(f))
            .ToList();

        if (missingRequired.Any())
        {
            ValidationError = $"Please fill in required filter(s): {string.Join(", ", missingRequired.Select(f => f.FilterLabel))}";
            return;
        }

        // Convert to MetricFilterValue list
        var filterValuesList = new List<MetricFilterValue>();

        foreach (var filter in Content.Filters)
        {
            var value = GetComputedFilterValue(filter);
            if (!string.IsNullOrWhiteSpace(value))
            {
                filterValuesList.Add(new MetricFilterValue
                {
                    ColumnName = filter.ColumnName,
                    Value = value
                });
            }
        }

        await OnRun.InvokeAsync(filterValuesList);
    }

    private bool HasFilterValue(MetricFilter filter)
    {
        if (filter.Operator == "BETWEEN")
        {
            return !string.IsNullOrWhiteSpace(BetweenStartValues.GetValueOrDefault(filter.ColumnName)) &&
                   !string.IsNullOrWhiteSpace(BetweenEndValues.GetValueOrDefault(filter.ColumnName));
        }
        else if ((filter.Operator == "IN" || filter.Operator == "NOT IN") && filter.FilterType == "select")
        {
            return MultiSelectValues.GetValueOrDefault(filter.ColumnName)?.Any() == true;
        }
        else
        {
            return !string.IsNullOrWhiteSpace(FilterValues.GetValueOrDefault(filter.ColumnName));
        }
    }

    private string? GetComputedFilterValue(MetricFilter filter)
    {
        if (filter.Operator == "BETWEEN")
        {
            var start = BetweenStartValues.GetValueOrDefault(filter.ColumnName);
            var end = BetweenEndValues.GetValueOrDefault(filter.ColumnName);
            if (!string.IsNullOrWhiteSpace(start) && !string.IsNullOrWhiteSpace(end))
            {
                return $"{start};{end}";
            }
            return null;
        }
        else if ((filter.Operator == "IN" || filter.Operator == "NOT IN") && filter.FilterType == "select")
        {
            var values = MultiSelectValues.GetValueOrDefault(filter.ColumnName);
            if (values?.Any() == true)
            {
                return string.Join(";", values);
            }
            return null;
        }
        else
        {
            return FilterValues.GetValueOrDefault(filter.ColumnName);
        }
    }

    private string GetOperatorLabel(string op)
    {
        return op switch
        {
            "=" => "equals",
            "<>" => "not equals",
            "<" => "less than",
            ">" => "greater than",
            "<=" => "at most",
            ">=" => "at least",
            "IN" => "is one of",
            "NOT IN" => "is not one of",
            "LIKE" => "contains",
            "NOT LIKE" => "does not contain",
            "BETWEEN" => "between",
            _ => op
        };
    }

    private string GetPlaceholderForOperator(MetricFilter filter)
    {
        if (!string.IsNullOrEmpty(filter.Placeholder))
        {
            return filter.Placeholder;
        }

        return filter.Operator switch
        {
            "IN" or "NOT IN" => "Enter values separated by ;",
            "LIKE" or "NOT LIKE" => "Use % as wildcard (e.g., %search%)",
            _ => "Enter value"
        };
    }

    // Remove old FluentDialog cancel — handled via [Parameter] OnCancel
}
