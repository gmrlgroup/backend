@using Application.Shared.Models
@using Application.Shared.Enums
@using System.Net.Http.Json
@inject HttpClient HttpClient

<style>
    .mfw-backdrop {
        position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 1000;
        display: flex; align-items: center; justify-content: center; padding: 16px;
        animation: mfw-fade 0.15s ease;
    }
    @@keyframes mfw-fade { from { opacity: 0; } to { opacity: 1; } }
    .mfw-modal {
        background: white; border-radius: 14px; width: 100%; max-width: 860px;
        max-height: 90vh; display: flex; flex-direction: column;
        box-shadow: 0 24px 64px rgba(0,0,0,0.18);
        animation: mfw-pop 0.2s ease;
        font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'Segoe UI', sans-serif;
    }
    @@keyframes mfw-pop { from { transform: scale(0.96) translateY(10px); opacity: 0; } to { transform: scale(1) translateY(0); opacity: 1; } }

    /* Header */
    .mfw-header { display: flex; align-items: center; justify-content: space-between; padding: 20px 24px 16px; flex-shrink: 0; }
    .mfw-header-left {}
    .mfw-title { font-size: 18px; font-weight: 700; color: #111827; margin: 0 0 2px 0; }
    .mfw-step-label { font-size: 13px; color: #6b7280; }
    .mfw-close { width: 32px; height: 32px; border: none; background: none; cursor: pointer; color: #9ca3af; border-radius: 6px; display: flex; align-items: center; justify-content: center; transition: all 0.15s; }
    .mfw-close:hover { background: #f3f4f6; color: #374151; }

    /* Stepper */
    .mfw-stepper { display: flex; align-items: center; padding: 0 24px 16px; overflow-x: auto; flex-shrink: 0; gap: 0; }
    .mfw-step { display: flex; align-items: center; gap: 0; flex-shrink: 0; }
    .mfw-step-dot {
        width: 28px; height: 28px; border-radius: 50%; border: 2px solid #e5e7eb;
        background: white; display: flex; align-items: center; justify-content: center;
        font-size: 12px; font-weight: 600; color: #9ca3af; transition: all 0.2s; flex-shrink: 0;
    }
    .mfw-step-dot.done { background: #6366f1; border-color: #6366f1; color: white; }
    .mfw-step-dot.active { background: white; border-color: #6366f1; color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,0.15); }
    .mfw-step-name { font-size: 11px; margin-left: 5px; color: #9ca3af; white-space: nowrap; }
    .mfw-step-name.active { color: #6366f1; font-weight: 600; }
    .mfw-step-name.done { color: #6b7280; }
    .mfw-step-connector { width: 28px; height: 2px; background: #e5e7eb; flex-shrink: 0; margin: 0 4px; }
    .mfw-step-connector.done { background: #6366f1; }

    /* Body */
    .mfw-body { flex: 1; overflow-y: auto; padding: 4px 24px 20px; display: flex; flex-direction: column; gap: 16px; min-height: 0; }
    .mfw-section-title { font-size: 12px; font-weight: 700; color: #6366f1; text-transform: uppercase; letter-spacing: 0.08em; margin: 4px 0 12px; display: flex; align-items: center; gap: 6px; }
    .mfw-section-title::after { content: ''; flex: 1; height: 1px; background: #e5e7eb; }
    .mfw-info { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; padding: 10px 14px; font-size: 13px; color: #6b7280; }

    /* Form elements */
    .mfw-grid { display: grid; gap: 12px; }
    .mfw-grid-2 { grid-template-columns: 1fr 1fr; }
    .mfw-grid-3 { grid-template-columns: 1fr 1fr 1fr; }
    .mfw-field { display: flex; flex-direction: column; gap: 5px; }
    .mfw-field.span-2 { grid-column: span 2; }
    .mfw-field.span-3 { grid-column: span 3; }
    .mfw-label { font-size: 13px; font-weight: 600; color: #374151; }
    .mfw-label .req { color: #ef4444; }
    .mfw-input { width: 100%; height: 36px; padding: 0 12px; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 13.5px; color: #111827; outline: none; transition: border-color 0.15s; box-sizing: border-box; background: white; }
    .mfw-input:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,0.1); }
    .mfw-textarea { width: 100%; padding: 8px 12px; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 13.5px; color: #111827; outline: none; resize: vertical; transition: border-color 0.15s; box-sizing: border-box; font-family: inherit; }
    .mfw-textarea:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,0.1); }
    .mfw-textarea.mono { font-family: 'Fira Code', 'Courier New', monospace; font-size: 13px; }
    .mfw-select { width: 100%; height: 36px; padding: 0 10px; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 13.5px; color: #111827; background: white; outline: none; cursor: pointer; box-sizing: border-box; }
    .mfw-select:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,0.1); }
    .mfw-checkbox-row { display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 13.5px; color: #374151; }
    .mfw-checkbox-row input { width: 16px; height: 16px; accent-color: #6366f1; cursor: pointer; }

    /* Cards */
    .mfw-card { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 10px; padding: 14px; display: flex; flex-direction: column; gap: 10px; }
    .mfw-card-header { display: flex; align-items: center; justify-content: space-between; }
    .mfw-card-label { font-size: 13px; font-weight: 600; color: #374151; }

    /* List items */
    .mfw-list-item { display: flex; align-items: center; gap: 8px; }
    .mfw-list-item .mfw-input { flex: 1; }
    .mfw-add-btn {
        display: inline-flex; align-items: center; gap: 6px; height: 34px; padding: 0 14px;
        border: 1px dashed #c7d2fe; background: #eef2ff; color: #6366f1; border-radius: 8px;
        font-size: 13px; font-weight: 500; cursor: pointer; transition: all 0.15s;
    }
    .mfw-add-btn:hover { background: #e0e7ff; border-color: #a5b4fc; }
    .mfw-remove-btn {
        width: 30px; height: 30px; border: none; background: none; color: #9ca3af;
        cursor: pointer; border-radius: 6px; display: flex; align-items: center; justify-content: center;
        flex-shrink: 0; transition: all 0.15s;
    }
    .mfw-remove-btn:hover { background: #fee2e2; color: #ef4444; }

    /* Radio */
    .mfw-radio-group { display: flex; gap: 12px; }
    .mfw-radio-option { display: flex; align-items: center; gap: 6px; cursor: pointer; font-size: 13.5px; color: #374151; }
    .mfw-radio-option input { accent-color: #6366f1; width: 16px; height: 16px; cursor: pointer; }

    /* DS details box */
    .mfw-ds-detail { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px; padding: 10px 14px; font-size: 13px; color: #166534; }

    /* Hint text */
    .mfw-hint { font-size: 11px; color: #9ca3af; }
    .mfw-note { font-size: 12px; color: #6b7280; background: #fffbeb; border: 1px solid #fde68a; border-radius: 6px; padding: 6px 10px; }

    /* Footer */
    .mfw-footer { display: flex; align-items: center; justify-content: flex-end; gap: 8px; padding: 16px 24px; border-top: 1px solid #e5e7eb; flex-shrink: 0; }
    .mfw-btn { display: inline-flex; align-items: center; gap: 6px; height: 36px; padding: 0 16px; border-radius: 8px; font-size: 13.5px; font-weight: 500; cursor: pointer; border: none; transition: all 0.15s; }
    .mfw-btn-primary { background: #6366f1; color: white; }
    .mfw-btn-primary:hover { background: #4f46e5; }
    .mfw-btn-secondary { background: white; color: #374151; border: 1px solid #e5e7eb; }
    .mfw-btn-secondary:hover { background: #f9fafb; }
    .mfw-footer-left { margin-right: auto; }

    @@media (max-width: 640px) {
        .mfw-grid-2, .mfw-grid-3 { grid-template-columns: 1fr; }
        .mfw-field.span-2, .mfw-field.span-3 { grid-column: span 1; }
    }
</style>

<div class="mfw-backdrop">
    <div class="mfw-modal" @onclick:stopPropagation="true">

        <!-- Header -->
        <div class="mfw-header">
            <div class="mfw-header-left">
                <h3 class="mfw-title">@(Content.Id == 0 ? "Create New Metric" : $"Edit Metric: {Content.KPI}")</h3>
                <span class="mfw-step-label">Step @(currentStep + 1) of @totalSteps — @StepNames[currentStep]</span>
            </div>
            <button class="mfw-close" @onclick="() => OnCancel.InvokeAsync()">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>

        <!-- Stepper -->
        <div class="mfw-stepper">
            @for (int i = 0; i < totalSteps; i++)
            {
                var stepIdx = i;
                var dotClass = stepIdx < currentStep ? "done" : (stepIdx == currentStep ? "active" : "");
                var nameClass = stepIdx < currentStep ? "done" : (stepIdx == currentStep ? "active" : "");
                <div class="mfw-step">
                    <div class="mfw-step-dot @dotClass">
                        @if (stepIdx < currentStep)
                        {
                            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                        }
                        else
                        {
                            @(stepIdx + 1)
                        }
                    </div>
                    <span class="mfw-step-name @nameClass">@StepNames[stepIdx]</span>
                </div>
                @if (i < totalSteps - 1)
                {
                    <div class="mfw-step-connector @(i < currentStep ? "done" : "")"></div>
                }
            }
        </div>

        <!-- Body -->
        <div class="mfw-body">

            @if (currentStep == 0)
            {
                <!-- Step 1: Functions & Contact -->
                <div class="mfw-section-title">
                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                    Function Information
                </div>
                @foreach (var func in Content.Functions.ToList())
                {
                    var cf = func;
                    <div class="mfw-card">
                        <div class="mfw-card-header">
                            <span class="mfw-card-label">Function Entry</span>
                            <button class="mfw-remove-btn" @onclick="() => Content.Functions.Remove(cf)">
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                            </button>
                        </div>
                        <div class="mfw-grid mfw-grid-2">
                            <div class="mfw-field span-2">
                                <label class="mfw-label">Function <span class="req">*</span></label>
                                <input class="mfw-input" placeholder="e.g., Finance, Operations" @bind="cf.Function" />
                            </div>
                            <div class="mfw-field">
                                <label class="mfw-label">Sub-Function</label>
                                <input class="mfw-input" placeholder="e.g., Accounting" @bind="cf.SubFunction" />
                            </div>
                            <div class="mfw-field">
                                <label class="mfw-label">Function Head</label>
                                <input class="mfw-input" placeholder="Department head name" @bind="cf.FunctionHead" />
                            </div>
                        </div>
                    </div>
                }
                <button class="mfw-add-btn" @onclick="AddFunction">+ Add Function</button>
                <div class="mfw-grid mfw-grid-2" style="margin-top:4px;">
                    <div class="mfw-field">
                        <label class="mfw-label">Key Performance Area <span class="req">*</span></label>
                        <input class="mfw-input" placeholder="Primary performance area" @bind="Content.KeyPerformanceArea" />
                    </div>
                    <div class="mfw-field">
                        <label class="mfw-label">Contact Email</label>
                        <input type="email" class="mfw-input" placeholder="contact@example.com" @bind="Content.ContactEmail" />
                    </div>
                    <div class="mfw-field span-2">
                        <label class="mfw-label">Contact Number</label>
                        <input class="mfw-input" placeholder="+1234567890" @bind="Content.ContactNumber" />
                    </div>
                </div>
            }
            else if (currentStep == 1)
            {
                <!-- Step 2: KPI Details -->
                <div class="mfw-section-title">
                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                    KPI Details
                </div>
                <div class="mfw-grid">
                    <div class="mfw-field">
                        <label class="mfw-label">KPI Name <span class="req">*</span></label>
                        <input class="mfw-input" placeholder="e.g., Customer Satisfaction Score" @bind="Content.KPI" />
                    </div>
                    <div class="mfw-field">
                        <label class="mfw-label">Formula</label>
                        <textarea class="mfw-textarea" rows="3" placeholder="Describe how this KPI is calculated" @bind="Content.Formula"></textarea>
                    </div>
                    <div class="mfw-grid mfw-grid-3">
                        <div class="mfw-field">
                            <label class="mfw-label">Type <span class="req">*</span></label>
                            <select class="mfw-select" value="@Content.Type" @onchange="e => Content.Type = Enum.Parse<MetricType>(e.Value?.ToString() ?? Content.Type.ToString())">
                                @foreach (var t in metricTypes)
                                {
                                    <option value="@t">@t</option>
                                }
                            </select>
                        </div>
                        <div class="mfw-field">
                            <label class="mfw-label">Perspective <span class="req">*</span></label>
                            <select class="mfw-select" value="@Content.Perspective" @onchange="e => Content.Perspective = Enum.Parse<MetricPerspective>(e.Value?.ToString() ?? Content.Perspective.ToString())">
                                @foreach (var p in metricPerspectives) { <option value="@p">@p</option> }
                            </select>
                        </div>
                        <div class="mfw-field">
                            <label class="mfw-label">KPI Level <span class="req">*</span></label>
                            <select class="mfw-select" value="@Content.KPILevel" @onchange="e => Content.KPILevel = Enum.Parse<MetricLevel>(e.Value?.ToString() ?? Content.KPILevel.ToString())">
                                @foreach (var l in metricLevels) { <option value="@l">@l</option> }
                            </select>
                        </div>
                    </div>
                </div>
            }
            else if (currentStep == 2)
            {
                <!-- Step 3: Target & Ownership -->
                <div class="mfw-section-title">
                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    Target &amp; Ownership
                </div>
                <div class="mfw-grid">
                    <div class="mfw-field">
                        <label class="mfw-label">Target</label>
                        <input class="mfw-input" placeholder="e.g., 95%, $1M, 100 units" @bind="Content.Target" />
                    </div>
                    <div class="mfw-field">
                        <label class="mfw-label">Unintended Consequences</label>
                        <textarea class="mfw-textarea" rows="2" placeholder="Potential negative side effects" @bind="Content.UnintendedConsequences"></textarea>
                    </div>
                </div>
                <div class="mfw-section-title">Recipients</div>
                @foreach (var r in Content.Recipients.ToList()) { var cr = r;
                    <div class="mfw-list-item">
                        <input class="mfw-input" placeholder="Recipient name" @bind="cr.RecipientName" />
                        <button class="mfw-remove-btn" @onclick="() => Content.Recipients.Remove(cr)">
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                        </button>
                    </div>
                }
                <button class="mfw-add-btn" @onclick="AddRecipient">+ Add Recipient</button>
                <div class="mfw-section-title">Owners</div>
                @foreach (var o in Content.Owners.ToList()) { var co = o;
                    <div class="mfw-list-item">
                        <input class="mfw-input" placeholder="Owner name" @bind="co.OwnerName" />
                        <button class="mfw-remove-btn" @onclick="() => Content.Owners.Remove(co)">
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                        </button>
                    </div>
                }
                <button class="mfw-add-btn" @onclick="AddOwner">+ Add Owner</button>
                <div class="mfw-section-title">Verifiers</div>
                @foreach (var v in Content.Verifiers.ToList()) { var cv = v;
                    <div class="mfw-list-item">
                        <input class="mfw-input" placeholder="Verifier name" @bind="cv.VerifierName" />
                        <button class="mfw-remove-btn" @onclick="() => Content.Verifiers.Remove(cv)">
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                        </button>
                    </div>
                }
                <button class="mfw-add-btn" @onclick="AddVerifier">+ Add Verifier</button>
            }
            else if (currentStep == 3)
            {
                <!-- Step 4: Dimensions -->
                <div class="mfw-section-title">
                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                    Dimensions
                </div>
                <p class="mfw-info">Define the dimensions by which this metric can be broken down (e.g., Store, Region, Product).</p>
                @foreach (var dim in Content.Dimensions.ToList())
                {
                    var cd = dim;
                    <div class="mfw-card">
                        <div class="mfw-card-header">
                            <span class="mfw-card-label">Dimension</span>
                            <button class="mfw-remove-btn" @onclick="() => Content.Dimensions.Remove(cd)">
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                            </button>
                        </div>
                        <div class="mfw-grid mfw-grid-2">
                            <div class="mfw-field span-2">
                                <label class="mfw-label">Name <span class="req">*</span></label>
                                <input class="mfw-input" placeholder="e.g., Store, Item, Region" @bind="cd.Name" />
                            </div>
                            <div class="mfw-field span-2">
                                <label class="mfw-label">Description</label>
                                <textarea class="mfw-textarea" rows="2" placeholder="What this dimension represents" @bind="cd.Description"></textarea>
                            </div>
                            <div class="mfw-field">
                                <label class="mfw-label">Source Table</label>
                                <input class="mfw-input" placeholder="Table name" @bind="cd.SourceTable" />
                            </div>
                            <div class="mfw-field">
                                <label class="mfw-label">Source Column</label>
                                <input class="mfw-input" placeholder="Column name" @bind="cd.SourceColumn" />
                            </div>
                        </div>
                    </div>
                }
                <button class="mfw-add-btn" @onclick="AddDimension">+ Add Dimension</button>
            }
            else if (currentStep == 4)
            {
                <!-- Step 5: Data Source -->
                <div class="mfw-section-title">
                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
                    Data Source Connection
                </div>
                <p class="mfw-info">Configure a database connection to fetch live metric data. Optional.</p>
                <label class="mfw-checkbox-row">
                    <input type="checkbox" @bind="hasDataSource" />
                    Enable Data Source Connection
                </label>
                @if (hasDataSource)
                {
                    @if (AvailableDataSources.Any())
                    {
                        <div class="mfw-radio-group">
                            <label class="mfw-radio-option">
                                <input type="radio" name="dsmode" checked="@useExistingDataSource" @onchange="() => useExistingDataSource = true" />
                                Use Existing
                            </label>
                            <label class="mfw-radio-option">
                                <input type="radio" name="dsmode" checked="@(!useExistingDataSource)" @onchange="() => useExistingDataSource = false" />
                                Create New
                            </label>
                        </div>
                        @if (useExistingDataSource)
                        {
                            <div class="mfw-field">
                                <label class="mfw-label">Select Data Source</label>
                                <select class="mfw-select" value="@selectedDataSourceIdString" @onchange="e => OnDataSourceSelectionChangedFromString(e.Value?.ToString() ?? string.Empty)">
                                    <option value="">-- Select a data source --</option>
                                    @foreach (var ds in AvailableDataSources)
                                    {
                                        <option value="@ds.Id">@(string.IsNullOrEmpty(ds.ConnectionName) ? $"{ds.Type}: {ds.Host}:{ds.Port}/{ds.Database}" : $"{ds.ConnectionName} ({ds.Type})")</option>
                                    }
                                </select>
                            </div>
                            @if (selectedDataSourceId != null)
                            {
                                <div class="mfw-ds-detail">
                                    <strong>@DataSourceModel.Type</strong> — @DataSourceModel.Host:@DataSourceModel.Port / @DataSourceModel.Database (user: @DataSourceModel.Username, SSL: @(DataSourceModel.UseSSL ? "on" : "off"))
                                </div>
                            }
                        }
                    }
                    @if (!useExistingDataSource || !AvailableDataSources.Any())
                    {
                        <div class="mfw-grid mfw-grid-2">
                            <div class="mfw-field">
                                <label class="mfw-label">Connection Name</label>
                                <input class="mfw-input" placeholder="e.g., Sales Database" @bind="DataSourceModel.ConnectionName" />
                            </div>
                            <div class="mfw-field">
                                <label class="mfw-label">Database Type <span class="req">*</span></label>
                                <select class="mfw-select" value="@DataSourceModel.Type" @onchange="e => DataSourceModel.Type = Enum.Parse<DataSourceType>(e.Value?.ToString() ?? DataSourceModel.Type.ToString())">
                                    @foreach (var dst in dataSourceTypes) { <option value="@dst">@dst</option> }
                                </select>
                            </div>
                            <div class="mfw-field">
                                <label class="mfw-label">Host <span class="req">*</span></label>
                                <input class="mfw-input" placeholder="localhost or db.example.com" @bind="DataSourceModel.Host" />
                            </div>
                            <div class="mfw-field">
                                <label class="mfw-label">Port <span class="req">*</span></label>
                                <input type="number" class="mfw-input" placeholder="8123" @bind="DataSourceModel.Port" />
                            </div>
                            <div class="mfw-field span-2">
                                <label class="mfw-label">Database <span class="req">*</span></label>
                                <input class="mfw-input" placeholder="Database name" @bind="DataSourceModel.Database" />
                            </div>
                            <div class="mfw-field">
                                <label class="mfw-label">Username <span class="req">*</span></label>
                                <input class="mfw-input" placeholder="Database username" @bind="DataSourceModel.Username" />
                            </div>
                            <div class="mfw-field">
                                <label class="mfw-label">Password</label>
                                <input type="password" class="mfw-input" placeholder="Database password" @bind="DataSourceModel.Password" />
                            </div>
                            <div class="mfw-field span-2">
                                <label class="mfw-checkbox-row">
                                    <input type="checkbox" @bind="DataSourceModel.UseSSL" /> Use SSL/TLS
                                </label>
                            </div>
                        </div>
                    }
                    <div class="mfw-field">
                        <label class="mfw-label">SQL Query</label>
                        <textarea class="mfw-textarea mono" rows="6" placeholder="SELECT SUM(amount) FROM sales WHERE date >= '{{start_date}}'" @bind="Content.Query"></textarea>
                    </div>
                }
            }
            else if (currentStep == 5)
            {
                <!-- Step 6: Query Filters -->
                <div class="mfw-section-title">
                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
                    Query Filters
                </div>
                <p class="mfw-info">Define filters users can apply at query-run time. Use <code>@@{{column_name}}</code> placeholders in the query.</p>
                @foreach (var filter in Content.Filters.ToList())
                {
                    var cf = filter;
                    <div class="mfw-card">
                        <div class="mfw-card-header">
                            <span class="mfw-card-label">@(string.IsNullOrEmpty(cf.FilterLabel) ? "(New Filter)" : cf.FilterLabel)</span>
                            <button class="mfw-remove-btn" @onclick="() => Content.Filters.Remove(cf)">
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                            </button>
                        </div>
                        <div class="mfw-grid mfw-grid-2">
                            <div class="mfw-field">
                                <label class="mfw-label">Label <span class="req">*</span></label>
                                <input class="mfw-input" placeholder="e.g., Start Date, Region" @bind="cf.FilterLabel" />
                            </div>
                            <div class="mfw-field">
                                <label class="mfw-label">Column Name <span class="req">*</span></label>
                                <input class="mfw-input" placeholder="e.g., start_date, region_id" @bind="cf.ColumnName" />
                            </div>
                            <div class="mfw-field">
                                <label class="mfw-label">Type</label>
                                <select class="mfw-select" value="@cf.FilterType" @onchange="e => cf.FilterType = e.Value?.ToString() ?? cf.FilterType">
                                    @foreach (var ft in filterTypes) { <option value="@ft">@ft</option> }
                                </select>
                            </div>
                            <div class="mfw-field">
                                <label class="mfw-label">Operator</label>
                                <select class="mfw-select" value="@cf.Operator" @onchange="e => cf.Operator = e.Value?.ToString() ?? cf.Operator">
                                    @foreach (var op in filterOperators) { <option value="@op.Value">@op.Label</option> }
                                </select>
                            </div>
                            <div class="mfw-field">
                                <label class="mfw-label">Default Value</label>
                                <input class="mfw-input" placeholder="@GetDefaultValuePlaceholder(cf.Operator)" @bind="cf.DefaultValue" />
                            </div>
                            <div class="mfw-field">
                                <label class="mfw-label">Sort Order</label>
                                <input type="number" class="mfw-input" @bind="cf.SortOrder" />
                            </div>
                            @if (cf.FilterType == "select")
                            {
                                <div class="mfw-field span-2">
                                    <label class="mfw-label">Options (semicolon-separated)</label>
                                    <input class="mfw-input" placeholder="Option1;Option2;Option3" @bind="cf.SelectOptions" />
                                </div>
                            }
                            <div class="mfw-field span-2">
                                <label class="mfw-label">Description</label>
                                <textarea class="mfw-textarea" rows="2" placeholder="Help text for users" @bind="cf.Description"></textarea>
                            </div>
                            <div class="mfw-field span-2">
                                <label class="mfw-checkbox-row">
                                    <input type="checkbox" @bind="cf.IsRequired" /> Required filter
                                </label>
                            </div>
                        </div>
                    </div>
                }
                <button class="mfw-add-btn" @onclick="AddFilter">+ Add Filter</button>
            }
            else if (currentStep == 6)
            {
                <!-- Step 7: Measurement & Data -->
                <div class="mfw-section-title">
                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                    Measurement &amp; Data
                </div>
                <div class="mfw-grid mfw-grid-2">
                    <div class="mfw-field">
                        <label class="mfw-label">Unit of Measure</label>
                        <input class="mfw-input" placeholder="%, $, units…" @bind="Content.UnitOfMeasure" />
                    </div>
                    <div class="mfw-field">
                        <label class="mfw-label">Polarity</label>
                        <select class="mfw-select" value="@Content.Polarity" @onchange="e => Content.Polarity = Enum.Parse<MetricPolarity>(e.Value?.ToString() ?? Content.Polarity.ToString())">
                            @foreach (var p in metricPolarities) { <option value="@p">@p</option> }
                        </select>
                    </div>
                    <div class="mfw-field">
                        <label class="mfw-label">Data Capture Frequency</label>
                        <select class="mfw-select" @onchange="e => Content.DataCapture = string.IsNullOrEmpty(e.Value?.ToString()) ? null : Enum.Parse<ReportingFrequency>(e.Value.ToString()!)">
                            <option value="">— None —</option>
                            @foreach (var f in reportingFrequencies) { <option value="@f" selected="@(Content.DataCapture == f)">@f</option> }
                        </select>
                    </div>
                    <div class="mfw-field">
                        <label class="mfw-label">Data Reporting Frequency</label>
                        <select class="mfw-select" @onchange="e => Content.DataReporting = string.IsNullOrEmpty(e.Value?.ToString()) ? null : Enum.Parse<ReportingFrequency>(e.Value.ToString()!)">
                            <option value="">— None —</option>
                            @foreach (var f in reportingFrequencies) { <option value="@f" selected="@(Content.DataReporting == f)">@f</option> }
                        </select>
                    </div>
                    <div class="mfw-field">
                        <label class="mfw-label">Data Source (label)</label>
                        <input class="mfw-input" placeholder="Where does the data come from?" @bind="Content.DataSource" />
                    </div>
                    <div class="mfw-field">
                        <label class="mfw-label">Data Integrity</label>
                        <select class="mfw-select" @onchange="e => Content.DataIntegrity = string.IsNullOrEmpty(e.Value?.ToString()) ? null : Enum.Parse<DataIntegrityLevel>(e.Value.ToString()!)">
                            <option value="">— None —</option>
                            @foreach (var di in dataIntegrityLevels) { <option value="@di" selected="@(Content.DataIntegrity == di)">@di</option> }
                        </select>
                    </div>
                    <div class="mfw-field">
                        <label class="mfw-label">Report</label>
                        <input class="mfw-input" placeholder="Report name or location" @bind="Content.Report" />
                    </div>
                    <div class="mfw-field span-2">
                        <label class="mfw-checkbox-row"><input type="checkbox" @bind="Content.DataReady" /> Data Ready</label>
                    </div>
                    <div class="mfw-field span-2">
                        <label class="mfw-label">KPI Controls</label>
                        <textarea class="mfw-textarea" rows="3" placeholder="Controls applied to this KPI" @bind="Content.KPIControls"></textarea>
                    </div>
                    <div class="mfw-field span-2">
                        <label class="mfw-label">Mitigating Factors</label>
                        <textarea class="mfw-textarea" rows="2" placeholder="Factors that may affect this KPI" @bind="Content.MitigatingFactors"></textarea>
                    </div>
                    <div class="mfw-field span-2">
                        <label class="mfw-label">Comments</label>
                        <textarea class="mfw-textarea" rows="2" @bind="Content.Comment"></textarea>
                    </div>
                </div>
            }

        </div>

        <!-- Footer -->
        <div class="mfw-footer">
            <div class="mfw-footer-left">
                @if (currentStep > 0)
                {
                    <button class="mfw-btn mfw-btn-secondary" @onclick="PreviousStep">← Previous</button>
                }
            </div>
            <button class="mfw-btn mfw-btn-secondary" @onclick="() => OnCancel.InvokeAsync()">Cancel</button>
            @if (currentStep < totalSteps - 1)
            {
                <button class="mfw-btn mfw-btn-primary" @onclick="NextStep">Next →</button>
            }
            else
            {
                <button class="mfw-btn mfw-btn-primary" @onclick="SaveAsync">
                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                    Save Metric
                </button>
            }
        </div>
    </div>
</div>
@code {
    [Parameter] public Metric Content { get; set; } = new();
    [Parameter] public EventCallback<Metric> OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private int currentStep = 0;
    private int totalSteps = 7;
    private string[] StepNames = { "Functions", "KPI Details", "Ownership", "Dimensions", "Data Source", "Filters", "Measurement" };

    private string[] filterTypes = new[] { "text", "date", "number", "select" };
    private (string Value, string Label)[] filterOperators = new[]
    {
        ("=", "Equals (=)"),
        ("<>", "Not Equals (<>)"),
        ("<", "Less Than (<)"),
        (">", "Greater Than (>)"),
        ("<=", "Less Than or Equal (<=)"),
        (">=", "Greater Than or Equal (>=)"),
        ("IN", "In List (IN)"),
        ("NOT IN", "Not In List (NOT IN)"),
        ("LIKE", "Contains (LIKE)"),
        ("NOT LIKE", "Does Not Contain (NOT LIKE)"),
        ("BETWEEN", "Between (BETWEEN)")
    };

    private MetricType[] metricTypes = Enum.GetValues<MetricType>();
    private MetricPerspective[] metricPerspectives = Enum.GetValues<MetricPerspective>();
    private MetricLevel[] metricLevels = Enum.GetValues<MetricLevel>();
    private MetricPolarity[] metricPolarities = Enum.GetValues<MetricPolarity>();
    private ReportingFrequency[] reportingFrequencies = Enum.GetValues<ReportingFrequency>();
    private DataIntegrityLevel[] dataIntegrityLevels = Enum.GetValues<DataIntegrityLevel>();
    private DataSourceType[] dataSourceTypes = Enum.GetValues<DataSourceType>();

    private bool hasDataSource = false;
    private bool useExistingDataSource = false;
    private int? selectedDataSourceId = null;
    private string selectedDataSourceIdString = "";
    private MetricDataSource DataSourceModel = new MetricDataSource { Port = 8123, Type = DataSourceType.ClickHouse };
    private List<MetricDataSource> AvailableDataSources = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataSources();
        if (Content.MetricDataSourceId != null && Content.MetricDataSource != null)
        {
            hasDataSource = true;
            useExistingDataSource = true;
            selectedDataSourceId = Content.MetricDataSourceId;
            selectedDataSourceIdString = Content.MetricDataSourceId.Value.ToString();
            DataSourceModel = Content.MetricDataSource;
        }
    }

    private async Task LoadDataSources()
    {
        try
        {
            if (!string.IsNullOrEmpty(Content.CompanyId))
            {
                HttpClient.DefaultRequestHeaders.Remove("X-Company-Id");
                HttpClient.DefaultRequestHeaders.Add("X-Company-Id", Content.CompanyId);
            }
            var response = await HttpClient.GetFromJsonAsync<List<MetricDataSource>>("api/metrics/datasources");
            if (response != null) AvailableDataSources = response;
        }
        catch { AvailableDataSources = new(); }
    }

    private void OnDataSourceSelectionChangedFromString(string value)
    {
        selectedDataSourceIdString = value;
        if (int.TryParse(value, out var id))
        {
            selectedDataSourceId = id;
            var selected = AvailableDataSources.FirstOrDefault(ds => ds.Id == id);
            if (selected != null) DataSourceModel = selected;
        }
        else { selectedDataSourceId = null; }
    }

    private void NextStep() { if (currentStep < totalSteps - 1) currentStep++; }
    private void PreviousStep() { if (currentStep > 0) currentStep--; }

    private async Task SaveAsync()
    {
        if (hasDataSource)
        {
            if (useExistingDataSource && selectedDataSourceId != null)
            {
                Content.MetricDataSourceId = selectedDataSourceId;
                Content.MetricDataSource = null;
            }
            else if (!useExistingDataSource)
            {
                Content.MetricDataSourceId = null;
                Content.MetricDataSource = new MetricDataSource
                {
                    ConnectionName = DataSourceModel.ConnectionName,
                    Type = DataSourceModel.Type,
                    Host = DataSourceModel.Host,
                    Port = DataSourceModel.Port,
                    Database = DataSourceModel.Database,
                    Username = DataSourceModel.Username,
                    Password = DataSourceModel.Password,
                    UseSSL = DataSourceModel.UseSSL
                };
            }
            else
            {
                Content.MetricDataSourceId = null;
                Content.MetricDataSource = null;
            }
        }
        else
        {
            Content.MetricDataSourceId = null;
            Content.MetricDataSource = null;
        }
        await OnSave.InvokeAsync(Content);
    }

    private void AddFunction() => Content.Functions.Add(new MetricFunction { Function = string.Empty });
    private void AddOwner() => Content.Owners.Add(new MetricOwner { OwnerName = string.Empty });
    private void AddRecipient() => Content.Recipients.Add(new MetricRecipient { RecipientName = string.Empty });
    private void AddVerifier() => Content.Verifiers.Add(new MetricVerifier { VerifierName = string.Empty });
    private void AddDimension() => Content.Dimensions.Add(new MetricDimension { Name = string.Empty });

    private void AddFilter()
    {
        var nextSort = Content.Filters.Any() ? Content.Filters.Max(f => f.SortOrder) + 1 : 0;
        Content.Filters.Add(new MetricFilter { FilterLabel = string.Empty, ColumnName = string.Empty, FilterType = "text", Operator = "=", SortOrder = nextSort });
    }

    private string GetDefaultValuePlaceholder(string op) => op switch
    {
        "IN" or "NOT IN" => "value1;value2;value3",
        "BETWEEN" => "start_value;end_value",
        "LIKE" or "NOT LIKE" => "%search_term%",
        _ => "Default value"
    };
}