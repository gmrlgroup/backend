@using Application.Shared.Models
@using Application.Shared.Enums
@using Application.Client.Services
@inject DatabaseTableClientService DatabaseService
@inject StateContainer StateContainer
@inject IJSRuntime JSRuntime

<!-- Data Freshness -->
<div class="bg-white overflow-hidden shadow rounded-lg">
    <div class="px-6 py-5 sm:p-6">
        <div class="flex items-center justify-between mb-4 gap-3 flex-wrap">
            <div>
                <h3 class="text-lg leading-6 font-medium text-gray-900">Data Freshness</h3>
                <p class="text-xs text-gray-500 mt-0.5">Flag this table as stale when its newest row is older than the threshold. Checked read-only on each monitoring run through the parent database's connection.</p>
            </div>
            @if (check?.IsEnabled == true)
            {
                <span class="text-xs px-2 py-0.5 rounded-full bg-green-100 text-green-700">Enabled</span>
            }
        </div>

        @if (check != null && !check.HasDatabaseConnection)
        {
            <div class="mb-4 bg-amber-50 border border-amber-200 rounded-md p-3 text-sm text-amber-800">
                This table isn't linked to a database with a saved connection. Add it from its database entity
                (the <span class="font-medium">Tables</span> card → <span class="font-medium">Fetch tables</span>)
                and configure that database's connection so freshness can be read.
            </div>
        }

        <div class="grid grid-cols-1 sm:grid-cols-6 gap-4">
            <div class="sm:col-span-3">
                <label class="block text-sm font-medium text-gray-700">Freshness column</label>
                <input @bind="form.FreshnessColumn" placeholder="updated_at"
                       class="mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
                <p class="text-xs text-gray-400 mt-1">Timestamp column inspected with MAX(...).</p>
            </div>
            <div class="sm:col-span-2">
                <label class="block text-sm font-medium text-gray-700">Max age (minutes)</label>
                <input @bind="form.MaxAgeMinutes" type="number" min="1"
                       class="mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
            </div>
            <div class="sm:col-span-1 flex items-end">
                <label class="inline-flex items-center gap-2 text-sm text-gray-700 pb-2">
                    <input @bind="form.IsEnabled" type="checkbox" class="h-4 w-4 rounded text-indigo-600 border-gray-300 focus:ring-indigo-500" />
                    Enabled
                </label>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="mt-4 rounded-md p-3 text-sm @(messageOk ? "bg-green-50 border border-green-200 text-green-800" : "bg-red-50 border border-red-200 text-red-700")">
                @message
            </div>
        }

        @if (lastResult != null)
        {
            <div class="mt-4 rounded-md p-3 text-sm @ResultClass(lastResult)">
                @if (!lastResult.Ok)
                {
                    <span>Check failed: @lastResult.Error</span>
                }
                else
                {
                    <div class="flex flex-wrap gap-x-6 gap-y-1">
                        <span><span class="font-medium">@(lastResult.IsStale ? "Stale" : (lastResult.LastUpdatedUtc.HasValue ? "Fresh" : "No timestamp"))</span></span>
                        @if (lastResult.LastUpdatedUtc.HasValue)
                        {
                            <span>Last updated: @lastResult.LastUpdatedUtc.Value.ToString("yyyy-MM-dd HH:mm")Z (@AgeText(lastResult.AgeMinutes) ago)</span>
                        }
                        @if (lastResult.RowCount.HasValue)
                        {
                            <span>Rows: @lastResult.RowCount.Value.ToString("N0")</span>
                        }
                        @if (lastResult.ResponseMs.HasValue)
                        {
                            <span class="text-gray-500">@lastResult.ResponseMs.Value.ToString("F0") ms</span>
                        }
                    </div>
                }
            </div>
        }

        <AuthorizeView Roles="@writeRoles" Context="freshCtx">
            <Authorized>
                <div class="mt-5 pt-4 border-t border-gray-100 flex items-center justify-end gap-2">
                    @if (configured)
                    {
                        <button @onclick="Delete"
                                class="inline-flex items-center px-3 py-1.5 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-red-600 bg-white hover:bg-red-50">
                            Delete
                        </button>
                    }
                    <button @onclick="RunNow" disabled="@(isRunning || check?.HasDatabaseConnection != true)"
                            class="inline-flex items-center px-3 py-1.5 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50">
                        @(isRunning ? "Checking..." : "Run check now")
                    </button>
                    <button @onclick="Save" disabled="@isSaving"
                            class="inline-flex items-center px-4 py-1.5 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 disabled:opacity-50">
                        @(isSaving ? "Saving..." : "Save")
                    </button>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>
</div>

@code {
    [Parameter] public string EntityId { get; set; } = string.Empty;

    private string CompanyId => StateContainer.Company?.Id ?? string.Empty;
    private string writeRoles => $"{CompanyId}_INCIDENTS,{CompanyId}_ADMIN";

    private TableCheckDto? check;
    private TableCheckRequest form = new() { MaxAgeMinutes = 1440 };
    private bool configured;

    private bool isSaving;
    private bool isRunning;
    private bool messageOk;
    private string? message;
    private TableFreshnessResult? lastResult;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(CompanyId)) return;
        await Load();
    }

    private async Task Load()
    {
        check = await DatabaseService.GetTableCheckAsync(CompanyId, EntityId);
        if (check != null)
        {
            configured = !string.IsNullOrEmpty(check.FreshnessColumn) || check.IsEnabled;
            form = new TableCheckRequest
            {
                FreshnessColumn = check.FreshnessColumn,
                MaxAgeMinutes = check.MaxAgeMinutes,
                IsEnabled = check.IsEnabled
            };
        }
    }

    private async Task Save()
    {
        isSaving = true;
        message = null;
        try
        {
            check = await DatabaseService.SaveTableCheckAsync(CompanyId, EntityId, form);
            configured = true;
            messageOk = true;
            message = "Freshness check saved.";
        }
        catch (Exception ex)
        {
            messageOk = false;
            message = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task Delete()
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "Remove this freshness check?")) return;
        if (await DatabaseService.DeleteTableCheckAsync(CompanyId, EntityId))
        {
            configured = false;
            lastResult = null;
            message = null;
            form = new TableCheckRequest { MaxAgeMinutes = 1440 };
            await Load();
        }
    }

    private async Task RunNow()
    {
        isRunning = true;
        message = null;
        try
        {
            lastResult = await DatabaseService.RunTableCheckAsync(CompanyId, EntityId);
        }
        finally
        {
            isRunning = false;
        }
    }

    private static string ResultClass(TableFreshnessResult r)
    {
        if (!r.Ok) return "bg-red-50 border border-red-200 text-red-700";
        if (r.IsStale) return "bg-yellow-50 border border-yellow-200 text-yellow-800";
        return "bg-green-50 border border-green-200 text-green-800";
    }

    private static string AgeText(double? minutes)
    {
        if (minutes == null) return "?";
        var m = minutes.Value;
        if (m < 60) return $"{m:F0}m";
        if (m < 1440) return $"{m / 60:F1}h";
        return $"{m / 1440:F1}d";
    }
}
