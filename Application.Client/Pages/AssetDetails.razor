@page "/status/entities/{AssetId}"
@using Application.Shared.Models
@using Application.Shared.Enums
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.FluentUI.AspNetCore.Components
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject MonitoredAssetClientService EntityService
@inject AssetStatusHistoryClientService HistoryService
@inject EntityAudienceClientService AudienceService
@inject StateContainer StateContainer
@attribute [Authorize(Policy = PolicyNames.StatusRead)]

<PageTitle>Entity Details - @(entity?.Name ?? "Loading...")</PageTitle>

<div class="min-h-screen bg-gray-50">
    @if (isLoading)
    {
        <div class="flex justify-center items-center h-64">
            <div class="animate-spin rounded-full h-10 w-10 border-2 border-indigo-600 border-t-transparent"></div>
        </div>
    }
    else if (entity == null)
    {
        <div class="max-w-3xl mx-auto px-4 py-20 text-center">
            <div class="mx-auto w-14 h-14 rounded-full bg-gray-100 flex items-center justify-center">
                <svg class="w-7 h-7 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
            </div>
            <h3 class="mt-4 text-lg font-semibold text-gray-900">Entity not found</h3>
            <p class="mt-1 text-sm text-gray-500">The entity you're looking for doesn't exist.</p>
            <button @onclick="BackToEntities"
                    class="mt-6 inline-flex items-center px-4 py-2 text-sm font-medium rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 transition-colors">
                Back to Entities
            </button>
        </div>
    }
    else
    {
        <div class="w-full px-4 sm:px-6 py-6">
            <!-- Back link -->
            <button @onclick="BackToEntities"
                    class="inline-flex items-center text-sm font-medium text-gray-500 hover:text-gray-900 transition-colors mb-4">
                <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                </svg>
                Entities
            </button>

            <!-- Header card -->
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-5">
                <div class="flex flex-col gap-5 sm:flex-row sm:items-start sm:justify-between">
                    <div class="flex items-start gap-4 min-w-0">
                        <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-indigo-50 flex items-center justify-center text-2xl">
                            @entity.GetEntityTypeIcon()
                        </div>
                        <div class="min-w-0">
                            <div class="flex flex-wrap items-center gap-2">
                                <h1 class="text-2xl font-bold text-gray-900 truncate">@entity.Name</h1>
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @entity.GetEntityTypeClass()">
                                    @entity.EntityType.ToString()
                                </span>
                                @if (entity.IsCritical)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">
                                        <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                                        </svg>
                                        Critical
                                    </span>
                                }
                            </div>
                            <div class="mt-1.5 flex items-center gap-2 text-sm">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @GetAssetStatusClass(currentEntityStatus)">
                                    <span class="w-1.5 h-1.5 rounded-full bg-current mr-1.5 opacity-70"></span>
                                    @currentEntityStatus.ToString()
                                </span>
                                <span class="text-gray-300">·</span>
                                <span class="text-gray-500">@(entity.IsActive ? "Active" : "Inactive")</span>
                            </div>
                            @if (!string.IsNullOrEmpty(entity.Description))
                            {
                                <p class="mt-3 text-sm text-gray-600 max-w-2xl">@entity.Description</p>
                            }
                        </div>
                    </div>
                    <AuthorizeView Roles="@writeRoles">
                        <Authorized>
                            <div class="flex items-center gap-2 flex-shrink-0">
                                <button @onclick="OpenUpdateStatusModal"
                                        class="inline-flex items-center px-3.5 py-2 text-sm font-medium rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 transition-colors">
                                    <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                                    </svg>
                                    Update Status
                                </button>
                                <button @onclick="EditEntity" title="Edit"
                                        class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-gray-300 text-gray-600 bg-white hover:bg-gray-50 transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                    </svg>
                                </button>
                                <button @onclick="DeleteEntity" title="Delete"
                                        class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-gray-300 text-red-600 bg-white hover:bg-red-50 hover:border-red-200 transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                    </svg>
                                </button>
                            </div>
                        </Authorized>
                    </AuthorizeView>
                </div>
            </div>

            <!-- Main Content -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 items-start">
                <!-- Left Column - Main Info -->
                <div class="lg:col-span-2 space-y-5">
                    <!-- Basic Information -->
                    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                        <h3 class="text-base font-semibold text-gray-900 mb-5">Details</h3>
                        <dl class="grid grid-cols-1 gap-x-6 gap-y-5 sm:grid-cols-2 lg:grid-cols-3">
                            <div>
                                <dt class="text-xs font-medium uppercase tracking-wide text-gray-400">Type</dt>
                                <dd class="mt-1 text-sm text-gray-900">@entity.EntityType.ToString()</dd>
                            </div>
                            <div>
                                <dt class="text-xs font-medium uppercase tracking-wide text-gray-400">State</dt>
                                <dd class="mt-1 flex items-center text-sm text-gray-900">
                                    <span class="w-2 h-2 @(entity.IsActive ? "bg-green-500" : "bg-gray-400") rounded-full mr-2"></span>
                                    @(entity.IsActive ? "Active" : "Inactive")
                                </dd>
                            </div>
                            @if (!string.IsNullOrEmpty(entity.Owner))
                            {
                                <div>
                                    <dt class="text-xs font-medium uppercase tracking-wide text-gray-400">Owner</dt>
                                    <dd class="mt-1 text-sm text-gray-900">@entity.Owner</dd>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(entity.Version))
                            {
                                <div>
                                    <dt class="text-xs font-medium uppercase tracking-wide text-gray-400">Version</dt>
                                    <dd class="mt-1 text-sm text-gray-900">@entity.Version</dd>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(entity.Location))
                            {
                                <div>
                                    <dt class="text-xs font-medium uppercase tracking-wide text-gray-400">Location</dt>
                                    <dd class="mt-1 text-sm text-gray-900">@entity.Location</dd>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(entity.Url))
                            {
                                <div class="sm:col-span-2 lg:col-span-3">
                                    <dt class="text-xs font-medium uppercase tracking-wide text-gray-400">URL</dt>
                                    <dd class="mt-1 text-sm">
                                        <a href="@entity.Url" target="_blank" class="inline-flex items-center text-indigo-600 hover:text-indigo-800 break-all">
                                            @entity.Url
                                            <svg class="inline w-3.5 h-3.5 ml-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                                            </svg>
                                        </a>
                                    </dd>
                                </div>
                            }
                        </dl>
                    </div>

                    <!-- Dependencies & Impact -->
                    <DependencyImpact EntityId="@entity.Id" />

                    @if (entity.EntityType == AssetType.Server)
                    {
                        <ServerManagement EntityId="@entity.Id" />
                    }

                    @if (entity.EntityType == AssetType.Dataset
                         && !string.IsNullOrEmpty(entity.Url)
                         && entity.Url.Contains("powerbi.com", StringComparison.OrdinalIgnoreCase))
                    {
                        <PowerBiDataset EntityId="@entity.Id" EntityUrl="@entity.Url" />
                    }

                    @if (entity.EntityType == AssetType.Database)
                    {
                        <DatabaseTables EntityId="@entity.Id" />
                    }
                </div>

                <!-- Right Column - Sidebar -->
                <div class="space-y-5">
                    <!-- Quick Actions -->
                    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                        <h3 class="text-base font-semibold text-gray-900 mb-4">Quick Actions</h3>
                        <div class="space-y-2">
                            <AuthorizeView Roles="@writeRoles" Context="editCtx">
                                <Authorized>
                                    <button @onclick="EditEntity"
                                            class="w-full flex items-center px-3 py-2 text-sm font-medium rounded-lg text-gray-700 hover:bg-gray-50 transition-colors">
                                        <svg class="mr-3 h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                        </svg>
                                        Edit Entity
                                    </button>
                                </Authorized>
                            </AuthorizeView>
                            <button @onclick="ManageDependencies"
                                    class="w-full flex items-center px-3 py-2 text-sm font-medium rounded-lg text-gray-700 hover:bg-gray-50 transition-colors">
                                <svg class="mr-3 h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
                                </svg>
                                Manage Dependencies
                            </button>
                            <AuthorizeView Roles="@writeRoles" Context="statusCtx">
                                <Authorized>
                                    <button @onclick="OpenUpdateStatusModal"
                                            class="w-full flex items-center px-3 py-2 text-sm font-medium rounded-lg text-gray-700 hover:bg-gray-50 transition-colors">
                                        <svg class="mr-3 h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                                        </svg>
                                        Update Status
                                    </button>
                                </Authorized>
                            </AuthorizeView>
                            @if (!string.IsNullOrEmpty(entity.Url))
                            {
                                <a href="@entity.Url" target="_blank"
                                   class="w-full flex items-center px-3 py-2 text-sm font-medium rounded-lg text-gray-700 hover:bg-gray-50 transition-colors">
                                    <svg class="mr-3 h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                                    </svg>
                                    Open URL
                                </a>
                            }
                        </div>
                    </div>

                    <!-- Entity Metadata -->
                    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                        <h3 class="text-base font-semibold text-gray-900 mb-4">Entity Info</h3>
                        <dl class="space-y-4">
                            <div>
                                <dt class="text-xs font-medium uppercase tracking-wide text-gray-400">Created</dt>
                                <dd class="mt-1 text-sm text-gray-900">@(entity.CreatedOn?.ToString("MMM dd, yyyy") ?? "Unknown")</dd>
                            </div>
                            <div>
                                <dt class="text-xs font-medium uppercase tracking-wide text-gray-400">Last Modified</dt>
                                <dd class="mt-1 text-sm text-gray-900">@(entity.ModifiedOn?.ToString("MMM dd, yyyy") ?? "Never")</dd>
                            </div>
                            <div>
                                <dt class="text-xs font-medium uppercase tracking-wide text-gray-400">Entity ID</dt>
                                <dd class="mt-1 text-xs text-gray-500 font-mono break-all">@entity.Id</dd>
                            </div>
                        </dl>
                    </div>

                    <!-- Audience -->
                    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                        <div class="flex items-center justify-between mb-5">
                            <div>
                                <h3 class="text-base font-semibold text-gray-900">Audience</h3>
                                <p class="text-xs text-gray-500 mt-0.5">Notified by email when an incident is opened on this entity (or anything it depends on).</p>
                            </div>
                        </div>

                        <AuthorizeView Roles="@writeRoles" Context="audienceCtx">
                            <Authorized>
                                <div class="flex flex-col gap-2 mb-4">
                                    <FluentSelect @bind-Value="selectedUserId" TOption="string" Class="w-full">
                                        <FluentOption Value="" TOption="string">Select a user...</FluentOption>
                                        @foreach (var u in assignableUsers)
                                        {
                                            <FluentOption Value="@u.Id" TOption="string">@(string.IsNullOrWhiteSpace(u.UserName) ? u.Email : u.UserName) (@u.Email)</FluentOption>
                                        }
                                    </FluentSelect>
                                    <div class="flex gap-2">
                                        <FluentSelect @bind-Value="selectedAudienceTypeString" TOption="string" Class="flex-1">
                                            <FluentOption Value="Owner" TOption="string">Owner</FluentOption>
                                            <FluentOption Value="Maintainer" TOption="string">Maintainer</FluentOption>
                                            <FluentOption Value="Stakeholder" TOption="string">Stakeholder</FluentOption>
                                        </FluentSelect>
                                        <FluentButton Appearance="Appearance.Accent" @onclick="AddAudienceMember"
                                                      Disabled="@(string.IsNullOrWhiteSpace(selectedUserId) || isSavingAudience)">
                                            @(isSavingAudience ? "Adding..." : "Add")
                                        </FluentButton>
                                    </div>
                                </div>
                            </Authorized>
                        </AuthorizeView>

                        @if (audience.Any())
                        {
                            <div class="space-y-2.5">
                                @foreach (var member in audience)
                                {
                                    <div class="flex items-center p-3 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors">
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium @GetAudienceTypeClass(member.AudienceType) flex-shrink-0 mr-3">
                                            @member.AudienceType.ToString()
                                        </span>
                                        <div class="flex-1 min-w-0">
                                            <span class="text-sm font-medium text-gray-900">@(string.IsNullOrWhiteSpace(member.DisplayName) ? member.Email : member.DisplayName)</span>
                                            <p class="mt-0.5 text-xs text-gray-500 break-all">@member.Email</p>
                                        </div>
                                        <AuthorizeView Roles="@writeRoles" Context="removeCtx">
                                            <Authorized>
                                                <button @onclick="() => RemoveAudienceMember(member.Id)" title="Remove"
                                                        class="flex-shrink-0 inline-flex items-center justify-center w-8 h-8 rounded-lg border border-gray-300 text-red-600 bg-white hover:bg-red-50 hover:border-red-200 transition-colors ml-3">
                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                                    </svg>
                                                </button>
                                            </Authorized>
                                        </AuthorizeView>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-8 border border-dashed border-gray-200 rounded-lg">
                                <svg class="mx-auto h-7 w-7 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-1.13a4 4 0 10-4-4 4 4 0 004 4z"></path>
                                </svg>
                                <p class="mt-2 text-sm text-gray-400">No audience members yet</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Update Status Modal -->
@if (showStatusUpdateModal)
{
    <FluentDialog>
        <div class="bg-white rounded-lg shadow-xl max-w-lg w-full">
            <div class="flex items-center justify-between p-6 border-b border-gray-200 bg-gray-50 rounded-t-lg">
                <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
                        <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-lg font-semibold text-gray-900">Update Entity Status</h3>
                        <p class="text-sm text-gray-500">Change the entity status and manage incidents</p>
                    </div>
                </div>
            </div>
            <div class="p-6">
                <EditForm Model="statusUpdateModel" OnValidSubmit="HandleStatusUpdate">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="text-red-600 text-sm mb-4" />

                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Current Status</label>
                            <div class="p-3 bg-gray-50 rounded-lg">
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium @GetAssetStatusClass(currentEntityStatus)">
                                    @currentEntityStatus.ToString()
                                </span>
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                New Status <span class="text-red-500">*</span>
                            </label>
                            <FluentSelect @bind-Value="selectedStatusString" TOption="string" Class="w-full">
                                <FluentOption Value="Unknown" TOption="string">Unknown</FluentOption>
                                <FluentOption Value="Online" TOption="string">Online</FluentOption>
                                <FluentOption Value="Offline" TOption="string">Offline</FluentOption>
                                <FluentOption Value="Degraded" TOption="string">Degraded</FluentOption>
                                <FluentOption Value="Maintenance" TOption="string">Maintenance</FluentOption>
                                <FluentOption Value="Error" TOption="string">Error</FluentOption>
                            </FluentSelect>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                Status Message <span class="text-red-500">*</span>
                            </label>
                            <FluentTextArea @bind-Value="statusUpdateModel.StatusMessage" Rows="3"
                                            Placeholder="Provide details about this status change..."
                                            Class="w-full" Required="true" />
                        </div>

                        @if (statusUpdateModel.Status != AssetStatus.Online && currentEntityStatus == AssetStatus.Online)
                        {
                            <div class="bg-yellow-50 border border-yellow-200 rounded-md p-3">
                                <p class="text-sm text-yellow-700">
                                    This will create a new incident for the status change from Online to @statusUpdateModel.Status.
                                </p>
                            </div>
                        }
                        else if (statusUpdateModel.Status == AssetStatus.Online && currentEntityStatus != AssetStatus.Online)
                        {
                            <div class="bg-green-50 border border-green-200 rounded-md p-3">
                                <p class="text-sm text-green-700">
                                    This will resolve any open incidents for this entity and update them as resolved.
                                </p>
                            </div>
                        }
                    </div>

                    <div class="flex justify-end space-x-3 pt-6 mt-6 border-t border-gray-200">
                        <FluentButton Appearance="Appearance.Neutral" @onclick="CloseStatusUpdateModal">Cancel</FluentButton>
                        <FluentButton Appearance="Appearance.Accent" Type="ButtonType.Submit"
                                      Disabled="@(string.IsNullOrWhiteSpace(statusUpdateModel.StatusMessage) || isUpdatingStatus)">
                            @(isUpdatingStatus ? "Updating..." : "Update Status")
                        </FluentButton>
                    </div>
                </EditForm>
            </div>
        </div>
    </FluentDialog>
}

@code {
    [Parameter] public string AssetId { get; set; } = string.Empty;

    private MonitoredAsset? entity;
    private bool isLoading = true;

    private string queryParam => StateContainer.Company is null ? "" : $"?c={StateContainer.Company.Id}";

    // Status write actions require the company INCIDENTS role (ADMIN always allowed).
    private string writeRoles => $"{StateContainer.Company?.Id}_INCIDENTS,{StateContainer.Company?.Id}_ADMIN";

    private bool showStatusUpdateModal = false;
    private bool isUpdatingStatus = false;
    private StatusUpdateModel statusUpdateModel = new();
    private AssetStatus currentEntityStatus = AssetStatus.Unknown;

    // Audience
    private List<EntityAudience> audience = new();
    private List<EntityAudienceClientService.AssignableUser> assignableUsers = new();
    private string selectedUserId = string.Empty;
    private string selectedAudienceTypeString = nameof(EntityAudienceType.Stakeholder);
    private bool isSavingAudience = false;

    private string selectedStatusString
    {
        get => statusUpdateModel.Status.ToString();
        set => statusUpdateModel.Status = Enum.Parse<AssetStatus>(value);
    }

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(AssetId))
        {
            await LoadEntity();
        }
    }

    private async Task LoadEntity()
    {
        try
        {
            entity = await EntityService.GetEntityAsync(AssetId);

            if (entity != null)
            {
                var companyId = StateContainer.Company?.Id ?? "";
                var latestStatus = await HistoryService.GetLatestEntityStatusAsync(AssetId, companyId);
                currentEntityStatus = latestStatus?.Status ?? AssetStatus.Unknown;

                audience = await AudienceService.GetAudienceAsync(companyId, AssetId);
                assignableUsers = await AudienceService.GetAssignableUsersAsync(companyId, AssetId);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading entity: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void BackToEntities()
    {
        Navigation.NavigateTo($"/status/entities{queryParam}");
    }

    private void EditEntity()
    {
        if (entity != null)
            Navigation.NavigateTo($"/status/entities/{entity.Id}/edit{queryParam}");
    }

    private async Task DeleteEntity()
    {
        if (entity == null) return;

        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete '{entity.Name}'? This action cannot be undone.");
        if (confirmed)
        {
            try
            {
                await EntityService.DeleteEntityAsync(entity.Id);
                Navigation.NavigateTo($"/status/entities{queryParam}");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting entity: {ex.Message}");
                await JSRuntime.InvokeVoidAsync("alert", "Error deleting entity. Please try again.");
            }
        }
    }

    private void ManageDependencies()
    {
        Navigation.NavigateTo($"/status/entities/{AssetId}/dependencies{queryParam}");
    }

    private void OpenUpdateStatusModal()
    {
        statusUpdateModel = new StatusUpdateModel { Status = currentEntityStatus };
        showStatusUpdateModal = true;
    }

    private void CloseStatusUpdateModal()
    {
        showStatusUpdateModal = false;
        statusUpdateModel = new();
    }

    private async Task HandleStatusUpdate()
    {
        if (entity == null || string.IsNullOrWhiteSpace(statusUpdateModel.StatusMessage)) return;

        isUpdatingStatus = true;

        try
        {
            await EntityService.UpdateEntityStatusAsync(AssetId, statusUpdateModel.Status, statusUpdateModel.StatusMessage);
            await JSRuntime.InvokeVoidAsync("alert", "Entity status updated successfully!");
            CloseStatusUpdateModal();
            currentEntityStatus = statusUpdateModel.Status;
            await LoadEntity();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating entity status: {ex.Message}");
            await JSRuntime.InvokeVoidAsync("alert", "Error updating entity status. Please try again.");
        }
        finally
        {
            isUpdatingStatus = false;
        }
    }

    private async Task AddAudienceMember()
    {
        if (string.IsNullOrWhiteSpace(selectedUserId)) return;

        isSavingAudience = true;
        try
        {
            var companyId = StateContainer.Company?.Id ?? "";
            var type = Enum.Parse<EntityAudienceType>(selectedAudienceTypeString);
            var created = await AudienceService.AddAsync(companyId, AssetId, selectedUserId, type);
            if (created != null)
            {
                audience = await AudienceService.GetAudienceAsync(companyId, AssetId);
                selectedUserId = string.Empty;
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("alert", "Could not add audience member. They may already be assigned with this role, or have no email.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error adding audience member: {ex.Message}");
        }
        finally
        {
            isSavingAudience = false;
        }
    }

    private async Task RemoveAudienceMember(string id)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Remove this audience member?");
        if (!confirmed) return;

        try
        {
            var companyId = StateContainer.Company?.Id ?? "";
            if (await AudienceService.RemoveAsync(companyId, id))
                audience = await AudienceService.GetAudienceAsync(companyId, AssetId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error removing audience member: {ex.Message}");
        }
    }

    private string GetAudienceTypeClass(EntityAudienceType type) => type switch
    {
        EntityAudienceType.Owner => "bg-indigo-100 text-indigo-800",
        EntityAudienceType.Maintainer => "bg-blue-100 text-blue-800",
        EntityAudienceType.Stakeholder => "bg-gray-100 text-gray-700",
        _ => "bg-gray-100 text-gray-700"
    };

    private string GetAssetStatusClass(AssetStatus status) => status switch
    {
        AssetStatus.Online => "bg-green-100 text-green-800",
        AssetStatus.Offline => "bg-gray-100 text-gray-800",
        AssetStatus.Degraded => "bg-yellow-100 text-yellow-800",
        AssetStatus.Maintenance => "bg-blue-100 text-blue-800",
        AssetStatus.Error => "bg-red-100 text-red-800",
        _ => "bg-gray-100 text-gray-800"
    };

    private class StatusUpdateModel
    {
        public AssetStatus Status { get; set; } = AssetStatus.Unknown;
        public string StatusMessage { get; set; } = string.Empty;
    }
}
