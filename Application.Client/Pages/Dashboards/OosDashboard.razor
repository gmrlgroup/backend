@page "/dashboards/oos"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using System.Globalization
@using Application.Shared.Authorization
@using Application.Shared.Models.Dashboards.Oos
@using Microsoft.AspNetCore.Authorization
@using System.Net.Http.Json
@attribute [Authorize(Policy = PolicyNames.DashboardsRead)]
@inject HttpClient Http
@inject StateContainer _stateContainer
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Out-of-Stock Report</PageTitle>

<HeadContent>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
</HeadContent>

@{
    var filtered = FilteredItems().ToList();
    var skus = filtered.Count;
    var rate = _totalCatalog > 0 ? (double)skus / _totalCatalog * 100 : 0;
    var lost = filtered.Sum(i => i.Lost);
    var storesAffected = filtered.Select(i => i.Store).Distinct().Count();

    var storeEntries = filtered.GroupBy(i => i.Store)
        .Select(g => new { Name = g.Key, Lost = g.Sum(x => x.Lost) })
        .OrderByDescending(x => x.Lost).Take(10).ToList();
    var maxStore = storeEntries.Count > 0 ? Math.Max(1, storeEntries.Max(x => x.Lost)) : 1;

    var vendorEntries = filtered.GroupBy(i => i.Supplier)
        .Select(g => new
        {
            Name = g.Key,
            Skus = g.Count(),
            Lost = g.Sum(x => x.Lost),
            Avg = g.Where(x => x.State != "low").Select(x => (double)x.DaysOut).DefaultIfEmpty(0).Average(),
            Fill = _vendorFill.TryGetValue(g.Key, out var f) ? f : 90.0
        })
        .OrderByDescending(x => x.Lost).ToList();
    var worst = vendorEntries.FirstOrDefault();

    var dimLabel = _catDim == "warehouse" ? "warehouse" : _catDim == "group" ? "store group" : "category";
}

<div class="oos-wrap">

    <header class="top">
        <div class="brand">
            <div class="mark">OOS</div>
            <div>
                <h1>Out-of-Stock Report</h1>
                <div class="sub">Retail inventory availability · daily operations view</div>
            </div>
        </div>
        <div class="asof">
            <div>Reporting period</div>
            <div class="day">@_asOf.ToString("MMM d, yyyy", EnUs)</div>
            <div class="live"><span class="dot"></span> <span>@_totalCatalog.ToString("#,##0", EnUs) Live SKUs tracked</span></div>
        </div>
    </header>

    <section class="filters" aria-label="Filters">
        <div class="fgroup">
            <label for="fCategory">Category</label>
            <select id="fCategory" @bind="_fCategory">
                <option value="all">All categories</option>
                @foreach (var c in Categories())
                {
                    <option value="@c">@c</option>
                }
            </select>
        </div>
        <div class="fgroup">
            <label for="fRegion">Region</label>
            <select id="fRegion" @bind="_fRegion">
                <option value="all">All regions</option>
                @foreach (var r in Regions())
                {
                    <option value="@r">@r</option>
                }
            </select>
        </div>
        <div class="fgroup">
            <label for="fState">Stock state</label>
            <select id="fState" @bind="_fState">
                <option value="all">All states</option>
                <option value="out">Out of stock</option>
                <option value="low">Low stock</option>
                <option value="restocking">Restocking</option>
            </select>
        </div>
        <div class="spacer" style="flex:1"></div>
        <button class="btn" @onclick="ResetFilters">Clear filters</button>
        @if (!string.IsNullOrWhiteSpace(_detailsUrl))
        {
            <button class="btn primary" @onclick="OpenDetails">View item details →</button>
        }
    </section>

    <section class="kpis" aria-label="Key metrics">
        <div class="tag fade" style="animation-delay:.02s">
            <div class="klabel">OOS SKUs</div>
            <div class="kval">@skus.ToString("#,##0", EnUs)</div>
            <div class="kfoot"><span class="delta up">+12%</span> vs. prior week</div>
        </div>
        <div class="tag fade alarm" style="animation-delay:.07s">
            <div class="klabel">OOS rate</div>
            <div class="kval">@rate.ToString("0.0", EnUs)%</div>
            <div class="kfoot"><span class="delta up">+0.3pt</span> vs. prior week</div>
        </div>
        <div class="tag fade" style="animation-delay:.12s">
            <div class="klabel">Est. lost sales</div>
            <div class="kval">@FmtMoney(lost)</div>
            <div class="kfoot"><span>@FmtMoneyK(lost) est. weekly run-rate</span></div>
        </div>
        <div class="tag fade" style="animation-delay:.17s">
            <div class="klabel">Stores affected</div>
            <div class="kval">@storesAffected</div>
            <div class="kfoot"><span>of @_totalStores stores</span></div>
        </div>
    </section>

    <section class="grid">
        <div class="panel">
            <div class="panel-head">
                <div>
                    <h2>Out-of-stock items</h2>
                    <div class="phint">Count of affected SKUs by @dimLabel</div>
                </div>
                <div class="segmented" role="group" aria-label="Break down by">
                    <button class="seg @(_catDim == "category" ? "active" : "")" @onclick='() => SetDim("category")'>Category</button>
                    <button class="seg @(_catDim == "warehouse" ? "active" : "")" @onclick='() => SetDim("warehouse")'>Warehouse</button>
                    <button class="seg @(_catDim == "group" ? "active" : "")" @onclick='() => SetDim("group")'>Store group</button>
                </div>
            </div>
            <div class="chartbox"><canvas id="oosCatChart"></canvas></div>
        </div>
        <div class="panel">
            <h2>OOS rate trend</h2>
            <div class="phint">Share of Live catalog unavailable · this year (YTD) vs. prior year</div>
            <div class="chartbox"><canvas id="oosTrendChart"></canvas></div>
        </div>
    </section>

    <section class="grid">
        <div class="panel">
            <h2>Lost sales by store</h2>
            <div class="phint">Estimated revenue impact, ranked · top 10 stores</div>
            <div style="margin-top:6px">
                @if (storeEntries.Count == 0)
                {
                    <div class="empty">No stores match the current filters.</div>
                }
                else
                {
                    @foreach (var s in storeEntries)
                    {
                        <div class="region-row">
                            <div class="rname" title="@s.Name">@s.Name</div>
                            <div class="rbar"><div class="rfill" style="width:@(((s.Lost / maxStore) * 100).ToString("0.0", EnUs))%"></div></div>
                            <div class="rval">@FmtMoney(s.Lost)</div>
                        </div>
                    }
                }
            </div>
        </div>
        <div class="panel">
            <h2>Vendor insights</h2>
            <div class="phint">Supplier performance across the current selection</div>
            @if (worst != null)
            {
                <div class="callout">
                    <span class="ci">⚠</span>
                    <span>
                        <b>@worst.Name</b> is driving the most lost sales (@FmtMoney(worst.Lost)) across @worst.Skus SKU@(worst.Skus > 1 ? "s" : ""),
                        with a @worst.Fill.ToString("0.0", EnUs)% fill rate and @worst.Avg.ToString("0.0", EnUs) avg days out.
                        Prioritize this vendor for replenishment follow-up.
                    </span>
                </div>
                <div style="margin-top:4px">
                    <div class="vrow vhead"><div>Vendor</div><div class="vnum">OOS SKUs</div><div class="vnum">Lost sales</div><div class="vnum">Fill rate</div></div>
                    <div class="vendor-scroll">
                        @foreach (var v in vendorEntries)
                        {
                            <div class="vrow">
                                <div class="vname" title="@v.Name">@v.Name</div>
                                <div class="vnum">@v.Skus</div>
                                <div class="vnum lost">@FmtMoney(v.Lost)</div>
                                <div class="fill"><span class="fbadge @FillClass(v.Fill)">@v.Fill.ToString("0.0", EnUs)%</span></div>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="empty">No vendors match the current filters.</div>
            }
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(_detailsUrl))
    {
        <section class="tablewrap">
            <button type="button" class="detail-cta" @onclick="OpenDetails">
                <div>
                    <h2>Item-level details</h2>
                    <div class="phint">Open the full affected-items dataset for SKU-by-SKU detail</div>
                </div>
                <span class="detail-arrow">View dataset →</span>
            </button>
        </section>
    }

    <footer>Lost-sales figures are modelled from daily sales velocity × days unavailable, computed from the sales_dataset warehouse (Live items, current + prior year).</footer>
</div>

@code {
    private static readonly CultureInfo EnUs = CultureInfo.GetCultureInfo("en-US");

    private List<OosItem> _all = new();
    private Dictionary<string, double> _vendorFill = new();
    private List<OosTrendPoint> _trend = new();
    private int _totalCatalog;
    private int _totalStores;
    private DateTime _asOf = DateTime.Today;
    private bool _loading = true;
    private bool _trendDrawn;
    private string? _detailsUrl;

    // filters
    private string _fCategory = "all";
    private string _fRegion = "all";
    private string _fState = "all";

    private string _catDim = "category";

    private IJSObjectReference? _module;
    private string? _lastChartSig;

    protected override async Task OnInitializedAsync()
    {
        _stateContainer.OnChange += OnCompanyChanged;
        await LoadAsync();
    }

    private async void OnCompanyChanged() => await InvokeAsync(LoadAsync);

    private async Task<string?> GetCompanyIdAsync()
    {
        for (var i = 0; i < 50 && _stateContainer.Company is null; i++)
            await Task.Delay(100);
        return _stateContainer.Company?.Id;
    }

    private async Task LoadAsync()
    {
        var companyId = await GetCompanyIdAsync();
        if (string.IsNullOrEmpty(companyId)) return;

        _loading = true;
        StateHasChanged();
        try
        {
            var req = new HttpRequestMessage(HttpMethod.Get, "api/dashboards/oos");
            req.Headers.Add("X-Company-ID", companyId);
            var resp = await Http.SendAsync(req);
            if (resp.IsSuccessStatusCode)
            {
                var data = await resp.Content.ReadFromJsonAsync<OosDashboardResponse>();
                if (data != null)
                {
                    _all = data.Items ?? new();
                    _vendorFill = data.VendorFillRates ?? new();
                    _trend = data.Trend ?? new();
                    _totalCatalog = data.TotalCatalog;
                    _totalStores = data.TotalStores;
                    _asOf = data.AsOfDate;
                    _detailsUrl = data.DetailsUrl;
                    _trendDrawn = false;
                }
            }
            else
            {
                Console.WriteLine($"OOS fetch failed ({(int)resp.StatusCode}): {await resp.Content.ReadAsStringAsync()}");
            }
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); }
        finally
        {
            _loading = false;
            _lastChartSig = null; // force chart redraw
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/oos-dashboard.js");
        if (_module is null || _loading) return;

        // Trend (YTD vs prior year) is computed server-side and doesn't depend on the filters —
        // draw it once per data load.
        if (!_trendDrawn)
        {
            _trendDrawn = true;
            await _module.InvokeVoidAsync("renderTrendChart", "oosTrendChart",
                _trend.Select(p => p.Label).ToArray(),
                _trend.Select(p => p.ThisYear).ToArray(),
                _trend.Select(p => p.PriorYear).ToArray());
        }

        // Category breakdown depends on the filters + selected dimension.
        var sig = $"{_fCategory}|{_fRegion}|{_fState}|{_catDim}|{_all.Count}";
        if (sig == _lastChartSig) return;
        _lastChartSig = sig;

        var filtered = FilteredItems().ToList();
        var byDim = filtered
            .GroupBy(i => _catDim == "warehouse" ? i.Warehouse : _catDim == "group" ? i.Group : i.Category)
            .Select(g => new { Label = g.Key, Count = g.Count() })
            .OrderByDescending(x => x.Count).ToList();
        await _module.InvokeVoidAsync("renderCategoryChart", "oosCatChart",
            byDim.Select(x => x.Label).ToArray(), byDim.Select(x => x.Count).ToArray());
    }

    private IEnumerable<OosItem> FilteredItems() =>
        _all.Where(d =>
            (_fCategory == "all" || d.Category == _fCategory) &&
            (_fRegion == "all" || d.Region == _fRegion) &&
            (_fState == "all" || d.State == _fState));

    private IEnumerable<string> Categories() => _all.Select(i => i.Category).Where(c => !string.IsNullOrEmpty(c)).Distinct().OrderBy(c => c);
    private IEnumerable<string> Regions() => _all.Select(i => i.Region).Where(c => !string.IsNullOrEmpty(c)).Distinct().OrderBy(c => c);

    private void SetDim(string dim) => _catDim = dim;

    private void ResetFilters()
    {
        _fCategory = "all";
        _fRegion = "all";
        _fState = "all";
    }

    private void OpenDetails()
    {
        if (string.IsNullOrWhiteSpace(_detailsUrl)) return;
        var cid = _stateContainer.Company?.Id;
        var url = _detailsUrl;
        if (!string.IsNullOrEmpty(cid))
            url += (url.Contains('?') ? "&" : "?") + $"c={Uri.EscapeDataString(cid)}";
        Nav.NavigateTo(url);
    }

    private static string FillClass(double f) => f >= 95 ? "good" : f >= 90 ? "mid" : "bad";

    private static string FmtMoney(double n) => "$" + Math.Round(n).ToString("#,##0", EnUs);

    private static string FmtMoneyK(double n) =>
        n >= 1000
            ? "$" + (n / 1000).ToString(n >= 10000 ? "#,##0" : "0.0", EnUs) + "k"
            : "$" + Math.Round(n).ToString(EnUs);

    public async ValueTask DisposeAsync()
    {
        _stateContainer.OnChange -= OnCompanyChanged;
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("destroy", "oosCatChart");
                await _module.InvokeVoidAsync("destroy", "oosTrendChart");
                await _module.DisposeAsync();
            }
            catch { /* circuit already gone */ }
        }
    }
}
