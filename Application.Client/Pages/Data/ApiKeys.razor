@page "/data/api-keys"
@using System.Net.Http.Json
@using Application.Shared.Models
@using Application.Shared.Models.Data
@inject HttpClient _httpClient
@inject IToastService _toastService
@inject NavigationManager _navigationManager
@inject AuthenticationStateProvider _authenticationStateProvider
@inject IJSRuntime _js
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@attribute [Authorize(Policy = PolicyNames.DatasetsAccess)]

<PageTitle>API Keys</PageTitle>

@if (!canManage && !isLoading)
{
    <div class="flex flex-col items-center justify-center h-64 text-gray-500 gap-2">
        <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p class="text-sm font-semibold text-gray-700">Access Denied</p>
        <p class="text-xs text-gray-400">Only company admins can manage API keys.</p>
    </div>
}
else
{
<div class="ds-page">
    <div class="ds-header">
        <div>
            <h1 class="ds-title">API Keys</h1>
            <p class="ds-subtitle">Grant external systems scoped, read or import access to your data.</p>
        </div>
        @if (!showCreate)
        {
            <button class="btn btn-default" @onclick="StartCreate">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                New API Key
            </button>
        }
    </div>

    @* One-time reveal of a freshly created key. *@
    @if (!string.IsNullOrEmpty(createdPlainKey))
    {
        <div class="ds-card" style="margin-bottom:1rem;border:1px solid #16a34a;background:#f0fdf4">
            <div style="padding:1rem">
                <p style="font-weight:600;color:#15803d;margin:0 0 0.25rem">Copy your API key now</p>
                <p style="font-size:0.8125rem;color:#3f6212;margin:0 0 0.75rem">This is the only time the full key is shown. Store it somewhere safe — you can't retrieve it again.</p>
                <div style="display:flex;gap:0.5rem;align-items:center">
                    <code style="flex:1;padding:0.5rem 0.75rem;background:#fff;border:1px solid #bbf7d0;border-radius:6px;font-size:0.8125rem;overflow:auto;word-break:break-all">@createdPlainKey</code>
                    <button class="btn btn-outline" @onclick="CopyKey">Copy</button>
                    <button class="btn-icon" title="Dismiss" @onclick="() => createdPlainKey = null">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                    </button>
                </div>
            </div>
        </div>
    }

    @* Create form. *@
    @if (showCreate)
    {
        <div class="ds-form-card" style="margin-bottom:1rem">
            <p class="ds-section-title">New API Key</p>

            <div class="ds-field">
                <label class="ds-label">Name</label>
                <input class="ds-input" @bind="newName" placeholder="e.g. Partner ingest, BI export" />
            </div>

            <div class="ds-field">
                <label class="ds-label">Expires <span style="color:#71717a;font-weight:400">(optional)</span></label>
                <input class="ds-input" type="date" @bind="newExpiry" />
            </div>

            <div class="ds-field">
                <label class="ds-label">Access grants</label>
                @if (!scopeRows.Any())
                {
                    <p style="font-size:0.8125rem;color:#71717a;margin:0 0 0.5rem">Add at least one dataset/table grant.</p>
                }
                @foreach (var row in scopeRows)
                {
                    <div style="display:flex;gap:0.5rem;align-items:center;margin-bottom:0.5rem;flex-wrap:wrap">
                        <select class="ds-input" style="flex:1;min-width:160px" value="@row.DatasetId"
                                @onchange="e => OnScopeDatasetChanged(row, e.Value?.ToString())">
                            <option value="">Select dataset…</option>
                            @foreach (var ds in datasets)
                            {
                                <option value="@ds.Id">@ds.Name</option>
                            }
                        </select>

                        <select class="ds-input" style="flex:1;min-width:160px" value="@(row.TableName ?? "")"
                                @onchange="e => row.TableName = string.IsNullOrEmpty(e.Value?.ToString()) ? null : e.Value!.ToString()"
                                disabled="@string.IsNullOrEmpty(row.DatasetId)">
                            <option value="">All tables</option>
                            @if (tablesByDataset.TryGetValue(row.DatasetId, out var tbls))
                            {
                                @foreach (var t in tbls)
                                {
                                    <option value="@t">@t</option>
                                }
                            }
                        </select>

                        <label style="display:flex;align-items:center;gap:0.25rem;font-size:0.8125rem">
                            <input type="checkbox" @bind="row.CanRead" /> Read
                        </label>
                        <label style="display:flex;align-items:center;gap:0.25rem;font-size:0.8125rem">
                            <input type="checkbox" @bind="row.CanImport" /> Import
                        </label>

                        <button class="btn-icon btn-icon-delete" title="Remove grant" @onclick="() => scopeRows.Remove(row)">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                        </button>
                    </div>
                }
                <button class="btn btn-outline" @onclick="AddScopeRow" style="margin-top:0.25rem">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                    Add grant
                </button>
            </div>

            <div class="ds-step-nav">
                <button class="btn btn-outline" @onclick="CancelCreate" disabled="@isSaving">Cancel</button>
                <button class="btn btn-default" @onclick="CreateKey" disabled="@isSaving">
                    @if (isSaving) { <span>Creating…</span> } else { <span>Create key</span> }
                </button>
            </div>
        </div>
    }

    <div class="ds-card">
        @if (isLoading)
        {
            <div class="ds-loading"><div class="ds-spinner"></div><span>Loading keys…</span></div>
        }
        else if (keys?.Any() == true)
        {
            <div class="ds-table-wrap">
                <table class="ds-table">
                    <thead>
                        <tr>
                            <th class="ds-th">Name</th>
                            <th class="ds-th">Prefix</th>
                            <th class="ds-th">Grants</th>
                            <th class="ds-th">Status</th>
                            <th class="ds-th">Last used</th>
                            <th class="ds-th ds-th-actions">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var key in keys)
                        {
                            <tr class="ds-tr">
                                <td class="ds-td ds-td-name"><span class="ds-dataset-name">@key.Name</span></td>
                                <td class="ds-td"><code style="font-size:0.75rem">@key.KeyPrefix…</code></td>
                                <td class="ds-td"><span class="ds-dataset-desc">@ScopeSummary(key)</span></td>
                                <td class="ds-td">@StatusBadge(key)</td>
                                <td class="ds-td ds-td-date">@(key.LastUsedAt?.ToLocalTime().ToString("MMM dd, yyyy HH:mm") ?? "—")</td>
                                <td class="ds-td ds-td-actions-cell">
                                    <div class="ds-actions">
                                        @if (key.IsActive)
                                        {
                                            <button class="btn-icon" title="Revoke key" @onclick="() => RevokeKey(key)">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m4.9 4.9 14.2 14.2"/></svg>
                                            </button>
                                        }
                                        <button class="btn-icon btn-icon-delete" title="Delete key" @onclick="() => DeleteKey(key)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="ds-empty">
                <div class="ds-empty-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m21 2-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0 3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
                </div>
                <h3 class="ds-empty-title">No API keys yet</h3>
                <p class="ds-empty-sub">Create a key to let an external system read or import your data.</p>
            </div>
        }
    </div>
</div>
}

@code {
    private List<ApiKeyDto>? keys;
    private List<Dataset> datasets = new();
    private Dictionary<string, List<string>> tablesByDataset = new();
    private List<ScopeRow> scopeRows = new();

    private bool isLoading = true;
    private bool isSaving = false;
    private bool canManage;
    private bool showCreate = false;
    private string? companyId;

    private string newName = string.Empty;
    private DateTime? newExpiry;
    private string? createdPlainKey;

    [SupplyParameterFromQuery]
    public string? c { get; set; }

    private class ScopeRow
    {
        public string DatasetId { get; set; } = string.Empty;
        public string? TableName { get; set; }
        public bool CanRead { get; set; } = true;
        public bool CanImport { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        companyId = c;
        if (string.IsNullOrEmpty(companyId))
        {
            _toastService.ShowWarning("Company ID is required");
            isLoading = false;
            return;
        }

        var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
        // Key management is admin-only. HasCompanyRole(companyId) is true only for {companyId}_ADMIN.
        canManage = authState.User.HasCompanyRole(companyId);
        if (!canManage) { isLoading = false; return; }

        SetHeaders();
        await LoadKeys();
        await LoadDatasets();
        isLoading = false;
    }

    private void SetHeaders()
    {
        _httpClient.DefaultRequestHeaders.Remove("X-Company-Id");
        _httpClient.DefaultRequestHeaders.Add("X-Company-Id", companyId!);
        // The datasets/tables endpoints also require a UserId header.
        var userId = _authenticationStateProvider.GetAuthenticationStateAsync().Result
            .User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (!string.IsNullOrEmpty(userId))
        {
            _httpClient.DefaultRequestHeaders.Remove("UserId");
            _httpClient.DefaultRequestHeaders.Add("UserId", userId);
        }
    }

    private async Task LoadKeys()
    {
        try
        {
            var response = await _httpClient.GetAsync("api/ApiKeys");
            if (response.IsSuccessStatusCode)
                keys = await response.Content.ReadFromJsonAsync<List<ApiKeyDto>>() ?? new();
            else
            {
                _toastService.ShowError($"Failed to load API keys: {response.StatusCode}");
                keys = new();
            }
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Error loading API keys: {ex.Message}");
            keys = new();
        }
    }

    private async Task LoadDatasets()
    {
        try
        {
            var response = await _httpClient.GetAsync("api/datasets");
            if (response.IsSuccessStatusCode)
                datasets = await response.Content.ReadFromJsonAsync<List<Dataset>>() ?? new();
        }
        catch { /* leave datasets empty; the form will simply have nothing to pick */ }
    }

    private async Task EnsureTablesLoaded(string datasetId)
    {
        if (string.IsNullOrEmpty(datasetId) || tablesByDataset.ContainsKey(datasetId)) return;
        try
        {
            var response = await _httpClient.GetAsync($"api/datasets/{datasetId}/tables");
            tablesByDataset[datasetId] = response.IsSuccessStatusCode
                ? (await response.Content.ReadFromJsonAsync<List<string>>() ?? new())
                : new();
        }
        catch
        {
            tablesByDataset[datasetId] = new();
        }
    }

    private void StartCreate()
    {
        newName = string.Empty;
        newExpiry = null;
        scopeRows = new() { new ScopeRow() };
        showCreate = true;
    }

    private void CancelCreate()
    {
        showCreate = false;
        scopeRows.Clear();
    }

    private void AddScopeRow() => scopeRows.Add(new ScopeRow());

    private async Task OnScopeDatasetChanged(ScopeRow row, string? datasetId)
    {
        row.DatasetId = datasetId ?? string.Empty;
        row.TableName = null; // reset table selection when the dataset changes
        await EnsureTablesLoaded(row.DatasetId);
    }

    private async Task CreateKey()
    {
        if (string.IsNullOrWhiteSpace(newName))
        {
            _toastService.ShowWarning("Please enter a name");
            return;
        }

        var scopes = scopeRows
            .Where(r => !string.IsNullOrEmpty(r.DatasetId) && (r.CanRead || r.CanImport))
            .Select(r => new ApiKeyScopeDto
            {
                DatasetId = r.DatasetId,
                TableName = string.IsNullOrWhiteSpace(r.TableName) ? null : r.TableName,
                CanRead = r.CanRead,
                CanImport = r.CanImport,
            })
            .ToList();

        if (!scopes.Any())
        {
            _toastService.ShowWarning("Add at least one grant with Read or Import enabled");
            return;
        }

        try
        {
            isSaving = true;
            var request = new CreateApiKeyRequest
            {
                Name = newName.Trim(),
                ExpiresAt = newExpiry?.ToUniversalTime(),
                Scopes = scopes,
            };
            var response = await _httpClient.PostAsJsonAsync("api/ApiKeys", request);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<CreateApiKeyResult>();
                createdPlainKey = result?.PlainTextKey;
                _toastService.ShowSuccess("API key created");
                showCreate = false;
                scopeRows.Clear();
                await LoadKeys();
            }
            else
            {
                var msg = await response.Content.ReadAsStringAsync();
                _toastService.ShowError($"Failed to create key: {msg}");
            }
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Error creating key: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task RevokeKey(ApiKeyDto key)
    {
        try
        {
            var response = await _httpClient.PostAsync($"api/ApiKeys/{key.Id}/revoke", null);
            if (response.IsSuccessStatusCode) { _toastService.ShowSuccess("Key revoked"); await LoadKeys(); }
            else _toastService.ShowError($"Failed to revoke key: {response.StatusCode}");
        }
        catch (Exception ex) { _toastService.ShowError($"Error revoking key: {ex.Message}"); }
    }

    private async Task DeleteKey(ApiKeyDto key)
    {
        try
        {
            var response = await _httpClient.DeleteAsync($"api/ApiKeys/{key.Id}");
            if (response.IsSuccessStatusCode) { _toastService.ShowSuccess("Key deleted"); await LoadKeys(); }
            else _toastService.ShowError($"Failed to delete key: {response.StatusCode}");
        }
        catch (Exception ex) { _toastService.ShowError($"Error deleting key: {ex.Message}"); }
    }

    private async Task CopyKey()
    {
        if (string.IsNullOrEmpty(createdPlainKey)) return;
        try
        {
            await _js.InvokeVoidAsync("navigator.clipboard.writeText", createdPlainKey);
            _toastService.ShowSuccess("Key copied to clipboard");
        }
        catch
        {
            _toastService.ShowInfo("Copy unavailable — select the key text and press Ctrl+C.");
        }
    }

    private static string ScopeSummary(ApiKeyDto key)
    {
        if (key.Scopes == null || !key.Scopes.Any()) return "No grants";
        return string.Join(", ", key.Scopes.Select(s =>
        {
            var target = string.IsNullOrEmpty(s.TableName) ? $"{s.DatasetName} (all tables)" : $"{s.DatasetName}.{s.TableName}";
            var perms = (s.CanRead ? "R" : "") + (s.CanImport ? "I" : "");
            return $"{target} [{perms}]";
        }));
    }

    private RenderFragment StatusBadge(ApiKeyDto key) => __builder =>
    {
        string label; string color;
        if (key.RevokedAt != null) { label = "Revoked"; color = "#dc2626"; }
        else if (!key.IsActive) { label = "Expired"; color = "#d97706"; }
        else { label = "Active"; color = "#16a34a"; }
        <span style="@($"display:inline-block;padding:0.125rem 0.5rem;border-radius:9999px;font-size:0.75rem;font-weight:600;color:{color};background:{color}1a")">@label</span>
    };
}
