@page "/data/datasets/create"
@using System.ComponentModel.DataAnnotations
@inject HttpClient _httpClient
@inject NavigationManager _navigationManager
@inject IToastService _toastService
@inject AuthenticationStateProvider _authenticationStateProvider
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@attribute [Authorize(Policy = PolicyNames.DatasetsAccess)]

<PageTitle>Create Dataset</PageTitle>

@if (!canEdit)
{
    <div class="flex flex-col items-center justify-center h-64 text-gray-500 gap-2">
        <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p class="text-sm font-semibold text-gray-700">Access Denied</p>
        <p class="text-xs text-gray-400">You don't have permission to create datasets.</p>
    </div>
}
else
{
<div class="ds-page">
    <div>
        <nav class="ds-breadcrumb">
            <a href="@($"/data/datasets?c={companyId}")">Datasets</a>
            <span class="ds-breadcrumb-sep">/</span>
            <span>New Dataset</span>
        </nav>
        <h1 class="ds-title">New Dataset</h1>
        <p class="ds-subtitle">Create a new dataset for your organization</p>
    </div>

    <div class="ds-form-layout">
        <div class="ds-form-card">
            <p class="ds-section-title">Dataset Information</p>
            <EditForm Model="@datasetModel" OnValidSubmit="@HandleValidSubmit" FormName="create-dataset" novalidate>
                <DataAnnotationsValidator />

                <div class="ds-field">
                    <label class="ds-label" for="ds-name">Dataset Name <span style="color:#ef4444">*</span></label>
                    <InputText id="ds-name" class="ds-input" @bind-Value="datasetModel.Name" placeholder="e.g., Sales Analytics 2024" />
                    <ValidationMessage For="@(() => datasetModel.Name)" class="ds-error" />
                    <span class="ds-hint">Use a descriptive name that identifies the dataset's purpose</span>
                </div>

                <div class="ds-field">
                    <label class="ds-label" for="ds-desc">Description <span style="color:#ef4444">*</span></label>
                    <InputTextArea id="ds-desc" class="ds-textarea" @bind-Value="datasetModel.Description" placeholder="Describe what this dataset contains, its source, and intended use..." rows="4" />
                    <ValidationMessage For="@(() => datasetModel.Description)" class="ds-error" />
                    <span class="ds-hint">Include data structure, format, and business context</span>
                </div>

                <div class="ds-form-actions">
                    <button type="submit" class="btn btn-default" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="ds-spinner" style="width:14px;height:14px;border-width:1.5px;margin-right:2px"></span>
                            <span>Creating...</span>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                            <span>Create Dataset</span>
                        }
                    </button>
                    <button type="button" class="btn btn-outline" @onclick="Cancel" disabled="@isSubmitting">Cancel</button>
                </div>
            </EditForm>
        </div>

        <div>
            <div class="ds-tip-card">
                <p class="ds-tip-title">Naming Convention</p>
                <p class="ds-tip-text">Use clear, descriptive names that include the data type, time period, and source when applicable.</p>
            </div>
            <div class="ds-tip-card" style="border-left-color:#22c55e">
                <p class="ds-tip-title">Documentation</p>
                <p class="ds-tip-text">Include data schema, update frequency, and data quality notes in the description.</p>
            </div>
            <div class="ds-tip-card" style="border-left-color:#f59e0b">
                <p class="ds-tip-title">Data Governance</p>
                <p class="ds-tip-text">Consider data privacy, retention policies, and access controls before creating the dataset.</p>
            </div>
        </div>
    </div>
</div>
}

@code {
    private Dataset datasetModel = new();
    private bool isSubmitting = false;
    private bool canEdit;
    private string? companyId;

    [SupplyParameterFromQuery]
    public string? c { get; set; }

    protected override async Task OnInitializedAsync()
    {
        companyId = c;
        if (string.IsNullOrEmpty(companyId))
        {
            _toastService.ShowError("Company ID is required");
            _navigationManager.NavigateTo("/");
            return;
        }
        datasetModel.CompanyId = companyId;

        var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        canEdit = user.IsInRole($"{companyId}_EDIT_DATA");
        if (user.Identity?.IsAuthenticated == true)
        {
            var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(userId))
            {
                _httpClient.DefaultRequestHeaders.Remove("UserId");
                _httpClient.DefaultRequestHeaders.Add("UserId", userId);
            }
        }
    }

    private async Task HandleValidSubmit()
    {
        isSubmitting = true;
        try
        {
            var response = await _httpClient.PostAsJsonAsync("api/datasets", datasetModel);
            if (response.IsSuccessStatusCode)
            {
                _toastService.ShowSuccess("Dataset created successfully!");
                _navigationManager.NavigateTo($"/data/datasets?c={companyId}");
            }
            else
            {
                var errorMessage = await response.Content.ReadAsStringAsync();
                _toastService.ShowError($"Failed to create dataset: {errorMessage}");
            }
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"An error occurred: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Cancel() => _navigationManager.NavigateTo($"/data/datasets?c={companyId}");
}
