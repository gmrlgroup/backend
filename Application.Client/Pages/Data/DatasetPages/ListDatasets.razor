@page "/data/datasets"
@using System.Net.Http.Json
@using Application.Shared.Enums
@using Application.Shared.Models
@inject HttpClient _httpClient
@inject IToastService _toastService
@inject NavigationManager _navigationManager
@inject AuthenticationStateProvider _authenticationStateProvider
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@attribute [Authorize(Policy = PolicyNames.DatasetsAccess)]

<PageTitle>Datasets</PageTitle>

@if (!canView && !isLoading)
{
    <div class="flex flex-col items-center justify-center h-64 text-gray-500 gap-2">
        <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p class="text-sm font-semibold text-gray-700">Access Denied</p>
        <p class="text-xs text-gray-400">You don't have permission to view datasets.</p>
    </div>
}
else
{
<div class="ds-page">
    <div class="ds-header">
        <div>
            <h1 class="ds-title">Datasets</h1>
            <p class="ds-subtitle">
                @if (!isLoading)
                {
                    <span>@(allItems?.Count ?? 0) dataset@(allItems?.Count == 1 ? "" : "s")</span>
                }
            </p>
        </div>
        @if (canEdit)
        {
        <button class="btn btn-default" @onclick="CreateDataset">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
            New Dataset
        </button>
        }
    </div>

    <div class="ds-card">
        <div class="ds-card-toolbar">
            <div class="ds-search-wrap">
                <svg class="ds-search-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                <input class="ds-search" type="search" placeholder="Search datasets..." @bind="searchTerm" @bind:event="oninput" @bind:after="HandleSearch" />
            </div>
        </div>

        @if (isLoading)
        {
            <div class="ds-loading">
                <div class="ds-spinner"></div>
                <span>Loading datasets...</span>
            </div>
        }
        else if (pagedItems?.Any() == true)
        {
            <div class="ds-table-wrap">
                <table class="ds-table">
                    <thead>
                        <tr>
                            <th class="ds-th ds-th-sortable" @onclick='() => SetSort("name")'>
                                <span>Name</span> @SortIcon("name")
                            </th>
                            <th class="ds-th ds-th-sortable" @onclick='() => SetSort("description")'>
                                <span>Description</span> @SortIcon("description")
                            </th>
                            <th class="ds-th">Source Type</th>
                            <th class="ds-th">Source Entity</th>
                            <th class="ds-th ds-th-sortable" @onclick='() => SetSort("created")'>
                                <span>Created</span> @SortIcon("created")
                            </th>
                            <th class="ds-th ds-th-actions">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dataset in pagedItems)
                        {
                            <tr class="ds-tr">
                                <td class="ds-td ds-td-name">
                                    <span class="ds-dataset-name">@dataset.Name</span>
                                </td>
                                <td class="ds-td">
                                    <span class="ds-dataset-desc">@dataset.Description</span>
                                </td>
                                <td class="ds-td">
                                    @if (dataset.SourceType == DatasetSourceType.External)
                                    {
                                        var info = SourceInfo(dataset.SourceEntityId);
                                        <span style="display:inline-flex;align-items:center;font-size:0.6875rem;font-weight:600;padding:0.125rem 0.5rem;border-radius:9999px;background:#eef2ff;color:#4f46e5;text-transform:uppercase;letter-spacing:0.03em">
                                            @(info?.DatabaseType.ToString() ?? "External")
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="font-size:0.6875rem;font-weight:600;padding:0.125rem 0.5rem;border-radius:9999px;background:#f4f4f5;color:#71717a;text-transform:uppercase;letter-spacing:0.03em">Local</span>
                                    }
                                </td>
                                <td class="ds-td">
                                    @if (dataset.SourceType == DatasetSourceType.External && !string.IsNullOrEmpty(dataset.SourceEntityId))
                                    {
                                        <a href="@($"/status/entities/{dataset.SourceEntityId}?c={companyId}")"
                                           title="@(SourceInfo(dataset.SourceEntityId)?.Name ?? "Open entity details")"
                                           style="font-size:0.75rem;color:#2563eb;font-family:ui-monospace,Consolas,monospace;text-decoration:none;max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:inline-block">
                                            @dataset.SourceEntityId
                                        </a>
                                    }
                                    else
                                    {
                                        <span style="font-size:0.75rem;color:#a1a1aa">—</span>
                                    }
                                </td>
                                <td class="ds-td ds-td-date">@dataset.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td class="ds-td ds-td-actions-cell">
                                    <div class="ds-actions">
                                        <button class="btn-icon btn-icon-open" title="Open dataset" @onclick="() => OpenDataset(dataset)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
                                        </button>
                                        <button class="btn-icon btn-icon-share" title="Share dataset" @onclick="() => ShareDataset(dataset)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/></svg>
                                        </button>
                                        @if (canEdit)
                                        {
                                        <button class="btn-icon btn-icon-edit" title="Edit dataset" @onclick="() => EditDataset(dataset)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                                        </button>
                                        <button class="btn-icon btn-icon-delete" title="Delete dataset" @onclick="() => DeleteDataset(dataset)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                                        </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (totalPages > 1)
            {
                <div class="ds-pagination">
                    <span>Page @(currentPage + 1) of @totalPages</span>
                    <div class="ds-page-btns">
                        <button class="btn-page" disabled="@(currentPage == 0)" @onclick="PrevPage">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                        </button>
                        @for (int i = 0; i < totalPages; i++)
                        {
                            var pageIndex = i;
                            <button class="btn-page @(currentPage == pageIndex ? "btn-page-active" : "")" @onclick="() => GoToPage(pageIndex)">@(i + 1)</button>
                        }
                        <button class="btn-page" disabled="@(currentPage >= totalPages - 1)" @onclick="NextPage">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                        </button>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="ds-empty">
                <div class="ds-empty-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/></svg>
                </div>
                <h3 class="ds-empty-title">No datasets found</h3>
                <p class="ds-empty-sub">
                    @if (!string.IsNullOrWhiteSpace(searchTerm))
                    {
                        <span>No datasets match "<strong>@searchTerm</strong>". Try a different search.</span>
                    }
                    else if (string.IsNullOrEmpty(companyId))
                    {
                        <span>Company ID is required to load datasets.</span>
                    }
                    else
                    {
                        <span>Get started by creating your first dataset.</span>
                    }
                </p>
                @if (canEdit && !string.IsNullOrEmpty(companyId) && string.IsNullOrWhiteSpace(searchTerm))
                {
                    <button class="btn btn-default" @onclick="CreateDataset">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                        Create Dataset
                    </button>
                }
            </div>
        }
    </div>
</div>
}

<ShareDatasetModal IsVisible="@showShareModal"
                   IsVisibleChanged="@((bool value) => showShareModal = value)"
                   DatasetId="@(selectedDatasetForSharing?.Id ?? string.Empty)"
                   DatasetName="@(selectedDatasetForSharing?.Name ?? string.Empty)"
                   CompanyId="@(companyId ?? string.Empty)" />

@code {
    private List<Dataset>? allItems;
    private List<Dataset>? filteredItems;
    private IEnumerable<Dataset>? pagedItems;
    private string searchTerm = string.Empty;
    private string sortField = "name";
    private bool sortAsc = true;
    private int currentPage = 0;
    private const int pageSize = 10;
    private int totalPages => (int)Math.Ceiling((filteredItems?.Count ?? 0) / (double)pageSize);
    private bool canView;
    private bool canEdit;
    private bool isLoading = true;
    private string? companyId;
    private bool showShareModal = false;
    private Dataset? selectedDatasetForSharing;

    // Lookup of connected Database entities (id → name/type) to label external datasets' source.
    private Dictionary<string, DatabaseEntityOptionDto> sourceDbLookup = new();
    private DatabaseEntityOptionDto? SourceInfo(string? id) =>
        !string.IsNullOrEmpty(id) && sourceDbLookup.TryGetValue(id, out var v) ? v : null;

    [SupplyParameterFromQuery]
    public string? c { get; set; }

    protected override async Task OnInitializedAsync()
    {
        companyId = c;
        if (string.IsNullOrEmpty(companyId))
        {
            _toastService.ShowWarning("Company ID is required to view datasets");
            isLoading = false;
            return;
        }
        var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        // {companyId}_ADMIN is implicitly allowed by HasCompanyRole.
        canView = user.HasCompanyRole(companyId, "VIEW_DATA");
        canEdit = user.HasCompanyRole(companyId, "EDIT_DATA");
        if (!canView) { isLoading = false; return; }
        await LoadDatasets();
    }

    private async Task LoadDatasets()
    {
        try
        {
            isLoading = true;
            StateHasChanged();

            var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (!string.IsNullOrEmpty(userId))
                {
                    _httpClient.DefaultRequestHeaders.Remove("UserId");
                    _httpClient.DefaultRequestHeaders.Add("UserId", userId);
                }
                if (!string.IsNullOrEmpty(c))
                {
                    _httpClient.DefaultRequestHeaders.Remove("X-Company-Id");
                    _httpClient.DefaultRequestHeaders.Add("X-Company-Id", c);
                }
            }

            var response = await _httpClient.GetAsync("api/datasets");
            if (response.IsSuccessStatusCode)
            {
                allItems = await response.Content.ReadFromJsonAsync<List<Dataset>>();
                ApplyFilterAndSort();

                // Only fetch the database lookup when at least one dataset is external.
                if (allItems?.Any(d => d.SourceType == DatasetSourceType.External) == true)
                    await LoadSourceDatabases();
            }
            else
            {
                _toastService.ShowError($"Failed to load datasets: {response.StatusCode}");
                allItems = [];
                filteredItems = [];
                pagedItems = [];
            }
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Error loading datasets: {ex.Message}");
            allItems = [];
            filteredItems = [];
            pagedItems = [];
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadSourceDatabases()
    {
        try
        {
            var response = await _httpClient.GetAsync("api/datasets/source-databases");
            if (response.IsSuccessStatusCode)
            {
                var dbs = await response.Content.ReadFromJsonAsync<List<DatabaseEntityOptionDto>>() ?? new();
                sourceDbLookup = dbs.ToDictionary(d => d.Id, d => d);
                StateHasChanged();
            }
        }
        catch { /* labels just fall back to the entity id / "External" */ }
    }

    private void HandleSearch()
    {
        currentPage = 0;
        ApplyFilterAndSort();
    }

    private void SetSort(string field)
    {
        if (sortField == field) sortAsc = !sortAsc;
        else { sortField = field; sortAsc = true; }
        currentPage = 0;
        ApplyFilterAndSort();
    }

    private void ApplyFilterAndSort()
    {
        var query = allItems?.AsEnumerable() ?? [];
        if (!string.IsNullOrWhiteSpace(searchTerm))
            query = query.Where(d =>
                (d.Name?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) == true) ||
                (d.Description?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) == true));

        query = sortField switch
        {
            "description" => sortAsc ? query.OrderBy(d => d.Description) : query.OrderByDescending(d => d.Description),
            "created" => sortAsc ? query.OrderBy(d => d.CreatedAt) : query.OrderByDescending(d => d.CreatedAt),
            _ => sortAsc ? query.OrderBy(d => d.Name) : query.OrderByDescending(d => d.Name),
        };

        filteredItems = query.ToList();
        pagedItems = filteredItems.Skip(currentPage * pageSize).Take(pageSize);
        StateHasChanged();
    }

    private RenderFragment SortIcon(string field) => __builder =>
    {
        if (sortField == field)
        {
            if (sortAsc)
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
            }
            else
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            }
        }
        else
        {
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.3"><path d="m18 15-6-6-6 6"/></svg>
        }
    };

    private void PrevPage() { if (currentPage > 0) { currentPage--; ApplyFilterAndSort(); } }
    private void NextPage() { if (currentPage < totalPages - 1) { currentPage++; ApplyFilterAndSort(); } }
    private void GoToPage(int page) { currentPage = page; ApplyFilterAndSort(); }

    private void CreateDataset() => _navigationManager.NavigateTo($"/data/datasets/create?c={companyId}");
    private void OpenDataset(Dataset dataset) => _navigationManager.NavigateTo($"/data/tables?c={companyId}&d={dataset.Id}");
    private void EditDataset(Dataset dataset) => _navigationManager.NavigateTo($"/data/datasets/edit/{dataset.Id}?c={companyId}");
    private void ShareDataset(Dataset dataset) { selectedDatasetForSharing = dataset; showShareModal = true; }

    private async Task DeleteDataset(Dataset dataset)
    {
        if (string.IsNullOrEmpty(dataset.Id))
        {
            _toastService.ShowError("Invalid dataset ID");
            return;
        }
        try
        {
            var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (!string.IsNullOrEmpty(userId))
                {
                    _httpClient.DefaultRequestHeaders.Remove("UserId");
                    _httpClient.DefaultRequestHeaders.Add("UserId", userId);
                }
            }
            var response = await _httpClient.DeleteAsync($"api/Datasets/{dataset.Id}");
            if (response.IsSuccessStatusCode)
            {
                _toastService.ShowSuccess($"Dataset '{dataset.Name}' deleted successfully");
                await LoadDatasets();
            }
            else
            {
                _toastService.ShowError($"Failed to delete dataset: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Error deleting dataset: {ex.Message}");
        }
    }
}
