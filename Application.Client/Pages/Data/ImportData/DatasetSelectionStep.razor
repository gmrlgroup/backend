@inject HttpClient _httpClient
@inject IToastService _toastService

<div class="ds-form-card">
    <p class="ds-section-title">Choose Dataset</p>

    @if (isLoading)
    {
        <div class="ds-loading" style="padding:2.5rem 0">
            <div class="ds-spinner"></div>
            <span>Loading datasets...</span>
        </div>
    }
    else if (datasets?.Any() == true)
    {
        <div class="ds-field">
            <label class="ds-label">Select an existing dataset</label>
            <select class="ds-select" @bind="selectedDatasetId">
                <option value="">— Choose a dataset —</option>
                @foreach (var dataset in datasets)
                {
                    <option value="@dataset.Id">@dataset.Name</option>
                }
            </select>
        </div>

        <hr class="ds-divider" style="margin:1.25rem 0" />
        <p style="font-size:0.875rem;color:#71717a;margin:0 0 0.75rem 0">Or create a new dataset:</p>

        <div style="display:flex;gap:0.75rem;align-items:flex-end">
            <div class="ds-field" style="flex:1;margin-bottom:0">
                <input class="ds-input" type="text" placeholder="New dataset name" @bind="newDatasetName" @bind:event="oninput" />
            </div>
            <button class="btn btn-outline" @onclick="CreateNewDataset" disabled="@(string.IsNullOrWhiteSpace(newDatasetName) || isCreatingDataset)">
                @if (isCreatingDataset)
                {
                    <span class="ds-spinner" style="width:14px;height:14px;border-width:1.5px"></span>
                    <span>Creating...</span>
                }
                else
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                    <span>Create</span>
                }
            </button>
        </div>
    }
    else
    {
        <div class="ds-columns-empty">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color:#d4d4d8"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/></svg>
            <p style="font-size:0.9375rem;font-weight:600;color:#18181b;margin:0">No Datasets Found</p>
            <p style="font-size:0.875rem;color:#71717a;margin:0">Create your first dataset to get started</p>
            <div style="display:flex;gap:0.75rem;align-items:center;width:100%;max-width:360px">
                <input class="ds-input" type="text" style="flex:1" placeholder="Dataset name" @bind="newDatasetName" @bind:event="oninput" />
                <button class="btn btn-default" @onclick="CreateNewDataset" disabled="@(string.IsNullOrWhiteSpace(newDatasetName) || isCreatingDataset)">
                    @if (isCreatingDataset) { <span class="ds-spinner" style="width:14px;height:14px;border-width:1.5px"></span> } else { <span>Create</span> }
                </button>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(selectedDatasetId))
    {
        <div class="ds-step-nav">
            <span></span>
            <button class="btn btn-default" @onclick="Continue">
                Continue
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </button>
        </div>
    }
</div>

@code {
    [Parameter] public string CompanyId { get; set; } = string.Empty;
    [Parameter] public EventCallback<Dataset> OnDatasetSelected { get; set; }
    [Parameter] public Dataset? SelectedDataset { get; set; }
    [Parameter] public EventCallback<Dataset?> SelectedDatasetChanged { get; set; }

    private List<Dataset>? datasets;
    private bool isLoading = true;
    private bool isCreatingDataset = false;
    private string selectedDatasetId = string.Empty;
    private string newDatasetName = string.Empty;

    protected override async Task OnInitializedAsync() => await LoadDatasets();

    private async Task LoadDatasets()
    {
        try
        {
            isLoading = true;
            StateHasChanged();
            datasets = await _httpClient.GetFromJsonAsync<List<Dataset>>("api/datasets");
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Failed to load datasets: {ex.Message}");
            datasets = [];
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task CreateNewDataset()
    {
        if (string.IsNullOrWhiteSpace(newDatasetName)) return;
        try
        {
            isCreatingDataset = true;
            StateHasChanged();
            var newDataset = new Dataset { Name = newDatasetName.Trim(), Description = "Dataset created during data import", CompanyId = CompanyId };
            var response = await _httpClient.PostAsJsonAsync("api/datasets", newDataset);
            if (response.IsSuccessStatusCode)
            {
                var createdDataset = await response.Content.ReadFromJsonAsync<Dataset>();
                if (createdDataset != null)
                {
                    await LoadDatasets();
                    selectedDatasetId = createdDataset.Id!;
                    newDatasetName = string.Empty;
                    _toastService.ShowSuccess($"Dataset '{createdDataset.Name}' created");
                }
            }
            else
            {
                var err = await response.Content.ReadAsStringAsync();
                _toastService.ShowError($"Failed to create dataset: {err}");
            }
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Error: {ex.Message}");
        }
        finally
        {
            isCreatingDataset = false;
            StateHasChanged();
        }
    }

    private async Task Continue()
    {
        var dataset = datasets!.First(d => d.Id == selectedDatasetId);
        await OnDatasetSelected.InvokeAsync(dataset);
    }
}
