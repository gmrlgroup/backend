@page "/data/import"
@using Application.Shared.Models.Data
@using Application.Shared.Models
@using Microsoft.AspNetCore.Components.Forms
@using System.IO
@using System.Text
@inject HttpClient _httpClient
@inject IToastService _toastService
@inject NavigationManager _navigationManager
@inject AuthenticationStateProvider _authenticationStateProvider
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@attribute [Authorize(Policy = PolicyNames.DatasetsAccess)]

<PageTitle>Import Data</PageTitle>

@if (!canEdit)
{
    <div class="flex flex-col items-center justify-center h-64 text-gray-500 gap-2">
        <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p class="text-sm font-semibold text-gray-700">Access Denied</p>
        <p class="text-xs text-gray-400">You don't have permission to import data.</p>
    </div>
}
else
{
<div class="ds-page">
    <div class="ds-header">
        <div style="display:flex;align-items:center;gap:0.75rem">
            <button class="btn-icon" title="Back" @onclick="GoBack">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            </button>
            <div>
                <h1 class="ds-title">Import Data</h1>
                <p class="ds-subtitle">Import CSV data into your datasets</p>
            </div>
        </div>
    </div>

    <!-- Stepper -->
    <div class="ds-stepper">
        <div class="ds-step @(currentStep == 1 ? "ds-step-active" : currentStep > 1 ? "ds-step-done" : "")">
            <div class="ds-step-circle">
                @if (currentStep > 1) {
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                } else { <span>1</span> }
            </div>
            <span class="ds-step-label">Choose Dataset</span>
        </div>
        <div class="ds-step @(currentStep == 2 ? "ds-step-active" : currentStep > 2 ? "ds-step-done" : "")">
            <div class="ds-step-circle">
                @if (currentStep > 2) {
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                } else { <span>2</span> }
            </div>
            <span class="ds-step-label">Upload File</span>
        </div>
        <div class="ds-step @(currentStep == 3 ? "ds-step-active" : "")">
            <div class="ds-step-circle"><span>3</span></div>
            <span class="ds-step-label">Configure Schema</span>
        </div>
    </div>

    <!-- Step content -->
    @if (currentStep == 1)
    {
        <DatasetSelectionStep OnDatasetSelected="HandleDatasetSelected" CompanyId="@companyId" />
    }
    else if (currentStep == 2)
    {
        <FileUploadStep OnFileUploaded="@HandleFileUploaded" OnBack="GoToPreviousStep" DatasetId="@selectedDataset?.Id" />
    }
    else if (currentStep == 3)
    {
        <SchemaConfigurationStep Dataset="@selectedDataset"
                                 FileName="@fileName"
                                 CsvHeaders="@csvHeaders"
                                 SampleRows="@sampleRows"
                                 CompanyId="@companyId"
                                 Format="@importFormat"
                                 ServerColumns="@serverColumns"
                                 FileBytes="@uploadedFileBytes"
                                 OnSchemaConfirmed="HandleSchemaConfirmed"
                                 OnBack="GoToPreviousStep"
                                 TableModel="@tableModel" />
    }
</div>
}

@code {
    private int currentStep = 1;
    private Dataset? selectedDataset;
    private byte[]? uploadedFileBytes;
    private string uploadedFileName = string.Empty;
    private string uploadedContentType = "text/csv";
    private string fileName = string.Empty;
    private List<string> csvHeaders = new();
    private List<List<string>> sampleRows = new();
    private ImportFileFormat importFormat = ImportFileFormat.Csv;
    private List<Column>? serverColumns;
    private Table tableModel = new();
    private string? userId;
    private bool isProcessing = false;
    private bool canEdit;

    [SupplyParameterFromQuery(Name = "c")]
    public string? companyId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _httpClient.DefaultRequestHeaders.Remove("CompanyId");
        if (!string.IsNullOrEmpty(companyId))
            _httpClient.DefaultRequestHeaders.Add("CompanyId", companyId);

        if (string.IsNullOrEmpty(companyId))
        {
            _toastService.ShowWarning("Company ID is required");
            GoBack();
            return;
        }
        // Set the headers the data API expects (X-Company-Id + UserId). The scoped HttpClient is shared
        // for the session, so setting them once here covers every child step's calls.
        _httpClient.DefaultRequestHeaders.Remove("X-Company-Id");
        _httpClient.DefaultRequestHeaders.Add("X-Company-Id", companyId);

        var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
        // {companyId}_ADMIN is implicitly allowed by HasCompanyRole.
        canEdit = authState.User.HasCompanyRole(companyId, "EDIT_DATA");
        if (!canEdit) return;

        userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (!string.IsNullOrEmpty(userId))
        {
            _httpClient.DefaultRequestHeaders.Remove("UserId");
            _httpClient.DefaultRequestHeaders.Add("UserId", userId);
        }
    }

    private Task HandleDatasetSelected(Dataset dataset)
    {
        selectedDataset = dataset;
        currentStep = 2;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task HandleFileUploaded((byte[] fileBytes, string fileName, string contentType, List<string> headers, List<List<string>> sampleRows, ImportFileFormat format, List<Column>? serverColumns) data)
    {
        uploadedFileBytes = data.fileBytes;
        uploadedFileName = data.fileName;
        uploadedContentType = data.contentType;
        fileName = Path.GetFileNameWithoutExtension(data.fileName);
        csvHeaders = data.headers;
        sampleRows = data.sampleRows;
        importFormat = data.format;
        serverColumns = data.serverColumns;
        currentStep = 3;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task HandleSchemaConfirmed((Table table, ImportMode mode, List<string> keyColumns, bool skipInvalidRows, ImportFileFormat format) submission)
    {
        var table = submission.table;
        try
        {
            isProcessing = true;
            StateHasChanged();

            if (!string.IsNullOrEmpty(userId))
                table.CreatedBy = userId;

            // Create the table. If it already exists (a re-import into an existing table), continue —
            // the chosen import mode (append/replace/upsert) handles the data.
            var tableResponse = await _httpClient.PostAsJsonAsync("api/Datasets/tables", table);
            if (!tableResponse.IsSuccessStatusCode)
            {
                var errorContent = await tableResponse.Content.ReadAsStringAsync();
                if (!errorContent.Contains("already exists", StringComparison.OrdinalIgnoreCase))
                {
                    _toastService.ShowError($"Failed to create table: {errorContent}");
                    return;
                }
            }

            if (uploadedFileBytes == null)
            {
                _toastService.ShowError("The uploaded file is no longer available. Please re-upload and try again.");
                return;
            }

            using var content = new MultipartFormDataContent();
            var fileContent = new ByteArrayContent(uploadedFileBytes);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue("application/octet-stream");
            content.Add(fileContent, "file", uploadedFileName);
            content.Add(new StringContent(submission.format.ToString()), "format");
            content.Add(new StringContent(submission.mode.ToString()), "mode");
            content.Add(new StringContent(string.Join(",", submission.keyColumns)), "keyColumns");
            content.Add(new StringContent(submission.skipInvalidRows.ToString()), "skipInvalidRows");

            var importResponse = await _httpClient.PostAsync(
                $"api/Datasets/{selectedDataset!.Id}/tables/{table.TableName}/import", content);
            if (!importResponse.IsSuccessStatusCode)
            {
                var errorContent = await importResponse.Content.ReadAsStringAsync();
                _toastService.ShowError($"Failed to import data: {errorContent}");
                return;
            }

            var result = await importResponse.Content.ReadFromJsonAsync<ImportResult>();
            if (result == null || !result.Success)
            {
                _toastService.ShowError($"Import failed: {result?.Error ?? "unknown error"}");
                return;
            }

            var parts = new List<string> { $"{result.RowsInserted} inserted" };
            if (result.RowsUpdated > 0) parts.Add($"{result.RowsUpdated} updated");
            if (result.RowsSkipped > 0) parts.Add($"{result.RowsSkipped} skipped");
            _toastService.ShowSuccess($"Imported into '{table.SchemaName}.{table.TableName}' — {string.Join(", ", parts)}");
            GoBack();
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Error importing data: {ex.Message}");
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private void GoToPreviousStep()
    {
        if (currentStep > 1) { currentStep--; StateHasChanged(); }
    }

    private void GoBack() => _navigationManager.NavigateTo($"/data/datasets?c={companyId}");
}
