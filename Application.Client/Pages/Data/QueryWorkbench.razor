@page "/data/query"
@using System.Net.Http.Json
@using Application.Shared.Models
@using Application.Shared.Models.Data
@inject HttpClient _httpClient
@inject IToastService _toastService
@inject NavigationManager _navigationManager
@inject AuthenticationStateProvider _authenticationStateProvider
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@attribute [Authorize(Policy = PolicyNames.DatasetsAccess)]

<PageTitle>Query Workbench</PageTitle>

@if (!canView && !isLoading)
{
    <div class="flex flex-col items-center justify-center h-64 text-gray-500 gap-2">
        <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p class="text-sm font-semibold text-gray-700">Access Denied</p>
        <p class="text-xs text-gray-400">You don't have permission to query data.</p>
    </div>
}
else
{
<div class="ds-page" style="display:flex;flex-direction:column;height:90vh">
    <div class="ds-header">
        <div>
            <h1 class="ds-title">Query Workbench</h1>
            <p class="ds-subtitle">Run SQL against a dataset's tables — join, aggregate, visualize, and save.</p>
        </div>
        <div style="display:flex;align-items:center;gap:0.5rem">
            <select class="ds-input" style="min-width:200px" value="@selectedDatasetId" @onchange="OnDatasetChanged">
                <option value="">Select dataset…</option>
                @foreach (var ds in datasets)
                {
                    <option value="@ds.Id">@ds.Name</option>
                }
            </select>
            <button class="btn btn-default" @onclick="RunQuery" disabled="@(isRunning || string.IsNullOrEmpty(selectedDatasetId))">
                @if (isRunning) { <span>Running…</span> } else
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="6 3 20 12 6 21 6 3"/></svg>
                    <span>Run</span>
                }
            </button>
        </div>
    </div>

    <div style="display:flex;gap:1rem;flex:1;overflow:hidden">
        <!-- Left: saved queries + tables -->
        <div style="width:260px;flex-shrink:0;display:flex;flex-direction:column;gap:0.75rem;overflow-y:auto">
            <div class="ds-card" style="padding:0.75rem">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.5rem">
                    <span style="font-size:0.75rem;font-weight:600;color:#71717a;text-transform:uppercase;letter-spacing:0.05em">Saved Queries</span>
                    <button class="btn-icon" title="Save current query" @onclick="OpenSaveQuery" disabled="@string.IsNullOrEmpty(selectedDatasetId)">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                    </button>
                </div>
                @if (savedQueries.Any())
                {
                    @foreach (var q in savedQueries)
                    {
                        <div class="qw-saved-item" style="display:flex;align-items:center;justify-content:space-between;gap:0.25rem;padding:0.375rem 0.25rem;border-radius:4px">
                            <button class="qw-link" title="@q.Description" style="background:none;border:none;text-align:left;cursor:pointer;flex:1;color:#2563eb;font-size:0.8125rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" @onclick="() => LoadSavedQuery(q)">
                                @q.Name @if (q.IsShared) { <span style="color:#16a34a;font-size:0.6875rem">· shared</span> }
                            </button>
                            @if (q.CanEdit)
                            {
                                <button class="btn-icon btn-icon-delete" title="Delete" @onclick="() => DeleteSavedQuery(q)" style="padding:2px">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                                </button>
                            }
                        </div>
                    }
                }
                else
                {
                    <p style="font-size:0.75rem;color:#a1a1aa;margin:0">No saved queries.</p>
                }
            </div>

            <div class="ds-card" style="padding:0.75rem">
                <span style="font-size:0.75rem;font-weight:600;color:#71717a;text-transform:uppercase;letter-spacing:0.05em">Tables</span>
                <div style="margin-top:0.5rem;display:flex;flex-direction:column;gap:0.125rem">
                    @if (tables.Any())
                    {
                        @foreach (var t in tables)
                        {
                            <button class="qw-link" style="background:none;border:none;text-align:left;cursor:pointer;color:#3f3f46;font-size:0.8125rem;padding:0.25rem;border-radius:4px;display:flex;align-items:center;gap:0.375rem" @onclick="() => InsertTable(t)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:#a1a1aa;flex-shrink:0"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M3 15h18"/><path d="M9 3v18"/></svg>
                                @t
                            </button>
                        }
                    }
                    else
                    {
                        <p style="font-size:0.75rem;color:#a1a1aa;margin:0">@(string.IsNullOrEmpty(selectedDatasetId) ? "Select a dataset." : "No tables.")</p>
                    }
                </div>
            </div>
        </div>

        <!-- Right: editor + results -->
        <div style="flex:1;display:flex;flex-direction:column;gap:0.75rem;overflow:hidden;min-width:0">
            <MonacoSqlEditor @bind-Value="sql" Height="200px" />

            @if (saveQueryOpen)
            {
                <div class="ds-form-card" style="padding:0.75rem;margin:0">
                    <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap">
                        <input class="ds-input" placeholder="Query name" @bind="saveName" style="flex:1;min-width:160px" />
                        <input class="ds-input" placeholder="Description (optional)" @bind="saveDescription" style="flex:1;min-width:160px" />
                        <label style="display:flex;align-items:center;gap:0.25rem;font-size:0.8125rem"><input type="checkbox" @bind="saveShared" /> Shared</label>
                        <button class="btn btn-default" @onclick="SaveQuery" disabled="@isSaving">Save</button>
                        <button class="btn btn-outline" @onclick="() => saveQueryOpen = false">Cancel</button>
                    </div>
                </div>
            }

            @if (saveResultOpen)
            {
                <div class="ds-form-card" style="padding:0.75rem;margin:0">
                    <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap">
                        <span style="font-size:0.8125rem;color:#71717a">Save result as</span>
                        <select class="ds-input" @bind="saveResultAsView"><option value="false">Table</option><option value="true">View</option></select>
                        <input class="ds-input" placeholder="object_name" @bind="saveResultName" style="flex:1;min-width:160px" />
                        <button class="btn btn-default" @onclick="SaveResult" disabled="@isSaving">Create</button>
                        <button class="btn btn-outline" @onclick="() => saveResultOpen = false">Cancel</button>
                    </div>
                </div>
            }

            <div class="ds-card" style="flex:1;display:flex;flex-direction:column;overflow:hidden;padding:0.75rem">
                <!-- Status bar + tabs -->
                <div style="display:flex;align-items:center;justify-content:space-between;gap:0.5rem;margin-bottom:0.5rem;flex-wrap:wrap">
                    <div style="display:flex;gap:0.25rem">
                        <button class="qw-tab @(activeTab == "results" ? "qw-tab-active" : "")" @onclick='() => activeTab = "results"'>Results</button>
                        <button class="qw-tab @(activeTab == "visualize" ? "qw-tab-active" : "")" @onclick='() => activeTab = "visualize"'>Visualize</button>
                    </div>
                    <div style="display:flex;align-items:center;gap:0.75rem">
                        @if (result != null && string.IsNullOrEmpty(result.Error))
                        {
                            <span style="font-size:0.75rem;color:#71717a">
                                @if (result.IsSelect)
                                {
                                    <span>@result.RowsReturned row@(result.RowsReturned == 1 ? "" : "s")@(result.Truncated ? " (truncated)" : "") · @result.ElapsedMs ms</span>
                                }
                                else
                                {
                                    <span>@result.RowsAffected row(s) affected · @result.ElapsedMs ms</span>
                                }
                            </span>
                            @if (canEdit && result.IsSelect && result.RowsReturned > 0)
                            {
                                <button class="btn btn-outline" style="padding:0.25rem 0.5rem;font-size:0.75rem" @onclick="OpenSaveResult">Save result as…</button>
                            }
                        }
                    </div>
                </div>

                @if (result?.Error is { Length: > 0 } err)
                {
                    <div style="background:#fef2f2;border:1px solid #fecaca;color:#b91c1c;border-radius:6px;padding:0.625rem 0.75rem;font-size:0.8125rem;font-family:ui-monospace,Consolas,monospace;white-space:pre-wrap">@err</div>
                }
                else if (result == null)
                {
                    <div class="ds-empty" style="flex:1">
                        <div class="ds-empty-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                        </div>
                        <h3 class="ds-empty-title">No results yet</h3>
                        <p class="ds-empty-sub">Pick a dataset, write a query, and hit Run.</p>
                    </div>
                }
                else if (activeTab == "results")
                {
                    <div style="flex:1;overflow:hidden">
                        @if (result.IsSelect)
                        {
                            <DataResultsTable Data="@result.Rows" ShowGlobalFilter="true" ShowColumnFilters="false" ShowExport="true" PageSize="50" />
                        }
                        else
                        {
                            <p style="font-size:0.875rem;color:#16a34a">Statement executed successfully — @result.RowsAffected row(s) affected.</p>
                        }
                    </div>
                }
                else
                {
                    <!-- Visualize -->
                    <div style="display:flex;gap:0.5rem;align-items:center;margin-bottom:0.5rem;flex-wrap:wrap">
                        <select class="ds-input" @bind="chartType">
                            <option value="bar">Bar</option>
                            <option value="line">Line</option>
                            <option value="pie">Pie</option>
                        </select>
                        <select class="ds-input" @bind="chartX">
                            <option value="">X axis…</option>
                            @foreach (var col in ColumnNames) { <option value="@col">@col</option> }
                        </select>
                        <div style="display:flex;gap:0.375rem;align-items:center;flex-wrap:wrap">
                            <span style="font-size:0.75rem;color:#71717a">Values:</span>
                            @foreach (var col in ColumnNames)
                            {
                                <label style="display:flex;align-items:center;gap:0.2rem;font-size:0.75rem">
                                    <input type="checkbox" checked="@chartY.Contains(col)" @onchange="e => ToggleY(col, (bool)e.Value!)" /> @col
                                </label>
                            }
                        </div>
                    </div>
                    <div style="flex:1;min-height:0">
                        @if (!string.IsNullOrEmpty(chartX) && chartY.Any())
                        {
                            <ResultChart Rows="@result.Rows" ChartType="@chartType" XColumn="@chartX" YColumns="@chartY" />
                        }
                        else
                        {
                            <p style="font-size:0.8125rem;color:#71717a">Choose an X axis and at least one value column.</p>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
}

<style>
    .qw-tab { background:#f4f4f5; border:1px solid #e4e4e7; border-radius:6px; padding:0.25rem 0.75rem; font-size:0.8125rem; cursor:pointer; color:#52525b; }
    .qw-tab-active { background:#2563eb; color:#fff; border-color:#2563eb; }
    .qw-saved-item:hover, .qw-link:hover { background:#f4f4f5; }
</style>

@code {
    [SupplyParameterFromQuery] public string? c { get; set; }
    [SupplyParameterFromQuery] public string? DatasetId { get; set; }
    [SupplyParameterFromQuery] public string? TableName { get; set; }

    private string? companyId;
    private bool canView;
    private bool canEdit;
    private bool isLoading = true;
    private bool isRunning;
    private bool isSaving;

    private List<Dataset> datasets = new();
    private List<string> tables = new();
    private List<SavedQueryDto> savedQueries = new();

    private string selectedDatasetId = string.Empty;
    private string sql = string.Empty;
    private SqlQueryResult? result;
    private string activeTab = "results";

    // Visualize state
    private string chartType = "bar";
    private string chartX = string.Empty;
    private List<string> chartY = new();
    private List<string> ColumnNames => result?.Columns.Select(col => col.Name).ToList() ?? new();

    // Save-query form
    private bool saveQueryOpen;
    private string saveName = string.Empty;
    private string saveDescription = string.Empty;
    private bool saveShared;

    // Save-result form
    private bool saveResultOpen;
    private string saveResultName = string.Empty;
    private string saveResultAsView = "false";

    protected override async Task OnInitializedAsync()
    {
        companyId = c;
        if (string.IsNullOrEmpty(companyId))
        {
            _toastService.ShowWarning("Company ID is required");
            isLoading = false;
            return;
        }

        var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
        canView = authState.User.HasCompanyRole(companyId, "VIEW_DATA");
        canEdit = authState.User.HasCompanyRole(companyId, "EDIT_DATA");
        if (!canView) { isLoading = false; return; }

        SetHeaders(authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value);
        await LoadDatasets();

        if (!string.IsNullOrEmpty(DatasetId))
        {
            selectedDatasetId = DatasetId;
            if (!string.IsNullOrEmpty(TableName))
                sql = $"SELECT *\nFROM \"{TableName}\"\nLIMIT 100;";
            await OnDatasetSelected();
        }

        isLoading = false;
    }

    private void SetHeaders(string? userId)
    {
        _httpClient.DefaultRequestHeaders.Remove("X-Company-Id");
        _httpClient.DefaultRequestHeaders.Add("X-Company-Id", companyId!);
        if (!string.IsNullOrEmpty(userId))
        {
            _httpClient.DefaultRequestHeaders.Remove("UserId");
            _httpClient.DefaultRequestHeaders.Add("UserId", userId);
        }
    }

    private async Task LoadDatasets()
    {
        try
        {
            var response = await _httpClient.GetAsync("api/datasets");
            if (response.IsSuccessStatusCode)
                datasets = await response.Content.ReadFromJsonAsync<List<Dataset>>() ?? new();
        }
        catch (Exception ex) { _toastService.ShowError($"Error loading datasets: {ex.Message}"); }
    }

    private async Task OnDatasetChanged(ChangeEventArgs e)
    {
        selectedDatasetId = e.Value?.ToString() ?? string.Empty;
        await OnDatasetSelected();
    }

    private async Task OnDatasetSelected()
    {
        tables.Clear();
        savedQueries.Clear();
        result = null;
        if (string.IsNullOrEmpty(selectedDatasetId)) return;

        try
        {
            var tablesResponse = await _httpClient.GetAsync($"api/datasets/{selectedDatasetId}/tables");
            if (tablesResponse.IsSuccessStatusCode)
                tables = await tablesResponse.Content.ReadFromJsonAsync<List<string>>() ?? new();
        }
        catch { /* a dataset with no tables returns 404; leave empty */ }

        await LoadSavedQueries();
    }

    private async Task LoadSavedQueries()
    {
        try
        {
            var response = await _httpClient.GetAsync($"api/datasets/{selectedDatasetId}/queries");
            if (response.IsSuccessStatusCode)
                savedQueries = await response.Content.ReadFromJsonAsync<List<SavedQueryDto>>() ?? new();
        }
        catch { savedQueries = new(); }
    }

    private async Task RunQuery()
    {
        if (string.IsNullOrEmpty(selectedDatasetId)) { _toastService.ShowWarning("Select a dataset first"); return; }
        if (string.IsNullOrWhiteSpace(sql)) { _toastService.ShowWarning("Write a query first"); return; }
        try
        {
            isRunning = true;
            result = null;
            var response = await _httpClient.PostAsJsonAsync(
                $"api/datasets/{selectedDatasetId}/query/run", new SqlQueryRequest { Sql = sql });
            if (response.IsSuccessStatusCode)
            {
                result = await response.Content.ReadFromJsonAsync<SqlQueryResult>();
                // Reset chart picks to sensible defaults for the new result.
                chartX = ColumnNames.FirstOrDefault() ?? string.Empty;
                chartY = ColumnNames.Skip(1).Take(1).ToList();
                activeTab = "results";
            }
            else
            {
                var msg = await response.Content.ReadAsStringAsync();
                _toastService.ShowError($"Query failed: {msg}");
            }
        }
        catch (Exception ex) { _toastService.ShowError($"Error running query: {ex.Message}"); }
        finally { isRunning = false; }
    }

    private void InsertTable(string table)
    {
        if (string.IsNullOrWhiteSpace(sql))
            sql = $"SELECT *\nFROM \"{table}\"\nLIMIT 100;";
        else
            sql += $" \"{table}\"";
    }

    private void LoadSavedQuery(SavedQueryDto q)
    {
        sql = q.QueryText;
        _toastService.ShowInfo($"Loaded '{q.Name}'");
    }

    private void OpenSaveQuery()
    {
        saveName = string.Empty;
        saveDescription = string.Empty;
        saveShared = false;
        saveQueryOpen = true;
        saveResultOpen = false;
    }

    private async Task SaveQuery()
    {
        if (string.IsNullOrWhiteSpace(saveName)) { _toastService.ShowWarning("Enter a name"); return; }
        if (string.IsNullOrWhiteSpace(sql)) { _toastService.ShowWarning("Nothing to save"); return; }
        try
        {
            isSaving = true;
            var request = new SaveSavedQueryRequest { Name = saveName.Trim(), Description = saveDescription?.Trim(), QueryText = sql, IsShared = saveShared };
            var response = await _httpClient.PostAsJsonAsync($"api/datasets/{selectedDatasetId}/queries", request);
            if (response.IsSuccessStatusCode)
            {
                _toastService.ShowSuccess("Query saved");
                saveQueryOpen = false;
                await LoadSavedQueries();
            }
            else
            {
                _toastService.ShowError($"Failed to save: {await response.Content.ReadAsStringAsync()}");
            }
        }
        catch (Exception ex) { _toastService.ShowError($"Error saving query: {ex.Message}"); }
        finally { isSaving = false; }
    }

    private async Task DeleteSavedQuery(SavedQueryDto q)
    {
        try
        {
            var response = await _httpClient.DeleteAsync($"api/datasets/{selectedDatasetId}/queries/{q.Id}");
            if (response.IsSuccessStatusCode) { _toastService.ShowSuccess("Query deleted"); await LoadSavedQueries(); }
            else _toastService.ShowError($"Failed to delete: {response.StatusCode}");
        }
        catch (Exception ex) { _toastService.ShowError($"Error deleting query: {ex.Message}"); }
    }

    private void OpenSaveResult()
    {
        saveResultName = string.Empty;
        saveResultAsView = "false";
        saveResultOpen = true;
        saveQueryOpen = false;
    }

    private async Task SaveResult()
    {
        if (string.IsNullOrWhiteSpace(saveResultName)) { _toastService.ShowWarning("Enter an object name"); return; }
        try
        {
            isSaving = true;
            var request = new SaveResultRequest { Sql = sql, ObjectName = saveResultName.Trim(), AsView = saveResultAsView == "true" };
            var response = await _httpClient.PostAsJsonAsync($"api/datasets/{selectedDatasetId}/query/save-result", request);
            if (response.IsSuccessStatusCode)
            {
                var r = await response.Content.ReadFromJsonAsync<SqlQueryResult>();
                if (r?.Error is { Length: > 0 } e) { _toastService.ShowError(e); }
                else
                {
                    _toastService.ShowSuccess($"Saved as {(saveResultAsView == "true" ? "view" : "table")} '{saveResultName}'");
                    saveResultOpen = false;
                    await OnDatasetSelected(); // refresh the tables list
                }
            }
            else
            {
                _toastService.ShowError($"Failed: {await response.Content.ReadAsStringAsync()}");
            }
        }
        catch (Exception ex) { _toastService.ShowError($"Error saving result: {ex.Message}"); }
        finally { isSaving = false; }
    }

    private void ToggleY(string col, bool on)
    {
        if (on) { if (!chartY.Contains(col)) chartY.Add(col); }
        else chartY.Remove(col);
    }
}
