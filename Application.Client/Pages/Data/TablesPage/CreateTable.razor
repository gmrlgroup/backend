@page "/data/tables/{Action}"
@using Application.Shared.Models.Data
@inject HttpClient _httpClient
@inject IToastService _toastService
@inject NavigationManager _navigationManager
@inject AuthenticationStateProvider _authenticationStateProvider
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@attribute [Authorize(Policy = PolicyNames.DatasetsAccess)]

<PageTitle>@(Action == "edit" ? "Edit Table" : "Create Table")</PageTitle>

@if (!canEdit)
{
    <div class="flex flex-col items-center justify-center h-64 text-gray-500 gap-2">
        <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p class="text-sm font-semibold text-gray-700">Access Denied</p>
        <p class="text-xs text-gray-400">You don't have permission to create or edit tables.</p>
    </div>
}
else
{
<div class="ds-page">
    <div>
        <nav class="ds-breadcrumb">
            <a href="@($"/data/datasets?c={companyId}")">Datasets</a>
            <span class="ds-breadcrumb-sep">/</span>
            @if (Dataset is not null)
            {
                <a href="@($"/data/tables?c={companyId}&d={datasetId}")">@Dataset.Name</a>
                <span class="ds-breadcrumb-sep">/</span>
            }
            <span>@(Action == "edit" ? "Edit Table" : "New Table")</span>
        </nav>
        <h1 class="ds-title">
            @if (Action == "edit") { <span>Edit Table</span> }
            else if (Dataset is not null) { <span>New Table in <span style="color:#6366f1">@Dataset.Name</span></span> }
            else { <span>New Table</span> }
        </h1>
        <p class="ds-subtitle">Define your table structure with columns and data types</p>
    </div>

    <div class="ds-form-card" style="max-width:900px">
        <EditForm Model="@tableModel" OnValidSubmit="@HandleSubmit">
            <DataAnnotationsValidator />

            <!-- Table Info -->
            <p class="ds-section-title">Table Information</p>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem">
                <div class="ds-field" style="margin-bottom:0">
                    <label class="ds-label">Schema Name</label>
                    <InputText class="ds-input" @bind-Value="tableModel.SchemaName" placeholder="e.g., main" />
                    <ValidationMessage For="@(() => tableModel.SchemaName)" class="ds-error" />
                </div>
                <div class="ds-field" style="margin-bottom:0">
                    <label class="ds-label">Table Name</label>
                    <InputText class="ds-input" @bind-Value="tableModel.TableName" placeholder="e.g., customers" />
                    <ValidationMessage For="@(() => tableModel.TableName)" class="ds-error" />
                </div>
            </div>

            <!-- Columns -->
            <div style="border-top:1px solid #f4f4f5;padding-top:1.5rem;margin-top:0.25rem">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem">
                    <p class="ds-section-title" style="margin:0">
                        Columns
                        <span style="font-size:0.8125rem;font-weight:400;color:#71717a;margin-left:0.375rem">(@tableModel.Columns.Count)</span>
                    </p>
                    <button type="button" class="btn btn-outline" @onclick="AddColumn">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                        Add Column
                    </button>
                </div>

                @if (tableModel.Columns.Any())
                {
                    <div class="ds-card" style="overflow:hidden">
                        <div class="ds-col-grid-header">
                            <span>Column Name</span>
                            <span>Data Type</span>
                            <span style="text-align:center">Nullable</span>
                            <span>Default Value</span>
                            <span></span>
                        </div>
                        @for (int i = 0; i < tableModel.Columns.Count; i++)
                        {
                            var index = i;
                            <div class="ds-col-grid-row">
                                <InputText class="ds-input" @bind-Value="tableModel.Columns[index].Name" placeholder="column_name" />
                                <select class="ds-select" @bind="tableModel.Columns[index].DataType">
                                    @foreach (var dt in Column.CommonDataTypes)
                                    {
                                        <option value="@dt">@dt</option>
                                    }
                                </select>
                                <div class="ds-checkbox-wrap">
                                    <input type="checkbox" class="ds-checkbox" @bind="tableModel.Columns[index].IsNullable" />
                                </div>
                                <InputText class="ds-input" @bind-Value="tableModel.Columns[index].DefaultValue" placeholder="optional" />
                                <button type="button" class="btn-icon btn-icon-delete" title="Remove column" @onclick="() => RemoveColumn(index)">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                                </button>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="ds-columns-empty">
                        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color:#d4d4d8"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M3 15h18"/><path d="M9 3v18"/></svg>
                        <p style="font-size:0.9375rem;font-weight:600;color:#18181b;margin:0">No columns yet</p>
                        <p style="font-size:0.875rem;color:#71717a;margin:0">Add columns to define your table structure</p>
                        <button type="button" class="btn btn-default" @onclick="AddColumn">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                            Add First Column
                        </button>
                    </div>
                }
            </div>

            <!-- Actions -->
            <div class="ds-form-actions" style="justify-content:flex-end">
                <button type="button" class="btn btn-outline" @onclick="GoBack" disabled="@isSubmitting">Cancel</button>
                <button type="submit" class="btn btn-default" disabled="@(!tableModel.Columns.Any() || isSubmitting)">
                    @if (isSubmitting)
                    {
                        <span class="ds-spinner" style="width:14px;height:14px;border-width:1.5px"></span>
                        <span>@(Action == "edit" ? "Saving..." : "Creating...")</span>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 3v18"/></svg>
                        <span>@(Action == "edit" ? "Save Changes" : "Create Table")</span>
                    }
                </button>
            </div>
        </EditForm>
    </div>
</div>
}

@code {
    [Parameter] public string Action { get; set; } = string.Empty;
    private Table tableModel = new Table();
    private bool isSubmitting = false;
    private bool canEdit;
    private string? companyId;
    private string? datasetId;

    [SupplyParameterFromQuery] public string? c { get; set; }
    [SupplyParameterFromQuery] public string? d { get; set; }
    [SupplyParameterFromQuery] public string? t { get; set; }

    public Dataset? Dataset { get; set; }
    public List<Column> Columns { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        companyId = c;
        datasetId = d;

        _httpClient.DefaultRequestHeaders.Remove("CompanyId");
        if (!string.IsNullOrEmpty(companyId))
            _httpClient.DefaultRequestHeaders.Add("CompanyId", companyId);

        if (string.IsNullOrEmpty(companyId)) { _toastService.ShowWarning("Company ID is required"); GoBack(); return; }
        if (string.IsNullOrEmpty(datasetId)) { _toastService.ShowWarning("Dataset ID is required"); GoBack(); return; }

        var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
        canEdit = authState.User.HasCompanyRole(companyId, "EDIT_DATA");
        if (!canEdit) return;

        Dataset = await _httpClient.GetFromJsonAsync<Dataset>($"api/datasets/{datasetId}");

        if (Action == "edit")
            tableModel = await _httpClient.GetFromJsonAsync<Table>($"api/datasets/{datasetId}/tables/{t}") ?? new Table();

        tableModel.CompanyId = companyId;
        tableModel.DatasetId = datasetId;

        if (Action != "edit")
            AddColumn();
    }

    private void AddColumn() { tableModel.Columns.Add(new Column()); StateHasChanged(); }

    private void RemoveColumn(int index)
    {
        if (tableModel.Columns.Count > index)
        {
            tableModel.Columns.RemoveAt(index);
            StateHasChanged();
        }
    }

    private async Task HandleSubmit()
    {
        if (!tableModel.Columns.Any()) { _toastService.ShowWarning("Please add at least one column"); return; }
        if (tableModel.Columns.Any(col => string.IsNullOrWhiteSpace(col.Name))) { _toastService.ShowWarning("All columns must have a name"); return; }

        var duplicates = tableModel.Columns.GroupBy(col => col.Name.ToLower()).Where(g => g.Count() > 1).Select(g => g.Key);
        if (duplicates.Any()) { _toastService.ShowWarning($"Duplicate column names: {string.Join(", ", duplicates)}"); return; }

        try
        {
            isSubmitting = true;
            StateHasChanged();

            var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (!string.IsNullOrEmpty(userId))
                {
                    _httpClient.DefaultRequestHeaders.Remove("UserId");
                    _httpClient.DefaultRequestHeaders.Add("UserId", userId);
                    tableModel.CreatedBy = userId;
                }
            }

            var response = await _httpClient.PostAsJsonAsync("api/Datasets/tables", tableModel);
            if (response.IsSuccessStatusCode)
            {
                _toastService.ShowSuccess($"Table '{tableModel.SchemaName}.{tableModel.TableName}' created successfully");
                GoBack();
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                _toastService.ShowError($"Failed to create table: {errorContent}");
            }
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Error creating table: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private void GoBack() => _navigationManager.NavigateTo($"/data/tables?c={companyId}&d={datasetId}");
}
