@page "/data/tables"
@using Application.Shared.Models
@using Application.Shared.Models.Data
@using Application.Shared.Models.Dashboards
@using System.Net.Http.Json
@inject HttpClient _httpClient
@inject IToastService _toastService
@inject NavigationManager _navigationManager
@inject AuthenticationStateProvider _authenticationStateProvider
@inject IJSRuntime _jsRuntime
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@attribute [Authorize(Policy = PolicyNames.DatasetsAccess)]

<PageTitle>Tables</PageTitle>

@if (!canView && !isLoading)
{
    <div class="flex flex-col items-center justify-center h-64 text-gray-500 gap-2">
        <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p class="text-sm font-semibold text-gray-700">Access Denied</p>
        <p class="text-xs text-gray-400">You don't have permission to view tables.</p>
    </div>
}
else
{
<div class="ds-page">
    <div class="ds-header">
        <div style="display:flex;align-items:center;gap:0.75rem">
            <button class="btn-icon" title="Back to Datasets" @onclick="GoBack">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            </button>
            <div>
                <h1 class="ds-title">
                    @if (!string.IsNullOrEmpty(datasetName)) { @datasetName<span style="font-weight:400;color:#71717a"> / Tables</span> }
                    else { <span>Tables</span> }
                </h1>
                <p class="ds-subtitle">
                    @if (!isLoading) { <span>@(tables?.Count ?? 0) table@(tables?.Count == 1 ? "" : "s")</span> }
                </p>
            </div>
        </div>
        @if (canEdit)
        {
        <div style="display:flex;align-items:center;gap:0.5rem">
            @if (!dbExists && !isLoading)
            {
                <button class="btn btn-outline" style="color:#b45309;border-color:#fcd34d" @onclick="CreateDatabase" disabled="@isCreatingDb"
                        title="This dataset has no database file on disk yet. Create it so ingestion and tables can run.">
                    @if (isCreatingDb)
                    {
                        <span class="ds-spinner" style="width:14px;height:14px;border-width:1.5px"></span>
                        <span>Creating…</span>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3"/></svg>
                        <span>Create Database</span>
                    }
                </button>
            }
            <button class="btn btn-default" @onclick="CreateTable">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                New Table
            </button>
        </div>
        }
    </div>

    <div class="ds-card">
        <div class="ds-card-toolbar">
            <div class="ds-search-wrap">
                <svg class="ds-search-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                <input class="ds-search" type="search" placeholder="Search tables..." @bind="searchTerm" @bind:event="oninput" @bind:after="HandleSearch" />
            </div>
        </div>

        @if (isLoading)
        {
            <div class="ds-loading">
                <div class="ds-spinner"></div>
                <span>Loading tables...</span>
            </div>
        }
        else if (pagedItems?.Any() == true)
        {
            <div class="ds-table-wrap">
                <table class="ds-table">
                    <thead>
                        <tr>
                            <th class="ds-th ds-th-sortable" @onclick="ToggleSort">
                                <span>Table Name</span>
                                @if (sortAsc)
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
                                }
                                else
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                                }
                            </th>
                            <th class="ds-th ds-th-actions">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tableName in pagedItems)
                        {
                            <tr class="ds-tr">
                                <td class="ds-td ds-td-name">
                                    <div style="display:flex;align-items:center;gap:0.5rem">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:#71717a;flex-shrink:0"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M3 15h18"/><path d="M9 3v18"/></svg>
                                        <span class="ds-dataset-name">@tableName</span>
                                    </div>
                                </td>
                                <td class="ds-td ds-td-actions-cell">
                                    <div class="ds-actions">
                                        <button class="btn-icon btn-icon-open" title="View / edit table data" @onclick="() => ViewTable(tableName)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M3 15h18"/><path d="M9 3v18"/></svg>
                                        </button>
                                        <button class="btn-icon" title="Query this table" @onclick="() => QueryTable(tableName)" style="color:#71717a">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3"/></svg>
                                        </button>
                                        <button class="btn-icon" title="API docs" @onclick="() => OpenApiDocs(tableName)" style="color:#71717a">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                                        </button>
                                        <button class="btn-icon" title="Download CSV" @onclick="() => DownloadTable(tableName)" style="color:#71717a">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                                        </button>
                                        @if (canEdit)
                                        {
                                        <button class="btn-icon btn-icon-share" title="Share this table" @onclick="() => OpenShareTable(tableName)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/></svg>
                                        </button>
                                        }
                                        @if (canEdit)
                                        {
                                        <button class="btn-icon" title="Connect this table to a dashboard" @onclick="() => OpenConnect(tableName)" style="color:#7c3aed">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                                        </button>
                                        }
                                        <button class="btn-icon btn-icon-edit" title="Edit table structure" @onclick="() => EditTable(tableName)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                                        </button>
                                        <button class="btn-icon btn-icon-delete" title="Delete table" @onclick="() => DeleteTable(tableName)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (totalPages > 1)
            {
                <div class="ds-pagination">
                    <span>Page @(currentPage + 1) of @totalPages</span>
                    <div class="ds-page-btns">
                        <button class="btn-page" disabled="@(currentPage == 0)" @onclick="PrevPage">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                        </button>
                        @for (int i = 0; i < totalPages; i++)
                        {
                            var pageIndex = i;
                            <button class="btn-page @(currentPage == pageIndex ? "btn-page-active" : "")" @onclick="() => GoToPage(pageIndex)">@(i + 1)</button>
                        }
                        <button class="btn-page" disabled="@(currentPage >= totalPages - 1)" @onclick="NextPage">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                        </button>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="ds-empty">
                <div class="ds-empty-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M3 15h18"/><path d="M9 3v18"/></svg>
                </div>
                <h3 class="ds-empty-title">No tables found</h3>
                <p class="ds-empty-sub">
                    @if (!string.IsNullOrWhiteSpace(searchTerm))
                    {
                        <span>No tables match "<strong>@searchTerm</strong>". Try a different search.</span>
                    }
                    else if (string.IsNullOrEmpty(companyId) || string.IsNullOrEmpty(datasetId))
                    {
                        <span>Company ID and Dataset ID are required to load tables.</span>
                    }
                    else
                    {
                        <span>Get started by creating your first table in this dataset.</span>
                    }
                </p>
                @if (canEdit && !string.IsNullOrEmpty(companyId) && !string.IsNullOrEmpty(datasetId) && string.IsNullOrWhiteSpace(searchTerm))
                {
                    <button class="btn btn-default" @onclick="CreateTable">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                        Create Table
                    </button>
                }
            </div>
        }
    </div>
</div>
}

<ApiDocsDialog IsVisible="@showApiDocs"
               IsVisibleChanged="@((bool v) => showApiDocs = v)"
               CompanyId="@companyId"
               DatasetId="@datasetId"
               DatasetName="@datasetName"
               TableName="@apiDocsTable" />

@if (showShareTable)
{
    <div class="ds-modal-backdrop" @onclick="() => showShareTable = false">
        <div class="ds-modal" @onclick:stopPropagation="true">
            <div class="ds-modal-header">
                <h2 class="ds-modal-title">
                    Share Table <span style="color:#71717a;font-weight:400">— @shareTableName</span>
                </h2>
                <button class="ds-modal-close" @onclick="() => showShareTable = false" aria-label="Close">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                </button>
            </div>
            <div class="ds-modal-body">
                <div class="ds-field">
                    <label class="ds-label">Email Address</label>
                    <input class="ds-input" @bind="shareTableEmail" placeholder="Enter user email address" />
                </div>
                <div class="ds-field" style="margin-bottom:0">
                    <label class="ds-label">Access Level</label>
                    <select class="ds-select" @bind="shareTableType">
                        <option value="Viewer">Viewer — Can view and query data</option>
                        <option value="Editor">Editor — Can modify dataset structure</option>
                        <option value="Admin">Admin — Full access including sharing</option>
                    </select>
                    <span class="ds-hint">Grants access to this table only. Users who already have full dataset access are unaffected.</span>
                </div>
                <div class="ds-modal-footer">
                    <button type="button" class="btn btn-default" style="flex:1" @onclick="ShareTableSubmit" disabled="@isSharingTable">
                        @if (isSharingTable) { <span class="ds-spinner" style="width:14px;height:14px;border-width:1.5px"></span><span>Sharing...</span> }
                        else { <span>Share Table</span> }
                    </button>
                    <button type="button" class="btn btn-outline" style="flex:1" @onclick="() => showShareTable = false">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showConnectModal)
{
    <div class="ds-modal-backdrop" @onclick="() => showConnectModal = false">
        <div class="ds-modal" @onclick:stopPropagation="true">
            <div class="ds-modal-header">
                <h2 class="ds-modal-title">Connect to Dashboard <span style="color:#71717a;font-weight:400">— @connectTableName</span></h2>
                <button class="ds-modal-close" @onclick="() => showConnectModal = false" aria-label="Close">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                </button>
            </div>
            <div class="ds-modal-body">
                @if (isLoadingLinks)
                {
                    <div class="ds-loading"><div class="ds-spinner"></div><span>Loading…</span></div>
                }
                else if (!availableDashboards.Any())
                {
                    <span class="ds-dataset-desc">No dashboards available to connect.</span>
                }
                else
                {
                    <p class="ds-hint" style="margin-top:0">Choose which dashboards open this table for their item-level details. Each dashboard links to one table — connecting reassigns it.</p>
                    @foreach (var dash in availableDashboards)
                    {
                        var connected = connectedPageUrls.Contains(dash.PageUrl);
                        <div style="display:flex;align-items:center;justify-content:space-between;gap:0.75rem;padding:0.65rem 0;border-top:1px solid #f4f4f5">
                            <div>
                                <div style="font-weight:500;color:#18181b">@dash.Label @if (connected) { <span style="color:#15803d;font-size:0.75rem;font-weight:600">· connected</span> }</div>
                                <div style="font-size:0.75rem;color:#a1a1aa;font-family:ui-monospace,Consolas,monospace">@dash.PageUrl</div>
                            </div>
                            @if (connected)
                            {
                                <button class="btn btn-outline" style="color:#b91c1c;border-color:#fecaca" @onclick="() => DisconnectDashboard(dash.PageUrl)" disabled="@isSavingLink">Disconnect</button>
                            }
                            else
                            {
                                <button class="btn btn-default" @onclick="() => ConnectDashboard(dash.PageUrl)" disabled="@isSavingLink">Connect</button>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery] public string? c { get; set; }
    [SupplyParameterFromQuery] public string? d { get; set; }

    private bool showConnectModal = false;
    private string connectTableName = string.Empty;
    private List<DashboardPageInfo> availableDashboards = new();
    private HashSet<string> connectedPageUrls = new();
    private bool isLoadingLinks = false;
    private bool isSavingLink = false;

    private async Task OpenConnect(string tableName)
    {
        connectTableName = tableName;
        connectedPageUrls = new();
        showConnectModal = true;
        isLoadingLinks = true;
        StateHasChanged();
        try
        {
            await SetUserHeaderAsync();
            if (availableDashboards.Count == 0)
                availableDashboards = await _httpClient.GetFromJsonAsync<List<DashboardPageInfo>>("api/dashboard-links/dashboards") ?? new();

            var links = await _httpClient.GetFromJsonAsync<List<DashboardDataLink>>(
                $"api/dashboard-links?datasetId={Uri.EscapeDataString(datasetId!)}&tableName={Uri.EscapeDataString(tableName)}") ?? new();
            connectedPageUrls = links.Select(l => l.PageUrl).ToHashSet();
        }
        catch (Exception ex) { _toastService.ShowError($"Error loading dashboards: {ex.Message}"); }
        finally { isLoadingLinks = false; StateHasChanged(); }
    }

    private async Task ConnectDashboard(string pageUrl)
    {
        try
        {
            isSavingLink = true;
            StateHasChanged();
            await SetUserHeaderAsync();
            var req = new DashboardLinkRequest { PageUrl = pageUrl, DatasetId = datasetId!, TableName = connectTableName };
            var resp = await _httpClient.PostAsJsonAsync("api/dashboard-links", req);
            if (resp.IsSuccessStatusCode)
            {
                connectedPageUrls.Add(pageUrl);
                _toastService.ShowSuccess("Table connected to dashboard.");
            }
            else
            {
                _toastService.ShowError($"Failed to connect: {await resp.Content.ReadAsStringAsync()}");
            }
        }
        catch (Exception ex) { _toastService.ShowError($"Error: {ex.Message}"); }
        finally { isSavingLink = false; StateHasChanged(); }
    }

    private async Task DisconnectDashboard(string pageUrl)
    {
        try
        {
            isSavingLink = true;
            StateHasChanged();
            await SetUserHeaderAsync();
            var resp = await _httpClient.DeleteAsync($"api/dashboard-links?pageUrl={Uri.EscapeDataString(pageUrl)}");
            if (resp.IsSuccessStatusCode || resp.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                connectedPageUrls.Remove(pageUrl);
                _toastService.ShowSuccess("Disconnected.");
            }
            else
            {
                _toastService.ShowError($"Failed to disconnect: {await resp.Content.ReadAsStringAsync()}");
            }
        }
        catch (Exception ex) { _toastService.ShowError($"Error: {ex.Message}"); }
        finally { isSavingLink = false; StateHasChanged(); }
    }

    private bool showApiDocs = false;
    private string? apiDocsTable;

    // Per-table share dialog
    private bool showShareTable = false;
    private string shareTableName = string.Empty;
    private string shareTableEmail = string.Empty;
    private string shareTableType = "Viewer";
    private bool isSharingTable = false;

    private void OpenShareTable(string tableName)
    {
        shareTableName = tableName;
        shareTableEmail = string.Empty;
        shareTableType = "Viewer";
        showShareTable = true;
    }

    private async Task ShareTableSubmit()
    {
        if (string.IsNullOrWhiteSpace(shareTableEmail))
        {
            _toastService.ShowWarning("Enter an email address");
            return;
        }
        try
        {
            isSharingTable = true;
            StateHasChanged();

            var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (!string.IsNullOrEmpty(userId))
                {
                    _httpClient.DefaultRequestHeaders.Remove("UserId");
                    _httpClient.DefaultRequestHeaders.Add("UserId", userId);
                }
            }

            var request = new GrantTableShareRequest
            {
                Email = shareTableEmail.Trim(),
                DatasetId = datasetId!,
                TableName = shareTableName,
                UserType = shareTableType switch
                {
                    "Admin" => DatasetUserType.Admin,
                    "Editor" => DatasetUserType.Editor,
                    _ => DatasetUserType.Viewer
                }
            };

            var response = await _httpClient.PostAsJsonAsync($"api/datasets/{datasetId}/sharing/grant-table", request);
            if (response.IsSuccessStatusCode)
            {
                _toastService.ShowSuccess($"Table '{shareTableName}' shared with {shareTableEmail}");
                showShareTable = false;
            }
            else
            {
                _toastService.ShowError($"Failed to share table: {await response.Content.ReadAsStringAsync()}");
            }
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Error sharing table: {ex.Message}");
        }
        finally
        {
            isSharingTable = false;
            StateHasChanged();
        }
    }

    private void OpenApiDocs(string tableName)
    {
        apiDocsTable = tableName;
        showApiDocs = true;
    }

    private bool canView;
    private bool canEdit;
    private List<string>? tables;
    private List<string>? filteredItems;
    private IEnumerable<string>? pagedItems;
    private string searchTerm = string.Empty;
    private bool sortAsc = true;
    private int currentPage = 0;
    private const int pageSize = 10;
    private int totalPages => (int)Math.Ceiling((filteredItems?.Count ?? 0) / (double)pageSize);
    private bool isLoading = true;
    private string? companyId;
    private string? datasetId;
    private string? datasetName;
    private bool dbExists = true;       // assume present until checked, so the button doesn't flash
    private bool isCreatingDb = false;

    protected override async Task OnInitializedAsync()
    {
        companyId = c;
        datasetId = d;

        if (string.IsNullOrEmpty(companyId))
        {
            _toastService.ShowWarning("Company ID is required to view tables");
            isLoading = false;
            return;
        }
        if (string.IsNullOrEmpty(datasetId))
        {
            _toastService.ShowWarning("Dataset ID is required to view tables");
            isLoading = false;
            return;
        }
        var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        canView = user.HasCompanyRole(companyId, "VIEW_DATA");
        canEdit = user.HasCompanyRole(companyId, "EDIT_DATA");
        if (!canView) { isLoading = false; return; }
        await CheckDatabaseAsync();
        await LoadTables();
    }

    private async Task SetUserHeaderAsync()
    {
        var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(userId))
            {
                _httpClient.DefaultRequestHeaders.Remove("UserId");
                _httpClient.DefaultRequestHeaders.Add("UserId", userId);
            }
        }
    }

    private async Task CheckDatabaseAsync()
    {
        try
        {
            await SetUserHeaderAsync();
            var resp = await _httpClient.GetAsync($"api/Datasets/{datasetId}/database-exists");
            if (resp.IsSuccessStatusCode)
                dbExists = await resp.Content.ReadFromJsonAsync<bool>();
        }
        catch { /* on error, leave dbExists as-is (assume present) */ }
    }

    private async Task CreateDatabase()
    {
        try
        {
            isCreatingDb = true;
            StateHasChanged();

            await SetUserHeaderAsync();
            var resp = await _httpClient.PostAsync($"api/Datasets/{datasetId}/database", null);
            if (resp.IsSuccessStatusCode)
            {
                dbExists = true;
                _toastService.ShowSuccess("Dataset database created.");
                await LoadTables();
            }
            else
            {
                _toastService.ShowError($"Failed to create database: {await resp.Content.ReadAsStringAsync()}");
            }
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Error creating database: {ex.Message}");
        }
        finally
        {
            isCreatingDb = false;
            StateHasChanged();
        }
    }

    private async Task LoadTables()
    {
        try
        {
            isLoading = true;
            StateHasChanged();

            var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (!string.IsNullOrEmpty(userId))
                {
                    _httpClient.DefaultRequestHeaders.Remove("UserId");
                    _httpClient.DefaultRequestHeaders.Add("UserId", userId);
                }
            }

            var datasetResponse = await _httpClient.GetAsync($"api/Datasets/{datasetId}");
            if (datasetResponse.IsSuccessStatusCode)
            {
                var dataset = await datasetResponse.Content.ReadFromJsonAsync<Dataset>();
                datasetName = dataset?.Name;
            }

            var response = await _httpClient.GetAsync($"api/Datasets/{datasetId}/tables");
            if (response.IsSuccessStatusCode)
            {
                tables = await response.Content.ReadFromJsonAsync<List<string>>();
                ApplyFilterAndSort();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                // No tables yet (e.g. empty or not-yet-created database) — show the empty state, not an error.
                tables = [];
                ApplyFilterAndSort();
            }
            else
            {
                _toastService.ShowError($"Failed to load tables: {response.StatusCode}");
                tables = [];
                filteredItems = [];
                pagedItems = [];
            }
        }
        catch (Exception ex)
        {
            _toastService.ShowError($"Error loading tables: {ex.Message}");
            tables = [];
            filteredItems = [];
            pagedItems = [];
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void HandleSearch()
    {
        currentPage = 0;
        ApplyFilterAndSort();
    }

    private void ToggleSort()
    {
        sortAsc = !sortAsc;
        ApplyFilterAndSort();
    }

    private void ApplyFilterAndSort()
    {
        var query = tables?.AsEnumerable() ?? [];
        if (!string.IsNullOrWhiteSpace(searchTerm))
            query = query.Where(t => t.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
        query = sortAsc ? query.OrderBy(t => t) : query.OrderByDescending(t => t);
        filteredItems = query.ToList();
        pagedItems = filteredItems.Skip(currentPage * pageSize).Take(pageSize);
        StateHasChanged();
    }

    private void PrevPage() { if (currentPage > 0) { currentPage--; ApplyFilterAndSort(); } }
    private void NextPage() { if (currentPage < totalPages - 1) { currentPage++; ApplyFilterAndSort(); } }
    private void GoToPage(int page) { currentPage = page; ApplyFilterAndSort(); }

