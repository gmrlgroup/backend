@page "/data/view"
@page "/data/edit"
@using Application.Shared.Models.Data
@using Application.Shared.Models
@using Application.Shared.Enums
@using Microsoft.FluentUI.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@inject HttpClient HttpClient
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JSRuntime
@inject IToastService ToastService
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@attribute [Authorize(Policy = PolicyNames.DatasetsAccess)]
@implements IAsyncDisposable

<PageTitle>Data Viewer - @(TableInfo?.TableName ?? "Loading...")</PageTitle>

@if (!canView)
{
    <div class="flex flex-col items-center justify-center h-64 text-gray-500 gap-2">
        <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p class="text-sm font-semibold text-gray-700">Access Denied</p>
        <p class="text-xs text-gray-400">You don't have permission to view data.</p>
    </div>
}
else
{
<div style="height:88vh;display:flex;flex-direction:column;background:#fafafa">
    <!-- Header -->
    <div style="background:#fff;border-bottom:1px solid #e4e4e7;padding:0.75rem 1.25rem;flex-shrink:0;display:flex;align-items:center;justify-content:space-between;gap:1rem">
        <div style="display:flex;align-items:center;gap:0.75rem">
            <button class="btn-icon" @onclick="GoBack" title="Back">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            </button>
            <div>
                <h1 style="margin:0;font-size:1.0625rem;font-weight:600;color:#18181b">
                    @(TableInfo?.TableName ?? "Loading…")
                </h1>
                <p style="margin:0;font-size:0.8125rem;color:#71717a">
                    @if (DatasetInfo != null && TableInfo != null)
                    {
                        <span>@DatasetInfo.Name · @TotalRows rows</span>
                        @if (hasChanges) { <span style="color:#b45309;font-weight:600"> · unsaved changes</span> }
                    }
                    else { <span>Loading table information…</span> }
                </p>
            </div>
        </div>
        <div style="display:flex;align-items:center;gap:0.5rem">
            @if (AllowEdit)
            {
                <button class="btn btn-outline" @onclick="AddRow" disabled="@(IsLoading || isSaving)" title="Add a new row">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                    Add Row
                </button>
                <button class="btn btn-outline" style="color:#dc2626;border-color:#fecaca" @onclick="DeleteSelected" disabled="@(IsLoading || isSaving)" title="Delete selected rows">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                    Delete
                </button>
                <button class="btn btn-default" @onclick="SaveChanges" disabled="@(IsLoading || isSaving || !hasChanges)">
                    @if (isSaving) { <span class="ds-spinner" style="width:14px;height:14px;border-width:1.5px"></span><span>Saving…</span> }
                    else { <span>Save</span> }
                </button>
                <span style="width:1px;height:22px;background:#e4e4e7;margin:0 0.25rem"></span>
            }
            <button class="btn btn-outline" style="color:#16a34a;border-color:#16a34a" @onclick="DownloadCsv" disabled="@IsLoading" title="Export the current view to CSV">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                Download
            </button>
            <button class="btn btn-outline" @onclick="RefreshData" disabled="@IsLoading">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/></svg>
                Refresh
            </button>
            <button class="btn btn-outline" @onclick="GoToQuery" title="Open in the SQL query workbench" disabled="@IsLoading">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3"/></svg>
                Query
            </button>
            <button class="btn btn-outline" @onclick="@(() => ShowApiDocs = true)" title="How to fetch this data via the API">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                API
            </button>
            <button class="btn btn-outline" @onclick="@(() => ShowCommentsPanel = !ShowCommentsPanel)" disabled="@IsLoading">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                Comments
                @if (CommentsCount > 0) { <span class="dv-badge">@CommentsCount</span> }
            </button>
        </div>
    </div>

    @if (truncated)
    {
        <div style="background:#fffbeb;border-bottom:1px solid #fde68a;color:#92400e;padding:0.5rem 1.25rem;font-size:0.8125rem;flex-shrink:0">
            Showing the first @LoadedRows of @TotalRows rows. @(AllowEdit ? "Edits apply to the loaded rows — use the SQL workbench or a re-import for bulk changes." : "Use filters or the SQL workbench to reach the rest.")
        </div>
    }

    <!-- Body -->
    <div style="flex:1;display:flex;overflow:hidden">
        <!-- Table area -->
        <div style="flex:1;padding:1rem;overflow:hidden;display:flex;flex-direction:column">
            @if (IsLoading)
            {
                <div style="flex:1;display:flex;align-items:center;justify-content:center;background:#fff;border-radius:0.5rem;border:1px solid #e4e4e7">
                    <div style="text-align:center">
                        <div class="ds-spinner" style="width:32px;height:32px;border-width:2.5px;margin:0 auto 0.75rem"></div>
                        <p style="font-size:0.875rem;color:#71717a;margin:0">Loading table data…</p>
                    </div>
                </div>
            }
            else if (TableColumns?.Any() == true)
            {
                <div id="@GridId" class="ag-theme-quartz" style="flex:1;width:100%"></div>
                @if (AllowEdit)
                {
                    <p style="font-size:0.75rem;color:#a1a1aa;margin:0.5rem 0 0 0">
                        Click a cell to edit · Enter / Tab to move · Ctrl+Z to undo · select rows with the checkboxes to delete · filter from the header row.
                    </p>
                }
            }
            else
            {
                <div style="flex:1;display:flex;align-items:center;justify-content:center;background:#fff;border-radius:0.5rem;border:1px solid #e4e4e7">
                    <div style="text-align:center">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="color:#d4d4d8;margin-bottom:0.75rem"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M3 15h18"/><path d="M9 3v18"/></svg>
                        <h3 style="font-size:0.9375rem;font-weight:600;color:#18181b;margin:0 0 0.25rem 0">No Data Available</h3>
                        <p style="font-size:0.875rem;color:#71717a;margin:0">This table appears to be empty or could not be loaded.</p>
                    </div>
                </div>
            }
        </div>

        <!-- Comments panel -->
        @if (ShowCommentsPanel)
        {
            <div class="dv-comments-panel">
                <CommentsSidebar CompanyId="@c"
                                DatasetId="@DatasetId"
                                CurrentUserId="@CurrentUserId"
                                TableName="@TableName"
                                OnCommentAdded="@OnCommentAdded"
                                OnCommentDeleted="@OnCommentDeleted" />
            </div>
        }
    </div>
</div>

<ApiDocsDialog IsVisible="@ShowApiDocs"
               IsVisibleChanged="@((bool v) => ShowApiDocs = v)"
               CompanyId="@c"
               DatasetId="@DatasetId"
               DatasetName="@(DatasetInfo?.Name)"
               TableName="@TableName" />
}

@code {
    [SupplyParameterFromQuery] public string? c { get; set; }
    [SupplyParameterFromQuery] public string? DatasetId { get; set; }
    [SupplyParameterFromQuery] public string? TableName { get; set; }

    private const string GridId = "data-view-grid";
    private const int rowCap = 5000;

    private bool ShowApiDocs = false;

    private Dataset? DatasetInfo;
    private Table? TableInfo;
    private List<Column>? TableColumns;
    private List<Dictionary<string, object>> TableData = new();

    private bool canView;
    private bool canEdit;
    // Editing is offered only to EDIT_DATA users on local DuckDB datasets; external sources are read-only.
    private bool AllowEdit => canEdit && DatasetInfo?.SourceType == DatasetSourceType.Local;
    private bool IsLoading = false;
    private bool isSaving;
    private bool hasChanges;
    private bool truncated;
    private bool ShowCommentsPanel = false;
    private int TotalRows = 0;
    private int LoadedRows => TableData.Count;
    private int CommentsCount = 0;
    private string CurrentUserId = string.Empty;

    private string? loadedKey;
    private bool gridInitialized;
    private DotNetObjectReference<ViewData>? dotNetRef;

    protected override async Task OnInitializedAsync()
    {
        EnsureCompanyHeader();

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        CurrentUserId = authState.User.Claims.FirstOrDefault(x => x.Type.EndsWith("nameidentifier"))?.Value ??
                        authState.User.Claims.FirstOrDefault(x => x.Type.EndsWith("id"))?.Value ?? string.Empty;
        EnsureUserIdHeader();

        var companyId = c ?? "";
        canView = authState.User.HasCompanyRole(companyId, "VIEW_DATA");
        canEdit = authState.User.HasCompanyRole(companyId, "EDIT_DATA");
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!canView || string.IsNullOrEmpty(DatasetId) || string.IsNullOrEmpty(TableName))
            return;

        var key = $"{DatasetId}|{TableName}";
        if (key == loadedKey) return;
        loadedKey = key;

        // Navigated to a different table on the same component instance — tear the grid down first.
        if (gridInitialized)
        {
            try { await JSRuntime.InvokeVoidAsync("dataGridEditor.dispose"); } catch { }
            gridInitialized = false;
        }

        await LoadInitialData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Build the grid once data is loaded and the container has rendered.
        if (!canView || IsLoading || TableColumns == null || !TableColumns.Any() || gridInitialized)
            return;
        gridInitialized = true;
        dotNetRef ??= DotNetObjectReference.Create(this);
        var colPayload = TableColumns.Select(col => new { name = col.Name, dataType = col.DataType }).ToList();
        await JSRuntime.InvokeVoidAsync("dataGridEditor.init", GridId, dotNetRef, colPayload, TableData, new { editable = AllowEdit });
    }

    private async Task LoadInitialData()
    {
        IsLoading = true;
        hasChanges = false;
        StateHasChanged();
        EnsureCompanyHeader();

        try
        {
            DatasetInfo = await HttpClient.GetFromJsonAsync<Dataset>($"api/Datasets/{DatasetId}");
            TableInfo = await HttpClient.GetFromJsonAsync<Table>($"api/Datasets/{DatasetId}/tables/{TableName}");
            TableColumns = TableInfo?.Columns;

            await LoadCommentsCount();
            await LoadRowsAsync(initial: true);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading initial data: {ex.Message}");
            ToastService.ShowError($"Failed to load table: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadCommentsCount()
    {
        try
        {
            var comments = await HttpClient.GetFromJsonAsync<List<DataTableComment>>($"api/DataViews/comments/{DatasetId}/{TableName}");
            CommentsCount = comments?.Count(x => x.DatasetId == DatasetId && x.TableName == TableName) ?? 0;
        }
        catch (Exception ex) { Console.WriteLine($"Error loading comments: {ex.Message}"); }
    }

    private async Task LoadRowsAsync(bool initial = false)
    {
        EnsureCompanyHeader();
        EnsureUserIdHeader();

        var query = new TableDataQuery
        {
            DatasetId = DatasetId!,
            TableName = TableName!,
            Page = 1,
            PageSize = rowCap,
            // Only fetch the rowid when the grid is editable — the viewer doesn't need it.
            IncludeRowId = AllowEdit
        };

        var response = await HttpClient.PostAsJsonAsync($"api/Datasets/{DatasetId}/tables/{TableName}/data", query);
        if (!response.IsSuccessStatusCode)
        {
            ToastService.ShowError($"Failed to load data: {response.StatusCode}");
            return;
        }

        var result = await response.Content.ReadFromJsonAsync<TableDataResult>();
        TableData = result?.Data ?? new();
        TotalRows = result?.TotalRows ?? TableData.Count;
        truncated = TotalRows > TableData.Count;

        // On reload (refresh/save/discard) push fresh rows straight into the live grid.
        if (!initial && gridInitialized)
            await JSRuntime.InvokeVoidAsync("dataGridEditor.setData", TableData);

        hasChanges = false;
    }

    [JSInvokable]
    public Task SetDirty(bool dirty)
    {
        if (hasChanges != dirty)
        {
            hasChanges = dirty;
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    private async Task AddRow() => await JSRuntime.InvokeVoidAsync("dataGridEditor.addRow");

    private async Task DeleteSelected()
    {
        var count = await JSRuntime.InvokeAsync<int>("dataGridEditor.deleteSelected");
        if (count == 0)
            ToastService.ShowInfo("Select one or more rows (using the checkboxes) to delete.");
    }

    private async Task SaveChanges()
    {
        var changes = await JSRuntime.InvokeAsync<BulkRowEditRequest>("dataGridEditor.getChanges");
        if (changes == null ||
            (changes.Updates.Count == 0 && changes.Inserts.Count == 0 && changes.Deletes.Count == 0))
        {
            ToastService.ShowInfo("No changes to save.");
            return;
        }

        isSaving = true;
        StateHasChanged();
        try
        {
            EnsureCompanyHeader();
            EnsureUserIdHeader();
            var response = await HttpClient.PostAsJsonAsync($"api/Datasets/{DatasetId}/tables/{TableName}/rows/bulk", changes);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<BulkRowEditResult>();
                if (result?.Success == true)
                {
                    ToastService.ShowSuccess($"Saved · {result.Inserted} added, {result.Updated} updated, {result.Deleted} deleted");
                    await LoadRowsAsync();
                }
                else
                {
                    ToastService.ShowError(result?.Error ?? "Changes could not be saved.");
                }
            }
            else
            {
                ToastService.ShowError($"Save failed: {await response.Content.ReadAsStringAsync()}");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error saving changes: {ex.Message}");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task RefreshData()
    {
        if (hasChanges && !await JSRuntime.InvokeAsync<bool>("confirm", "Refresh will discard unsaved changes. Continue?"))
            return;
        await LoadRowsAsync();
    }

    private async Task DownloadCsv()
    {
        var fileName = $"{TableName}_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
        await JSRuntime.InvokeVoidAsync("dataGridEditor.exportCsv", fileName);
    }

    private void EnsureCompanyHeader()
    {
        if (!HttpClient.DefaultRequestHeaders.Contains("X-Company-ID"))
            HttpClient.DefaultRequestHeaders.Add("X-Company-ID", c);
    }

    private void EnsureUserIdHeader()
    {
        if (string.IsNullOrEmpty(CurrentUserId)) return;
        HttpClient.DefaultRequestHeaders.Remove("UserId");
        HttpClient.DefaultRequestHeaders.Add("UserId", CurrentUserId);
    }

    private void GoBack() => NavigationManager.NavigateTo($"/data/tables?c={c}&d={DatasetId}");
    private void GoToQuery() => NavigationManager.NavigateTo($"/data/query?c={c}&DatasetId={DatasetId}&TableName={TableName}");
    private void OnCommentAdded(DataTableComment comment) { CommentsCount++; StateHasChanged(); }
    private void OnCommentDeleted(string commentId) { CommentsCount = Math.Max(0, CommentsCount - 1); StateHasChanged(); }

    public async ValueTask DisposeAsync()
    {
        try { await JSRuntime.InvokeVoidAsync("dataGridEditor.dispose"); } catch { /* circuit may already be gone */ }
        dotNetRef?.Dispose();
    }
}
