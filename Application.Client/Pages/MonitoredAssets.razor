@page "/status/entities"
@using Application.Shared.Models
@using Application.Shared.Enums
@using Application.Client.Services
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject MonitoredAssetClientService EntityService
@inject NavigationManager Navigation
@inject StateContainer StateContainer
@inject IJSRuntime JSRuntime
@attribute [Authorize]

<PageTitle>Status Entities</PageTitle>

<div class="min-h-screen bg-gray-50 p-6">
    <div class="mb-6 flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Entities</h1>
            <p class="mt-1 text-sm text-gray-500">Manage monitored systems and services</p>
        </div>
        <button @onclick="CreateEntity"
                class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700">
            + New Entity
        </button>
    </div>

    <!-- Filters -->
    <div class="bg-white rounded-lg border border-gray-200 p-4 mb-4 flex flex-wrap gap-3">
        <input @bind="searchFilter" @oninput="OnSearchChanged"
               class="flex-1 min-w-48 border border-gray-300 rounded-md text-sm px-3 py-2"
               placeholder="Search entities..." />
        <select @bind="typeFilter" @bind:after="ApplyFilters"
                class="border border-gray-300 rounded-md text-sm px-3 py-2">
            <option value="">All Types</option>
            @foreach (var t in Enum.GetValues<AssetType>())
            {
                <option value="@t">@t.ToString()</option>
            }
        </select>
        <select @bind="statusFilter" @bind:after="ApplyFilters"
                class="border border-gray-300 rounded-md text-sm px-3 py-2">
            <option value="">All Status</option>
            <option value="active">Active</option>
            <option value="inactive">Inactive</option>
        </select>
    </div>

    @if (isLoading)
    {
        <div class="flex justify-center items-center h-40">
            <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-indigo-600"></div>
        </div>
    }
    else
    {
        <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
            @if (filteredEntities.Any())
            {
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Group</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Owner</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Current Status</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Active</th>
                            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-100">
                        @foreach (var entity in filteredEntities)
                        {
                            var latestStatus = entity.StatusHistory?.OrderByDescending(s => s.CheckedAt).FirstOrDefault();
                            <tr class="hover:bg-gray-50 cursor-pointer" @onclick="() => ViewEntity(entity.Id)">
                                <td class="px-4 py-3">
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium @entity.GetEntityTypeClass()">
                                        @entity.GetEntityTypeIcon() @entity.EntityType
                                    </span>
                                </td>
                                <td class="px-4 py-3">
                                    <div class="text-sm font-medium text-gray-900">@entity.Name</div>
                                    @if (!string.IsNullOrEmpty(entity.Description))
                                    {
                                        <div class="text-xs text-gray-400 truncate max-w-xs">@entity.Description</div>
                                    }
                                </td>
                                <td class="px-4 py-3 text-sm text-gray-700">@(entity.Group ?? "-")</td>
                                <td class="px-4 py-3 text-sm text-gray-700">@(entity.Owner ?? "-")</td>
                                <td class="px-4 py-3">
                                    @if (latestStatus != null)
                                    {
                                        <span class="inline-flex items-center gap-1 text-xs font-medium">
                                            <span class="w-2 h-2 rounded-full @GetDotClass(latestStatus.Status)"></span>
                                            @latestStatus.Status
                                        </span>
                                    }
                                    else { <span class="text-xs text-gray-400">Unknown</span> }
                                </td>
                                <td class="px-4 py-3">
                                    <span class="w-2 h-2 rounded-full inline-block @(entity.IsActive ? "bg-green-400" : "bg-gray-400")"></span>
                                    @if (entity.IsCritical) { <span class="ml-1 text-xs text-red-500">Critical</span> }
                                </td>
                                <td class="px-4 py-3 text-right" @onclick:stopPropagation="true">
                                    <button @onclick="() => EditEntity(entity.Id)" class="text-indigo-600 hover:text-indigo-900 text-sm mr-3" style="border:none;background:none;">Edit</button>
                                    <button @onclick="() => DeleteEntity(entity)" class="text-red-600 hover:text-red-900 text-sm" style="border:none;background:none;">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-center py-12 text-sm text-gray-500">
                    No entities found.
                    <button @onclick="CreateEntity" class="ml-1 text-indigo-600 hover:underline" style="border:none;background:none;">Create one</button>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<MonitoredAsset> entities = new();
    private List<MonitoredAsset> filteredEntities = new();
    private bool isLoading = true;
    private string searchFilter = "";
    private string typeFilter = "";
    private string statusFilter = "";

    private string queryParam => StateContainer.Company is null ? "" : $"?c={StateContainer.Company.Id}";

    protected override async Task OnInitializedAsync()
    {
        var companyId = StateContainer.Company?.Id;
        if (!string.IsNullOrEmpty(companyId))
            entities = await EntityService.GetEntitiesWithLatestStatusAsync(companyId);
        ApplyFilters();
        isLoading = false;
    }

    private void ApplyFilters()
    {
        var filtered = entities.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(searchFilter))
            filtered = filtered.Where(e => e.Name.Contains(searchFilter, StringComparison.OrdinalIgnoreCase) ||
                (e.Description?.Contains(searchFilter, StringComparison.OrdinalIgnoreCase) ?? false));
        if (!string.IsNullOrWhiteSpace(typeFilter) && Enum.TryParse<AssetType>(typeFilter, out var t))
            filtered = filtered.Where(e => e.EntityType == t);
        if (statusFilter == "active") filtered = filtered.Where(e => e.IsActive);
        else if (statusFilter == "inactive") filtered = filtered.Where(e => !e.IsActive);
        filteredEntities = filtered.ToList();
        StateHasChanged();
    }

    private void OnSearchChanged(ChangeEventArgs e) { searchFilter = e.Value?.ToString() ?? ""; ApplyFilters(); }

    private void CreateEntity() => Navigation.NavigateTo($"/status/entities/create{queryParam}");
    private void ViewEntity(string id) => Navigation.NavigateTo($"/status/entities/{id}{queryParam}");
    private void EditEntity(string id) => Navigation.NavigateTo($"/status/entities/{id}/edit{queryParam}");

    private async Task DeleteEntity(MonitoredAsset entity)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", $"Delete '{entity.Name}'?")) return;
        if (await EntityService.DeleteEntityAsync(entity.Id))
        {
            entities.Remove(entity);
            ApplyFilters();
        }
    }

    private string GetDotClass(AssetStatus s) => s switch
    {
        AssetStatus.Online => "bg-green-400",
        AssetStatus.Offline => "bg-red-400",
        AssetStatus.Error => "bg-red-400",
        AssetStatus.Degraded => "bg-yellow-400",
        AssetStatus.Maintenance => "bg-blue-400",
        _ => "bg-gray-400"
    };
}
