@page "/status"
@using Application.Shared.Models
@using Application.Shared.Enums
@using Application.Client.Services
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject MonitoredAssetClientService EntityService
@inject IncidentClientService IncidentService
@inject NavigationManager Navigation
@inject StateContainer StateContainer
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize]

<PageTitle>Status Overview</PageTitle>

<div class="min-h-screen bg-gray-50 p-6">
    @if (!canView && !isLoading)
    {
        <div class="flex flex-col items-center justify-center h-64 text-gray-500 gap-2">
            <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <p class="text-sm font-semibold text-gray-700">Access Denied</p>
            <p class="text-sm text-center">You need the <strong>@(StateContainer.Company?.Id)_VIEW_STATUS</strong> role to view this page.</p>
        </div>
    }
    else
    {
    <!-- Header -->
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Status Overview</h1>
        <p class="mt-1 text-sm text-gray-500">Monitor the health and status of all your entities</p>
    </div>

    @if (isLoading)
    {
        <div class="flex justify-center items-center h-64">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-indigo-600"></div>
        </div>
    }
    else
    {
        <!-- Summary Cards -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
            <div class="bg-white rounded-lg border border-gray-200 p-4">
                <div class="text-sm font-medium text-gray-500">Total Entities</div>
                <div class="mt-1 text-2xl font-semibold text-gray-900">@entities.Count</div>
            </div>
            <div class="bg-white rounded-lg border border-green-200 p-4">
                <div class="text-sm font-medium text-green-600">Online</div>
                <div class="mt-1 text-2xl font-semibold text-green-700">@statusSummary.GetValueOrDefault("Online", 0)</div>
            </div>
            <div class="bg-white rounded-lg border border-red-200 p-4">
                <div class="text-sm font-medium text-red-600">Offline / Error</div>
                <div class="mt-1 text-2xl font-semibold text-red-700">@(statusSummary.GetValueOrDefault("Offline", 0) + statusSummary.GetValueOrDefault("Error", 0))</div>
            </div>
            <div class="bg-white rounded-lg border border-orange-200 p-4">
                <div class="text-sm font-medium text-orange-600">Active Incidents</div>
                <div class="mt-1 text-2xl font-semibold text-orange-700">@activeIncidents.Count</div>
            </div>
        </div>

        <!-- Active Incidents -->
        @if (activeIncidents.Any())
        {
            <div class="bg-white rounded-lg border border-red-200 mb-6">
                <div class="px-4 py-3 border-b border-red-200 flex items-center justify-between">
                    <h2 class="text-base font-semibold text-red-700">🔴 Active Incidents</h2>
                    <button @onclick='() => Navigation.NavigateTo($"status/incidents{queryParam}")' class="text-sm text-red-600 hover:text-red-800">View all →</button>
                </div>
                <ul class="divide-y divide-gray-100">
                    @foreach (var incident in activeIncidents.Take(5))
                    {
                        <li class="px-4 py-3 hover:bg-gray-50 cursor-pointer" @onclick='() => Navigation.NavigateTo($"status/incidents/{incident.Id}{queryParam}")'>
                            <div class="flex items-center justify-between">
                                <div>
                                    <span class="text-sm font-medium text-gray-900">@incident.Title</span>
                                    <span class="ml-2 text-xs text-gray-500">@incident.Entity?.Name</span>
                                </div>
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium @incident.GetSeverityClass()">@incident.Severity</span>
                            </div>
                        </li>
                    }
                </ul>
            </div>
        }

        <!-- Entities Grid -->
        <div class="bg-white rounded-lg border border-gray-200">
            <div class="px-4 py-3 border-b border-gray-200 flex items-center justify-between">
                <h2 class="text-base font-semibold text-gray-900">Entities</h2>
                <button @onclick='() => Navigation.NavigateTo($"status/entities{queryParam}")' class="text-sm text-indigo-600 hover:text-indigo-800">Manage →</button>
            </div>
            @if (entities.Any())
            {
                <div class="divide-y divide-gray-100">
                    @foreach (var entity in entities.Take(20))
                    {
                        <div class="px-4 py-3 flex items-center justify-between hover:bg-gray-50 cursor-pointer"
                             @onclick='() => Navigation.NavigateTo($"status/entities/{entity.Id}{queryParam}")'>
                            <div class="flex items-center gap-3">
                                <span class="text-lg">@entity.GetEntityTypeIcon()</span>
                                <div>
                                    <span class="text-sm font-medium text-gray-900">@entity.Name</span>
                                    @if (!string.IsNullOrEmpty(entity.Group) && entity.Group != "Default")
                                    {
                                        <span class="ml-2 text-xs text-gray-400">@entity.Group</span>
                                    }
                                </div>
                            </div>
                            <div class="flex items-center gap-2">
                                @if (entity.IsCritical)
                                {
                                    <span class="text-xs text-red-500 font-medium">Critical</span>
                                }
                                @{
                                    var latestStatus = entity.StatusHistory?.OrderByDescending(s => s.CheckedAt).FirstOrDefault();
                                }
                                @if (latestStatus != null)
                                {
                                    <span class="inline-flex items-center gap-1 text-xs font-medium @GetStatusClass(latestStatus.Status)">
                                        <span class="w-1.5 h-1.5 rounded-full @GetStatusDotClass(latestStatus.Status)"></span>
                                        @latestStatus.Status
                                    </span>
                                }
                                else
                                {
                                    <span class="text-xs text-gray-400">Unknown</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-8 text-sm text-gray-500">
                    No entities yet. <button @onclick='() => Navigation.NavigateTo($"status/entities{queryParam}")' class="text-indigo-600 hover:underline">Create one</button>
                </div>
            }
        </div>
    } @* end else isLoading *@
    } @* end else canView *@
</div>

@code {
    private List<MonitoredAsset> entities = new();
    private List<Incident> activeIncidents = new();
    private Dictionary<string, int> statusSummary = new();
    private bool isLoading = true;
    private bool canView = false;

    private string queryParam => StateContainer.Company is null ? "" : $"?c={StateContainer.Company.Id}";

    protected override async Task OnInitializedAsync()
    {
        var companyId = StateContainer.Company?.Id;
        if (string.IsNullOrEmpty(companyId)) { isLoading = false; return; }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        canView = authState.User.IsInRole($"{companyId}_VIEW_STATUS");
        if (!canView) { isLoading = false; return; }

        entities = await EntityService.GetEntitiesWithLatestStatusAsync(companyId);
        activeIncidents = await IncidentService.GetActiveIncidentsAsync(companyId);
        statusSummary = await EntityService.GetEntityStatusSummaryAsync(companyId);
        isLoading = false;
    }

    private string GetStatusClass(AssetStatus status) => status switch
    {
        AssetStatus.Online => "text-green-700",
        AssetStatus.Offline => "text-red-700",
        AssetStatus.Error => "text-red-700",
        AssetStatus.Degraded => "text-yellow-700",
        AssetStatus.Maintenance => "text-blue-700",
        _ => "text-gray-500"
    };

    private string GetStatusDotClass(AssetStatus status) => status switch
    {
        AssetStatus.Online => "bg-green-500",
        AssetStatus.Offline => "bg-red-500",
        AssetStatus.Error => "bg-red-500",
        AssetStatus.Degraded => "bg-yellow-500",
        AssetStatus.Maintenance => "bg-blue-500",
        _ => "bg-gray-400"
    };
}
