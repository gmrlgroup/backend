@using Microsoft.AspNetCore.Identity
@using Application.Shared.Models.User;

@inject SignInManager<ApplicationUser> SignInManager

<nav class="acct-nav">
    <NavLink class="acct-nav-link" href="Account/Manage" Match="NavLinkMatch.All" ActiveClass="active">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" />
        </svg>
        <span>Profile</span>
    </NavLink>

    <NavLink class="acct-nav-link" href="Account/Manage/Email" ActiveClass="active">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <rect x="2" y="4" width="20" height="16" rx="2" /><path d="m22 7-10 5L2 7" />
        </svg>
        <span>Email</span>
    </NavLink>

    <NavLink class="acct-nav-link" href="Account/Manage/ChangePassword" ActiveClass="active">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" />
        </svg>
        <span>Password</span>
    </NavLink>

    @if (hasExternalLogins)
    {
        <NavLink class="acct-nav-link" href="Account/Manage/ExternalLogins" ActiveClass="active">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" /><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
            </svg>
            <span>External logins</span>
        </NavLink>
    }

    <NavLink class="acct-nav-link" href="Account/Manage/TwoFactorAuthentication" ActiveClass="active">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
        </svg>
        <span>Two-factor auth</span>
    </NavLink>

    <NavLink class="acct-nav-link" href="Account/Manage/PersonalData" ActiveClass="active">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <ellipse cx="12" cy="5" rx="9" ry="3" /><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" /><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3" />
        </svg>
        <span>Personal data</span>
    </NavLink>
</nav>


@code {
    private bool hasExternalLogins;

    protected override async Task OnInitializedAsync()
    {
        hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
    }
}
