<div class="ds-card">
    <div class="acct-section-pad">
        <h2 class="acct-card-title">Recovery codes</h2>

        <StatusMessage Message="@StatusMessage" />

        <div class="acct-alert warning" role="alert">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z" /><line x1="12" y1="9" x2="12" y2="13" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
            <span>
                <strong>Put these codes in a safe place.</strong>
                <p>If you lose your device and don't have the recovery codes you will lose access to your account.</p>
            </span>
        </div>

        <div class="acct-codes">
            @foreach (var recoveryCode in RecoveryCodes)
            {
                <code>@recoveryCode</code>
            }
        </div>
    </div>
</div>


@code {
    [Parameter]
    public string[] RecoveryCodes { get; set; } = [];

    [Parameter]
    public string? StatusMessage { get; set; }
}
